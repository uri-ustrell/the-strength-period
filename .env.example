# Required (server-side, used by /api/generate-plan)
# Get your Gemini API key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: overrides default model (gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional frontend-only mock flag (MSW)
# Default false keeps real API-first local behavior
VITE_MOCK_API=false

# Optional Step 18 preset pipeline (Claude API)
# Required only for live `npm run presets` calls without --response-file
# CLAUDE_API_KEY=your-claude-api-key
# Set to true only when free-tier quota is available for your Claude account
# CLAUDE_FREE_TIER_AVAILABLE=false

# Optional Step 18 photo pipeline providers
# HUGGINGFACE_API_TOKEN=hf_xxx
# NANOBANANA_API_KEY=your-nanobanana-key
# Set true only when Nanobanana free tier is confirmed
# NANOBANANA_FREE_TIER_AVAILABLE=false
# NANOBANANA_ENDPOINT=https://api.nanobanana.ai/v1/images
