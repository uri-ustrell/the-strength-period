  "weighted_vest_pushup_v1": "Weight Vest Push-Up",
  "weighted_vest_ruck_walk_v1": "Weight Vest Ruck Walk",
  "weighted_vest_squat_v1": "Weight Vest Squat",
  "weighted_vest_step_up_v1": "Weight Vest Step-Up",
  "wide_grip_pullup_v1": "Wide-Grip Pull-Up",
  "Wide-Grip_Lat_Pulldown": "Wide-Grip Lat Pulldown",
  "world_greatest_stretch_v1": "World's Greatest Stretch",
  "wrist_warmup_circles_v1": "Wrist Warm-up Circles",
  "ytwl_complex_v1": "YTWL Complex",
  "instructions": {
    "ab_wheel_rollout_v1": [
      "Kneel on the floor holding an ab wheel under the shoulders.",
      "Roll the wheel forward keeping the spine neutral and ribs down.",
      "Pull back to the start without losing the brace."
    ],
    "alternate_nostril_breathing_v1": [
      "Sit comfortably and bring the right hand to the face with thumb on the right nostril and ring finger on the left.",
      "Close the right nostril and inhale through the left, then close the left and exhale through the right.",
      "Inhale through the right, close it and exhale through the left; continue alternating."
    ],
    "ankle_rocking_v1": [
      "Kneel on one knee with the front foot flat and hands on the front thigh.",
      "Drive the front knee forward over the toes feeling a stretch in the ankle, keeping the heel down.",
      "Return and repeat for reps; switch sides."
    ],
    "band_bicep_curl_v1": [
      "Stand on the center of the band; grip ends with palms up and arms at your sides.",
      "Curl the handles toward your shoulders, keeping elbows fixed at your sides without swinging.",
      "Lower under control over 2 sec."
    ],
    "band_chest_fly_v1": [
      "Anchor two bands at chest height behind you and grip a handle in each hand with arms out to the sides.",
      "Bring the hands together in front of the chest in an arc squeezing the chest.",
      "Return slowly to the start."
    ],
    "band_chest_press_standing_v1": [
      "Anchor a resistance band behind you at chest height (door or stable weight).",
      "Grip one end in each hand, one foot slightly forward for stability.",
      "Press handles forward until arms are nearly extended; return slowly over 2 sec."
    ],
    "band_concentration_curl_v1": [
      "Sit and step one foot on a band, holding the other end with the same-side hand.",
      "Brace the elbow against the inner thigh and curl the band up.",
      "Lower slowly back to the start; complete reps before switching sides."
    ],
    "band_external_rotation_v1": [
      "Anchor a band at elbow height and stand sideways gripping it with the far hand, elbow tucked at 90°.",
      "Rotate the forearm out away from the body keeping the elbow pinned to the side.",
      "Return slowly; complete reps before switching sides."
    ],
    "band_face_pull_v1": [
      "Anchor a band at face height and stand back so it has tension, holding the ends with palms down.",
      "Pull the band toward the face leading with the elbows wide and externally rotating the shoulders.",
      "Return in 2 seconds without losing band tension."
    ],
    "band_internal_rotation_v1": [
      "Anchor a band at elbow height and stand sideways gripping it with the near hand, elbow tucked at 90°.",
      "Rotate the forearm in across the body keeping the elbow pinned.",
      "Return slowly; complete reps before switching sides."
    ],
    "band_lateral_walk_v1": [
      "Place a resistance band around your ankles or just above knees; stand with knees slightly bent.",
      "Take controlled lateral steps, maintaining constant band tension and a stable core.",
      "Do not let feet come together fully to keep the band under tension throughout."
    ],
    "band_monster_walk_v1": [
      "Place a mini band around the ankles or just above the knees and adopt a quarter-squat stance.",
      "Step forward and out alternating legs to keep tension on the band.",
      "Continue for the prescribed reps or distance."
    ],
    "band_overhead_press_v1": [
      "Stand on the center of the band with feet hip-width apart; grip ends at shoulder height.",
      "Press handles overhead until arms are nearly extended, keeping core braced.",
      "Lower slowly back to shoulder height and repeat."
    ],
    "band_seated_abduction_v1": [
      "Sit on a bench with a mini band around the thighs just above the knees.",
      "Press the knees apart against the band keeping the feet flat.",
      "Return slowly to the start."
    ],
    "band_squat_v1": [
      "Place a resistance band just above your knees; stand with feet hip-width apart.",
      "Push your knees out against the band resistance throughout the squat.",
      "Lower to parallel or below; drive up through your heels."
    ],
    "band_tricep_overhead_extension_v1": [
      "Anchor a band low and stand facing away holding the band overhead with both hands.",
      "Bend the elbows lowering the band behind the head.",
      "Extend the arms back to the start under control."
    ],
    "band_tricep_pushdown_v1": [
      "Anchor a band overhead and grip the ends with elbows tucked at the sides.",
      "Press the band down by extending the elbows fully without moving the upper arms.",
      "Return in 2 seconds back to the starting position."
    ],
    "Barbell_Deadlift": [
      "Stand in front of a loaded barbell.",
      "While keeping the back as straight as possible, bend your knees, bend forward and grasp the bar using a medium (shoulder width) overhand grip. This will be the starting position of the exercise. Tip: If it is difficult to hold on to the bar with this grip, alternate your grip or use wrist straps.",
      "While holding the bar, start the lift by pushing with your legs while simultaneously getting your torso to the upright position as you breathe out. In the upright position, stick your chest out and contract the back by bringing the shoulder blades back. Think of how the soldiers in the military look when they are in standing in attention.",
      "Go back to the starting position by bending at the knees while simultaneously leaning the torso forward at the waist while keeping the back straight. When the weights on the bar touch the floor you are back at the starting position and ready to perform another repetition.",
      "Perform the amount of repetitions prescribed in the program."
    ],
    "Barbell_Squat": [
      "This exercise is best performed inside a squat rack for safety purposes. To begin, first set the bar on a rack to just below shoulder level. Once the correct height is chosen and the bar is loaded, step under the bar and place the back of your shoulders (slightly below the neck) across it.",
      "Hold on to the bar using both arms at each side and lift it off the rack by first pushing with your legs and at the same time straightening your torso.",
      "Step away from the rack and position your legs using a shoulder width medium stance with the toes slightly pointed out. Keep your head up at all times and also maintain a straight back. This will be your starting position. (Note: For the purposes of this discussion we will use the medium stance described above which targets overall development; however you can choose any of the three stances discussed in the foot stances section).",
      "Begin to slowly lower the bar by bending the knees and hips as you maintain a straight posture with the head up. Continue down until the angle between the upper leg and the calves becomes slightly less than 90-degrees. Inhale as you perform this portion of the movement. Tip: If you performed the exercise correctly, the front of the knees should make an imaginary straight line with the toes that is perpendicular to the front. If your knees are past that imaginary line (if they are past your toes) then you are placing undue stress on the knee and the exercise has been performed incorrectly.",
      "Begin to raise the bar as you exhale by pushing the floor with the heel of your foot as you straighten the legs again and go back to the starting position.",
      "Repeat for the recommended amount of repetitions."
    ],
    "bb_bench_press_v1": [
      "Lie on a bench with the barbell over the chest, hands just outside shoulder width.",
      "Lower the bar to the chest in 2–3 seconds tucking the elbows ~45°.",
      "Press the bar back up to lockout."
    ],
    "bb_bent_over_row_v1": [
      "Hinge at the hips to about a 45° torso angle, holding the barbell with an overhand grip just outside the knees.",
      "Pull the bar to the lower ribs by leading with the elbows and squeezing the shoulder blades.",
      "Lower in 2 seconds back to the start without rounding the back."
    ],
    "bb_bicep_curl_v1": [
      "Stand with the barbell at arm's length, hands shoulder-width apart, palms facing forward.",
      "Curl the bar up toward the shoulders without swinging the torso.",
      "Lower in 2–3 seconds under control to a full elbow extension."
    ],
    "bb_close_grip_bench_v1": [
      "Lie on a bench with the barbell gripped at shoulder-width, slight elbow tuck.",
      "Lower the bar to the lower chest in 2 seconds keeping the elbows tucked at ~30°.",
      "Press the bar back up to lockout without flaring the elbows."
    ],
    "bb_drag_curl_v1": [
      "Stand tall with the barbell at hip level, hands shoulder-width apart underhand.",
      "Curl the bar by dragging it up the body keeping the elbows behind the torso.",
      "Lower in 2–3 seconds back to the start."
    ],
    "bb_good_morning_v1": [
      "Stand with the barbell across the upper back, feet hip-width apart.",
      "Hinge at the hips with a slight knee bend lowering the torso toward parallel to the floor.",
      "Drive the hips forward to return to standing."
    ],
    "bb_hip_thrust_v1": [
      "Sit with the upper back against a bench and the barbell across the hips.",
      "Drive through the heels lifting the hips until the body forms a straight line from knees to shoulders.",
      "Lower the hips under control to the start."
    ],
    "bb_overhead_press_v1": [
      "Stand with feet hip-width apart and the barbell racked at the shoulders, hands just outside shoulder width.",
      "Press the bar straight up overhead, moving the head slightly forward as the bar passes the face.",
      "Lower in 2–3 seconds back to the front rack with the elbows tucked."
    ],
    "bb_pendlay_row_v1": [
      "Stand with feet hip-width apart and the barbell on the floor over the mid-foot.",
      "Hinge to a flat back parallel to the floor and grip the bar shoulder-width.",
      "Row the bar explosively to the lower ribs and lower it back to the floor under control between reps."
    ],
    "bb_rdl_v1": [
      "Stand with the barbell at hip level, hands shoulder-width apart.",
      "Hinge at the hips with a slight knee bend, sliding the bar down the thighs until you feel a hamstring stretch.",
      "Drive the hips forward to return to standing keeping the bar close to the body."
    ],
    "bb_shrug_v1": [
      "Stand with the barbell held at arm's length in front of the thighs, hands shoulder-width apart.",
      "Lift the shoulders straight up toward the ears without rolling them.",
      "Pause briefly at the top and lower the shoulders under control."
    ],
    "bird_dog_pregnancy_v1": [
      "Start on hands and knees with a neutral spine.",
      "Extend the opposite arm and leg keeping the hips and shoulders square to the floor.",
      "Lower under control and switch sides."
    ],
    "bird_dog_row_v1": [
      "Set up on three points with one knee and the opposite hand on a bench, the other arm holding a dumbbell and the free leg extended back.",
      "Row the dumbbell to the ribs without rotating the hips.",
      "Lower under control; complete reps before switching sides."
    ],
    "body_saw_plank_v1": [
      "Set up in a forearm plank with sliders or a towel under the feet.",
      "Push back through the elbows so the body slides toward the heels.",
      "Pull forward back to the plank position keeping the core braced."
    ],
    "body_scan_v1": [
      "Lie comfortably on the back with arms by the sides and eyes closed.",
      "Bring attention slowly through each body part from feet to head, noticing sensations without judgement.",
      "Breathe naturally for 10–20 minutes."
    ],
    "bottoms_up_kb_press_v1": [
      "Hold a kettlebell at the shoulder with the bell up and the handle gripped tight.",
      "Press the kettlebell overhead keeping the bell balanced upside down.",
      "Lower under control; complete reps before switching sides."
    ],
    "bound_alternating_v1": [
      "Run a few steps to gain rhythm.",
      "Push off one leg and jump forward and slightly up landing on the opposite leg.",
      "Continue alternating for the prescribed bounds focusing on horizontal distance."
    ],
    "box_breathing_v1": [
      "Sit comfortably with the spine tall and shoulders relaxed.",
      "Inhale through the nose for 4 seconds, hold for 4 seconds.",
      "Exhale for 4 seconds, hold empty for 4 seconds; repeat the cycle."
    ],
    "box_jump_v1": [
      "Stand a foot away from a sturdy box with feet hip-width apart.",
      "Swing the arms back, hinge briefly and jump explosively landing softly on top of the box with knees bent.",
      "Step down (do not jump down) to start the next rep."
    ],
    "box_squat_jump_v1": [
      "Sit on a low box with feet flat and torso upright.",
      "Drive through the feet jumping explosively up off the box.",
      "Land softly, sit back down briefly and repeat."
    ],
    "bridge_kegel_v1": [
      "Lie supine with knees bent and feet hip-width apart.",
      "Exhale lifting the hips while gently engaging the pelvic floor.",
      "Inhale lowering the hips and relaxing the pelvic floor; repeat."
    ],
    "bridge_pose_yoga_v1": [
      "Lie on the back with knees bent and feet hip-width apart.",
      "Press into the feet and lift the hips toward the ceiling, optionally clasping the hands beneath the body.",
      "Hold breathing steadily and lower under control."
    ],
    "broad_jump_v1": [
      "Stand with feet hip-width apart, swing the arms back and bend the knees.",
      "Drive the arms forward and jump as far horizontally as possible.",
      "Land softly with knees bent; reset before the next rep."
    ],
    "bulgarian_split_squat_v1": [
      "Stand a stride away from a bench and place the top of one foot on it behind you.",
      "Lower into a lunge until the front thigh is parallel to the floor.",
      "Drive through the front foot to return to standing; complete reps before switching sides."
    ],
    "burpee_jump_v1": [
      "Stand with feet shoulder-width apart.",
      "Drop to a push-up position, perform one push-up, jump the feet to the hands and explode up into a vertical jump.",
      "Land softly and immediately repeat."
    ],
    "butterfly_breath_v1": [
      "Sit with the soles of the feet together and knees relaxed apart.",
      "Inhale and visualise the breath descending into the pelvis relaxing the floor.",
      "Exhale gently lifting the pelvic floor; continue for the prescribed time."
    ],
    "cat_cow_v1": [
      "Start on hands and knees with wrists under shoulders and knees under hips.",
      "Inhale and arch the spine dropping the belly while looking up (cow).",
      "Exhale and round the spine tucking the chin and pelvis (cat); alternate slowly."
    ],
    "childs_pose_v1": [
      "Kneel on the mat with big toes touching and knees apart.",
      "Sit the hips back to the heels and walk the hands forward extending the arms.",
      "Rest the forehead on the mat and breathe slowly into the back."
    ],
    "chinup_v1": [
      "Hang from a pull-up bar with palms facing the body shoulder-width.",
      "Pull the chest toward the bar by driving the elbows down.",
      "Lower in 2–3 seconds to a dead hang."
    ],
    "clap_pushup_v1": [
      "Set up in a high plank with hands shoulder-width apart.",
      "Lower the chest and press up explosively clapping the hands together at the top.",
      "Land softly with elbows soft and continue."
    ],
    "close_grip_pushup_v1": [
      "Set up in a high plank with hands directly under the shoulders or slightly closer.",
      "Lower the chest with the elbows tracking close to the ribs.",
      "Press back up to the start without flaring the elbows."
    ],
    "cobra_pose_v1": [
      "Lie face-down with hands under the shoulders and elbows tucked.",
      "Press lightly into the hands lifting the chest off the floor with the elbows still bent.",
      "Hold breathing steadily; lower under control."
    ],
    "coherent_breathing_v1": [
      "Sit or lie comfortably with the spine in neutral.",
      "Inhale through the nose for 5 seconds expanding the belly and ribs.",
      "Exhale through the nose for 5 seconds; continue at this pace for 5–10 minutes."
    ],
    "copenhagen_plank_v1": [
      "Lie on your side with the top leg resting on a bench at ankle or knee height.",
      "Lift the hips into a side plank pressing the top leg down on the bench.",
      "Hold without dropping the hips for the prescribed time."
    ],
    "cossack_squat_v1": [
      "Stand with feet wider than shoulder-width.",
      "Shift the weight to one side bending that knee while the other leg stays straight with toes up.",
      "Push back to centre and alternate sides."
    ],
    "couch_stretch_v1": [
      "Kneel facing away from a wall or couch, place one shin against the wall with the foot pointing up and the other foot flat in front in a lunge.",
      "Squeeze the back glute and lift the chest tall, keeping the lower back neutral.",
      "Hold for 30–60 seconds breathing slowly; switch sides."
    ],
    "cuban_press_db_v1": [
      "Stand with a light dumbbell in each hand and elbows bent to 90° at chest height.",
      "Externally rotate the shoulders bringing the dumbbells to the ears.",
      "Press overhead, then reverse the motion to return."
    ],
    "curtsy_lunge_v1": [
      "Stand tall with feet hip-width apart.",
      "Step one foot back and across the body lowering into a curtsy lunge.",
      "Return to standing and alternate sides."
    ],
    "db_arnold_press_v1": [
      "Sit on a bench with back support, holding two dumbbells in front of the shoulders, palms facing the body.",
      "Press the dumbbells overhead while rotating the palms outward until the arms are fully extended.",
      "Reverse the motion in 2 seconds back to the starting position."
    ],
    "db_bulgarian_split_squat_v1": [
      "Hold a dumbbell in each hand and stand a stride away from a bench with one foot resting on it behind you.",
      "Lower into a lunge until the front thigh is parallel to the floor.",
      "Drive through the front foot to return to standing."
    ],
    "db_chest_fly_v1": [
      "Lie on a bench with a dumbbell in each hand pressed over the chest, elbows slightly bent.",
      "Lower the dumbbells out to the sides in an arc until you feel a chest stretch.",
      "Reverse the motion squeezing the chest at the top."
    ],
    "db_chest_supported_row_v1": [
      "Lie face-down on an incline bench set to ~30°, holding a dumbbell in each hand with arms hanging.",
      "Row both dumbbells toward the rib cage by squeezing the shoulder blades together.",
      "Lower in 2 seconds back to full extension."
    ],
    "db_concentration_curl_v1": [
      "Sit on a bench with legs spread, holding a dumbbell in one hand and bracing that elbow against the inner thigh.",
      "Curl the dumbbell up to the shoulder while keeping the elbow fixed against the thigh.",
      "Lower in 2 seconds and repeat for all reps before switching arms."
    ],
    "db_cross_body_hammer_curl_v1": [
      "Stand tall with a dumbbell in each hand, palms facing the body.",
      "Curl one dumbbell across the body toward the opposite shoulder.",
      "Lower under control and alternate sides."
    ],
    "db_decline_press_v1": [
      "Lie on a decline bench with a dumbbell in each hand at chest height.",
      "Press both dumbbells up over the chest until the arms are extended.",
      "Lower in 2–3 seconds back to the chest."
    ],
    "db_flat_press_v1": [
      "Lie on a bench with a dumbbell in each hand at chest height.",
      "Press both dumbbells up over the chest until the arms are extended.",
      "Lower in 2–3 seconds back to the chest."
    ],
    "db_front_raise_v1": [
      "Stand tall with a dumbbell in each hand resting on the front of the thighs.",
      "Raise the dumbbells straight up to shoulder height with arms slightly bent.",
      "Lower in 2–3 seconds back to the thighs."
    ],
    "db_hammer_curl_v1": [
      "Stand with a dumbbell in each hand by the sides, palms facing the body (neutral grip).",
      "Curl the dumbbells up toward the shoulders without rotating the wrists.",
      "Lower in 2–3 seconds under control."
    ],
    "db_hip_thrust_v1": [
      "Sit with the upper back against a bench and a dumbbell on the hips.",
      "Drive through the heels lifting the hips until the body forms a straight line.",
      "Lower the hips under control to the start."
    ],
    "db_incline_bench_press_v1": [
      "Set an adjustable bench to a 30–45° incline and lie back with a dumbbell in each hand at shoulder height, palms facing forward.",
      "Press both dumbbells up and slightly inward until the arms are extended without locking the elbows.",
      "Lower the dumbbells in 2–3 seconds until the elbows reach roughly chest level, keeping the shoulder blades retracted."
    ],
    "db_incline_curl_v1": [
      "Sit on an incline bench with a dumbbell in each hand and arms hanging down.",
      "Curl the dumbbells up keeping the elbows pinned at the sides.",
      "Lower in 2–3 seconds back to a full stretch."
    ],
    "db_kickback_v1": [
      "Hinge at the hips holding a dumbbell with one hand and brace with the other on a bench or knee.",
      "With the upper arm parallel to the floor, extend the elbow back until the arm is straight.",
      "Lower under control to 90°; complete reps before switching sides."
    ],
    "db_kroc_row_v1": [
      "Hinge at the hips with one hand braced on a stable surface and a heavy dumbbell in the other.",
      "Row the dumbbell explosively to the hip allowing some controlled body english.",
      "Lower under control; complete reps before switching sides."
    ],
    "db_lateral_raise_v1": [
      "Stand with a dumbbell in each hand, arms relaxed by the sides, slight bend in the elbows.",
      "Raise both arms out to the sides until they reach shoulder height, leading with the elbows.",
      "Lower in 2–3 seconds back to the starting position without swinging."
    ],
    "db_lying_external_rotation_v1": [
      "Lie on one side with a light dumbbell in the top hand and the elbow tucked at 90° on the ribs.",
      "Rotate the forearm up to the ceiling without moving the elbow.",
      "Lower under control; complete reps before switching sides."
    ],
    "db_meadows_row_v1": [
      "Stand in a staggered stance and hinge at the hips, bracing one hand on the front knee.",
      "Row a dumbbell from the floor up to the hip with the other hand keeping the elbow high.",
      "Lower under control; complete reps before switching sides."
    ],
    "db_overhead_tricep_extension_v1": [
      "Stand or sit holding a dumbbell with both hands overhead, arms extended.",
      "Bend the elbows lowering the dumbbell behind the head.",
      "Extend the arms back to the start without flaring the elbows."
    ],
    "db_pullover_lat_v1": [
      "Lie on a bench holding a dumbbell with both hands above the chest, arms slightly bent.",
      "Lower the dumbbell back over the head until you feel a stretch through the lats and chest.",
      "Pull the dumbbell back over the chest contracting the lats."
    ],
    "db_pullover_v1": [
      "Lie supine on a bench with both hands holding one dumbbell over the chest, elbows slightly bent.",
      "Lower the dumbbell behind the head in an arc until you feel a stretch across the lats and chest, keeping the lower back in contact with the bench.",
      "Pull the dumbbell back over the chest under control."
    ],
    "db_rdl_v1": [
      "Stand with a dumbbell in each hand resting on the front of the thighs.",
      "Hinge at the hips with a slight knee bend, lowering the dumbbells along the legs.",
      "Drive the hips forward to return to standing squeezing the glutes at the top."
    ],
    "db_rear_delt_fly_v1": [
      "Hinge forward at the hips with a flat back, holding light dumbbells with arms hanging down, palms facing each other.",
      "Raise both arms out to the sides squeezing the shoulder blades together until the upper arms reach torso level.",
      "Lower in 2 seconds back to the start under control."
    ],
    "db_rear_delt_row_v1": [
      "Hinge at the hips with a dumbbell in each hand, arms hanging.",
      "Row the dumbbells to the sides flaring the elbows wide squeezing the rear delts.",
      "Lower in 2–3 seconds back to the start."
    ],
    "db_renegade_row_v1": [
      "Set up in a push-up position with hands on two dumbbells placed shoulder-width apart, feet wider than hips.",
      "Row one dumbbell to the side of the rib cage while keeping the hips square to the floor.",
      "Lower under control and alternate sides for the prescribed reps."
    ],
    "db_seated_overhead_press_v1": [
      "Sit upright on a bench with a dumbbell in each hand at the shoulders, palms forward.",
      "Press both dumbbells overhead until the arms are fully extended.",
      "Lower in 2–3 seconds back to the shoulders."
    ],
    "db_side_bend_v1": [
      "Stand tall with a dumbbell in one hand and the other hand on the head.",
      "Bend laterally toward the loaded side then return to upright contracting the opposite obliques.",
      "Complete reps before switching sides."
    ],
    "db_single_arm_row_v1": [
      "Place one knee and same-side hand on a bench, the other foot on the floor and a dumbbell in the free hand.",
      "Row the dumbbell to the side of the rib cage, leading with the elbow.",
      "Lower in 2 seconds and complete all reps before switching sides."
    ],
    "db_skullcrusher_v1": [
      "Lie on a bench with two dumbbells extended over the chest, palms facing each other.",
      "Bend the elbows to lower the dumbbells toward the temples, keeping the upper arms vertical.",
      "Extend the elbows to return without flaring them out."
    ],
    "db_snatch_v1": [
      "Start with a dumbbell between the feet and hinge to grip it with one hand.",
      "Drive the hips forward explosively pulling the dumbbell straight overhead in one motion.",
      "Lower to the floor under control and complete reps before switching sides."
    ],
    "db_spider_curl_v1": [
      "Lie chest-down on an incline bench with a dumbbell in each hand and arms hanging vertically.",
      "Curl the dumbbells up squeezing the biceps at the top.",
      "Lower in 2–3 seconds back to a full stretch."
    ],
    "db_thruster_v1": [
      "Stand with a dumbbell in each hand racked at the shoulders.",
      "Squat down to parallel keeping the chest up.",
      "Drive up explosively and press the dumbbells overhead in one motion."
    ],
    "db_wrist_curl_v1": [
      "Sit with the forearm resting on a bench or thigh, dumbbell in hand palm up.",
      "Lower the dumbbell as the wrist extends, then curl the wrist back up.",
      "Repeat for the prescribed reps and switch sides."
    ],
    "db_z_press_v1": [
      "Sit on the floor with legs extended in front and a dumbbell in each hand at the shoulders.",
      "Press the dumbbells overhead while keeping the torso vertical.",
      "Lower in 2–3 seconds back to the shoulders."
    ],
    "db_zottman_curl_v1": [
      "Stand with a dumbbell in each hand at the sides, palms facing forward.",
      "Curl the dumbbells up to the shoulders, then rotate the wrists so the palms face down at the top.",
      "Lower in 3 seconds with the palms down, rotating back to palms-up at the bottom."
    ],
    "dead_bug_loaded_v1": [
      "Lie on the back with arms straight up holding a light dumbbell and knees over the hips.",
      "Lower the opposite arm and leg toward the floor without arching the lower back.",
      "Return to start and alternate sides."
    ],
    "dead_bug_neutral_pelvis_v1": [
      "Lie supine with arms reaching to the ceiling and knees stacked over hips at 90°.",
      "Exhale gently engaging the core and lower the opposite arm and leg toward the floor without arching the back.",
      "Inhale to return; alternate sides."
    ],
    "dead_hang_v1": [
      "Hang from a pull-up bar with both hands shoulder-width apart and arms fully extended.",
      "Relax the shoulders and let them stretch up while gripping firmly.",
      "Hold for the prescribed time."
    ],
    "deep_squat_release_v1": [
      "Stand with feet slightly wider than hips, toes turned out.",
      "Squat down as low as comfortable, using a wall or support if needed.",
      "Hold for 30–60 seconds breathing slowly into the pelvic floor."
    ],
    "depth_drop_jump_v1": [
      "Stand on top of a box of moderate height (30–60 cm).",
      "Step off the box and as soon as you land, rebound immediately into a maximal vertical jump.",
      "Land softly and reset before the next rep."
    ],
    "depth_jump_v1": [
      "Stand on a box (20–40 cm), step off and land on both feet simultaneously.",
      "Upon landing, absorb into a squat and immediately jump upward to maximize reactive power.",
      "Minimize ground contact time. Stop the exercise if landing feels stiff or a joint signals pain."
    ],
    "diaphragmatic_breathing_v1": [
      "Lie on the back with knees bent and one hand on the chest, the other on the belly.",
      "Inhale slowly through the nose for 4 seconds expanding the belly while the chest stays relatively still.",
      "Exhale through pursed lips for 6 seconds; repeat for the prescribed time."
    ],
    "downward_dog_v1": [
      "From hands and knees, tuck the toes and lift the hips up and back into an inverted V shape.",
      "Press the chest toward the thighs and the heels toward the floor without locking the knees.",
      "Hold breathing steadily for the prescribed time."
    ],
    "Dumbbell_Bicep_Curl": [
      "Stand up straight with a dumbbell in each hand at arm's length. Keep your elbows close to your torso and rotate the palms of your hands until they are facing forward. This will be your starting position.",
      "Now, keeping the upper arms stationary, exhale and curl the weights while contracting your biceps. Continue to raise the weights until your biceps are fully contracted and the dumbbells are at shoulder level. Hold the contracted position for a brief pause as you squeeze your biceps.",
      "Then, inhale and slowly begin to lower the dumbbells back to the starting position.",
      "Repeat for the recommended amount of repetitions."
    ],
    "Dumbbell_Lunges": [
      "Stand with your torso upright holding two dumbbells in your hands by your sides. This will be your starting position.",
      "Step forward with your right leg around 2 feet or so from the foot being left stationary behind and lower your upper body down, while keeping the torso upright and maintaining balance. Inhale as you go down. Note: As in the other exercises, do not allow your knee to go forward beyond your toes as you come down, as this will put undue stress on the knee joint. Make sure that you keep your front shin perpendicular to the ground.",
      "Using mainly the heel of your foot, push up and go back to the starting position as you exhale.",
      "Repeat the movement for the recommended amount of repetitions and then perform with the left leg."
    ],
    "Dumbbell_Shoulder_Press": [
      "While holding a dumbbell in each hand, sit on a military press bench or utility bench that has back support. Place the dumbbells upright on top of your thighs.",
      "Now raise the dumbbells to shoulder height one at a time using your thighs to help propel them up into position.",
      "Make sure to rotate your wrists so that the palms of your hands are facing forward. This is your starting position.",
      "Now, exhale and push the dumbbells upward until they touch at the top.",
      "Then, after a brief pause at the top contracted position, slowly lower the weights back down to the starting position while inhaling.",
      "Repeat for the recommended amount of repetitions."
    ],
    "eccentric_calf_raise_v1": [
      "Stand on the edge of a step with the ball of your foot, holding a wall for balance.",
      "Rise on both toes (concentric), then slowly lower on one leg over 4–5 sec, letting the heel drop below the step level.",
      "Return with both legs and repeat. Progress by adding load or increasing reps."
    ],
    "fitball_dead_bug_v1": [
      "Lie supine holding a fitball between the hands and knees with arms and legs at 90°.",
      "Press hands and knees into the ball as you extend the opposite arm and leg without losing pressure.",
      "Return and alternate sides under control."
    ],
    "fitball_pelvic_circles_v1": [
      "Sit on a fitball with feet flat and the spine tall.",
      "Make slow circles with the hips in one direction.",
      "Reverse direction for the same number of reps; breathe naturally."
    ],
    "fitball_pelvic_tilt_v1": [
      "Sit on a fitball with feet flat and hands on the hips.",
      "Tilt the pelvis forward and back slowly without moving the upper body.",
      "Repeat smoothly coordinating with the breath."
    ],
    "fitball_wall_squat_v1": [
      "Place a fitball between the lower back and a wall, feet shoulder-width apart and slightly forward.",
      "Squat down rolling the ball with you until the thighs are parallel to the floor.",
      "Hold or stand back up under control."
    ],
    "foam_roll_glutes_v1": [
      "Sit on a foam roller with one ankle crossed over the opposite knee.",
      "Lean toward the crossed-leg side and roll slowly across the glute.",
      "Pause on tight spots and breathe; switch sides."
    ],
    "foam_roll_quads_v1": [
      "Lie face-down with the foam roller across the front of the thighs, supporting the upper body on the forearms.",
      "Roll slowly from above the knees to the hip flexors.",
      "Pause on tight spots and breathe; avoid rolling directly on the kneecap."
    ],
    "foam_roll_thoracic_v1": [
      "Lie back on a foam roller placed across the upper back, knees bent and hands behind the head.",
      "Lift the hips slightly and roll up and down between the shoulder blades and mid-back.",
      "Pause on tight spots and breathe slowly; avoid the lumbar spine."
    ],
    "four_seven_eight_breathing_v1": [
      "Sit comfortably and place the tongue tip behind the upper teeth.",
      "Inhale silently through the nose for 4 seconds, hold the breath for 7 seconds.",
      "Exhale audibly through the mouth for 8 seconds; repeat for 4 cycles."
    ],
    "front_foot_elevated_split_squat_v1": [
      "Place the front foot on a step or low platform with the back foot on the floor in a split stance.",
      "Lower the back knee toward the floor keeping the torso tall.",
      "Drive through the front foot to return to standing."
    ],
    "glute_bridge_march_v1": [
      "Lie on the back with knees bent and feet flat.",
      "Lift the hips into a glute bridge.",
      "Hold the bridge while marching one knee toward the chest, then alternate without dropping the hips."
    ],
    "half_kneeling_chop_v1": [
      "Anchor a band high and assume a half-kneeling stance with the inside knee down.",
      "Pull the band diagonally down across the body to the outside hip.",
      "Return slowly; complete reps before switching sides."
    ],
    "half_kneeling_lift_v1": [
      "Anchor a band low and assume a half-kneeling stance with the outside knee down.",
      "Pull the band diagonally up across the body to overhead on the opposite side.",
      "Return slowly; complete reps before switching sides."
    ],
    "handstand_pushup_wall_v1": [
      "Kick up to a handstand against a wall with hands shoulder-width apart.",
      "Lower the head toward the floor by bending the elbows.",
      "Press back up to a full handstand without breaking form."
    ],
    "hang_clean_v1": [
      "Stand with the barbell at hip level, hands shoulder-width apart.",
      "Hinge to mid-thigh, explode up driving the hips and pull the bar to a front rack at the shoulders, dropping under to receive it.",
      "Stand fully and lower the bar to the start under control."
    ],
    "happy_baby_pose_v1": [
      "Lie on the back and bring the knees toward the armpits.",
      "Grab the outsides of the feet and gently pull them down toward the floor with shins vertical.",
      "Rock slightly side to side breathing slowly."
    ],
    "heel_slide_pelvic_v1": [
      "Lie supine with knees bent and feet flat on the mat.",
      "Exhale gently lifting the pelvic floor and slide one heel away until the leg is straight.",
      "Inhale to bring the heel back; alternate sides."
    ],
    "heel_slide_supine_v1": [
      "Lie supine with knees bent and feet flat on the mat.",
      "Exhale and slide one heel away on the floor until the leg is fully extended without arching the lower back.",
      "Inhale to slide the heel back; alternate sides."
    ],
    "hip_90_90_switch_v1": [
      "Sit with one shin in front parallel to the body and the other shin to the side, both at 90°.",
      "Lift the knees and rotate the hips to switch leg positions to the opposite side.",
      "Return slowly under control without using the hands."
    ],
    "hip_cars_v1": [
      "Stand on one leg, holding a wall for balance if needed.",
      "Lift the free knee to hip height, abduct it to the side, then rotate it back behind you and lower.",
      "Reverse the circle; switch sides."
    ],
    "hollow_body_hold_v1": [
      "Lie on the back with arms overhead and legs straight.",
      "Press the lower back into the floor and lift the shoulders and legs into a banana shape.",
      "Hold without losing contact between the lower back and the floor."
    ],
    "incline_plank_pregnancy_v1": [
      "Place the hands on a sturdy bench or chair shoulder-width apart.",
      "Step the feet back into a straight line from head to heels, exhaling and gently lifting the pelvic floor.",
      "Hold for the prescribed time breathing steadily; do not let the lower back sag."
    ],
    "inverted_row_feet_elevated_v1": [
      "Hang under a set of rings or a low bar with the heels resting on a bench, body in a straight line.",
      "Pull the chest to the rings driving the elbows back.",
      "Lower in 2–3 seconds back to the start."
    ],
    "kb_clean_v1": [
      "Start with the kettlebell on the floor between the feet, hinge at the hips and grip with one hand.",
      "Drive the hips forward to pull the kettlebell up, guiding the elbow back as the bell rotates around the wrist.",
      "Catch the kettlebell in the rack position at the shoulder, then reverse to the floor."
    ],
    "kb_double_clean_v1": [
      "Stand with two kettlebells on the floor between the feet.",
      "Hinge, grip both bells and drive the hips forward to clean both kettlebells to a double rack at the shoulders.",
      "Lower under control to the floor and repeat."
    ],
    "kb_double_press_v1": [
      "Start with two kettlebells racked at the shoulders, elbows tucked.",
      "Press both kettlebells overhead until the arms are fully extended.",
      "Lower in 2–3 seconds back to the rack."
    ],
    "kb_farmer_carry_v1": [
      "Hold a heavy kettlebell in each hand by the sides with shoulders packed and ribs down.",
      "Walk forward with controlled steps for the prescribed distance or time.",
      "Set the kettlebells down with a hip hinge, do not drop them."
    ],
    "kb_goblet_squat_v1": [
      "Hold a kettlebell at chest height with both hands cupping the bell.",
      "Squat down keeping the chest up and elbows tracking inside the knees.",
      "Stand back up driving through the mid-foot."
    ],
    "kb_halo_v1": [
      "Hold a light kettlebell upside down by the horns at chest height.",
      "Circle the kettlebell around the head close to the skull while keeping the elbows tucked.",
      "Reverse direction halfway through the set."
    ],
    "kb_press_v1": [
      "Stand with a kettlebell racked at the shoulder, elbow tucked, opposite hand at the side.",
      "Press the kettlebell overhead until the arm is fully extended and the bicep is near the ear.",
      "Lower in 2–3 seconds back to the rack and complete reps before switching sides."
    ],
    "kb_snatch_v1": [
      "Start with the kettlebell on the floor between the feet.",
      "Hinge, explosively drive the hips forward and pull the kettlebell straight overhead in one continuous motion punching the hand through at the top.",
      "Lower under control to the floor and switch hands as scheduled."
    ],
    "kb_swing_two_handed_v1": [
      "Stand with feet shoulder-width apart and the kettlebell on the floor in front.",
      "Hinge to grip the bell, hike it back between the legs and explosively snap the hips to swing it to chest height.",
      "Let it fall back between the legs in a controlled hinge and continue."
    ],
    "kb_swing_v1": [
      "Stand with feet shoulder-width apart, kettlebell on the floor about a foot in front.",
      "Hinge at the hips, grip the kettlebell with both hands and hike it back between the legs.",
      "Drive the hips forward explosively to swing the kettlebell up to chest height, then let it fall back into the next rep."
    ],
    "kb_turkish_get_up_v1": [
      "Lie on your back with one arm pressing a kettlebell overhead, same-side knee bent and foot flat.",
      "Roll up to the elbow, then to the hand, then sweep the straight leg under to a half-kneeling position, all while keeping the kettlebell stacked over the shoulder.",
      "Stand up under control and reverse every step back to the floor; alternate sides."
    ],
    "kb_windmill_v1": [
      "Stand with feet wider than shoulders and a light kettlebell pressed overhead in one hand.",
      "Rotate the feet 45° toward the empty hand and slide that hand down the inside of the leg while pushing the hips toward the loaded side.",
      "Return to standing under control by squeezing the obliques and glutes; switch sides."
    ],
    "kegel_basic_v1": [
      "Sit or lie comfortably with knees bent and a relaxed posture.",
      "Gently lift the pelvic floor as if stopping the flow of urine, hold for 3–5 seconds without holding the breath.",
      "Fully release for 5 seconds before the next repetition; quality matters more than quantity."
    ],
    "kegel_elevator_v1": [
      "Sit comfortably and visualise the pelvic floor as an elevator with several floors.",
      "Contract progressively in 3 levels (1st floor, 2nd floor, top floor) holding briefly at each.",
      "Release in the same 3 levels back down to full relaxation; breathe naturally."
    ],
    "kegel_quick_pulses_v1": [
      "Sit or lie comfortably with the spine in neutral.",
      "Perform short 1-second contractions of the pelvic floor followed by full 1-second releases.",
      "Keep the glutes and inner thighs relaxed; breathe normally throughout."
    ],
    "kegel_with_breath_v1": [
      "Lie supine with knees bent and one hand on the belly.",
      "Inhale relaxing the pelvic floor and expanding the belly.",
      "Exhale gently lifting the pelvic floor; repeat coordinating breath and contraction."
    ],
    "Lat_Pulldown": [
      "Sit down on a pull-down machine with a wide bar attached to the top pulley. Make sure that you adjust the knee pad of the machine to fit your height. These pads will prevent your body from being raised by the resistance attached to the bar.",
      "Grab the bar with the palms facing forward using the prescribed grip. Note on grips: For a wide grip, your hands need to be spaced out at a distance wider than shoulder width. For a medium grip, your hands need to be spaced out at a distance equal to your shoulder width and for a close grip at a distance smaller than your shoulder width.",
      "As you have both arms extended in front of you holding the bar at the chosen grip width, bring your torso back around 30 degrees or so while creating a curvature on your lower back and sticking your chest out. This is your starting position.",
      "As you breathe out, bring the bar down until it touches your upper chest by drawing the shoulders and the upper arms down and back. Tip: Concentrate on squeezing the back muscles once you reach the full contracted position. The upper torso should remain stationary and only the arms should move. The forearms should do no other work except for holding the bar; therefore do not try to pull down the bar using the forearms.",
      "After a second at the contracted position squeezing your shoulder blades together, slowly raise the bar back to the starting position when your arms are fully extended and the lats are fully stretched. Inhale during this portion of the movement.",
      "Repeat this motion for the prescribed amount of repetitions."
    ],
    "lateral_box_jump_v1": [
      "Stand sideways next to a low box.",
      "Bend the knees and jump laterally onto the box landing softly.",
      "Step down to the opposite side and jump back across; alternate."
    ],
    "lateral_lunge_v1": [
      "Stand tall with feet together.",
      "Take a wide step to one side, sit the hips back and bend that knee while the other leg stays straight.",
      "Push back to standing and alternate sides."
    ],
    "lateral_step_down_v1": [
      "Stand on a step or box (10–20 cm) with the control foot near the edge.",
      "Slowly flex the support knee to lower the other foot toward the floor in 3–4 sec, keeping the knee aligned over the second toe.",
      "Touch the floor without transferring weight; push back up. Control the hip not dropping to the side."
    ],
    "legs_up_wall_v1": [
      "Sit sideways against a wall and swing the legs up the wall as you lie back on the mat.",
      "Slide the hips close to the wall and let the arms relax at the sides.",
      "Breathe slowly for 5–15 minutes."
    ],
    "Lying_Leg_Curls": [
      "Adjust the machine lever to fit your height and lie face down on the leg curl machine with the pad of the lever on the back of your legs (just a few inches under the calves). Tip: Preferably use a leg curl machine that is angled as opposed to flat since an angled position is more favorable for hamstrings recruitment.",
      "Keeping the torso flat on the bench, ensure your legs are fully stretched and grab the side handles of the machine. Position your toes straight (or you can also use any of the other two stances described on the foot positioning section). This will be your starting position.",
      "As you exhale, curl your legs up as far as possible without lifting the upper legs from the pad. Once you hit the fully contracted position, hold it for a second.",
      "As you inhale, bring the legs back to the initial position. Repeat for the recommended amount of repetitions."
    ],
    "modified_side_plank_knee_v1": [
      "Lie on one side with the bottom forearm on the mat, knees bent and stacked.",
      "Lift the hips off the mat creating a straight line from knees to head.",
      "Hold breathing steadily; switch sides after the prescribed time."
    ],
    "mountain_climber_explosive_v1": [
      "Set up in a high plank with hands under shoulders.",
      "Drive one knee toward the chest and switch legs explosively in mid-air.",
      "Continue at a fast pace keeping the hips low."
    ],
    "neck_cars_v1": [
      "Sit or stand tall with shoulders relaxed.",
      "Slowly rotate the head in a controlled circle exploring the full range without pain.",
      "Reverse direction for the same reps; keep the motion slow."
    ],
    "nordic_curl_v1": [
      "Kneel with ankles secured under a bench, bar, or held by a partner.",
      "Keeping your body straight from knees to head, lean forward slowly (3–5 sec) under eccentric hamstring control.",
      "When you can no longer control the fall, use your hands to brake, then push back. Progress from partial to full range of motion."
    ],
    "open_book_stretch_v1": [
      "Lie on one side with knees stacked at 90° and arms extended in front, palms together.",
      "Inhale and slowly open the top arm across the body following it with your gaze, keeping the knees stacked.",
      "Exhale to return; complete reps and switch sides."
    ],
    "pallof_press_band_v1": [
      "Anchor a band at chest height and stand sideways gripping it with both hands at the chest.",
      "Press the band straight out in front resisting the pull toward the anchor.",
      "Bring the hands back to the chest under control; complete reps before switching sides."
    ],
    "pallof_press_split_stance_v1": [
      "Anchor a band at chest height and assume a half-kneeling or split stance perpendicular to the anchor.",
      "Press the band straight out resisting rotation.",
      "Return slowly; complete reps before switching sides."
    ],
    "pec_release_ball_v1": [
      "Place a massage ball between the upper chest and a wall just below the collarbone.",
      "Lean into the ball and slowly explore the area moving the arm to find tight spots.",
      "Hold each tight spot for 20–30 seconds breathing slowly; switch sides."
    ],
    "pelvic_clock_v1": [
      "Lie supine with knees bent and feet flat on the mat.",
      "Imagine a clock on the pelvis and tilt it slowly to 12, 3, 6 and 9 o'clock positions.",
      "Make smooth circles in both directions; breathe naturally."
    ],
    "pigeon_pose_v1": [
      "From hands and knees, bring one shin forward across the mat with the back leg extended straight back.",
      "Square the hips and lower the torso over the front shin to your comfortable depth.",
      "Hold breathing slowly; switch sides."
    ],
    "pike_pushup_v1": [
      "Set up in a downward-dog position with hips high and hands shoulder-width.",
      "Lower the head toward the floor by bending the elbows.",
      "Press back up to the start."
    ],
    "pistol_squat_assisted_v1": [
      "Hold a TRX, doorframe or post for balance and stand on one leg.",
      "Lower into a single-leg squat extending the free leg in front.",
      "Drive through the planted foot to return to standing."
    ],
    "Plank": [
      "Get into a prone position on the floor, supporting your weight on your toes and your forearms. Your arms are bent and directly below the shoulder.",
      "Keep your body straight at all times, and hold this position as long as possible. To increase difficulty, an arm or leg can be raised."
    ],
    "plank_jack_v1": [
      "Set up in a high plank with feet together.",
      "Jump the feet wide out to the sides and immediately back together.",
      "Continue at a steady pace keeping the hips level."
    ],
    "plank_long_lever_v1": [
      "Set up in a forearm plank with elbows extended forward of the shoulders.",
      "Press the floor away and brace the abs without sagging the hips.",
      "Hold for the prescribed time."
    ],
    "plyo_pushup_v1": [
      "Set up in a high plank with hands shoulder-width apart.",
      "Lower the chest, then explosively press up so the hands leave the floor.",
      "Land softly with elbows soft and immediately lower into the next rep."
    ],
    "postpartum_band_row_v1": [
      "Sit tall with the band looped around the feet and an end in each hand.",
      "Row the band toward the lower ribs squeezing the shoulder blades.",
      "Return in 2 seconds without losing tension."
    ],
    "postpartum_diaphragmatic_breath_v1": [
      "Lie supine or sit comfortably with one hand on the chest and the other on the belly.",
      "Inhale through the nose expanding the belly and ribs without lifting the chest.",
      "Exhale slowly releasing fully; repeat for 5–10 minutes."
    ],
    "postpartum_gentle_squat_v1": [
      "Stand with feet hip-width apart, hands on hips.",
      "Squat down to a comfortable depth keeping the chest up and exhaling on the way down.",
      "Stand back up driving through the mid-foot."
    ],
    "postpartum_glute_bridge_v1": [
      "Lie supine with knees bent and feet hip-width apart.",
      "Exhale lifting the hips squeezing the glutes without overarching the lower back.",
      "Lower in 2 seconds under control."
    ],
    "postpartum_pelvic_tilt_v1": [
      "Lie supine with knees bent and feet flat on the mat.",
      "Exhale tilting the pelvis to flatten the lumbar curve, gently engaging the pelvic floor.",
      "Inhale releasing back to neutral."
    ],
    "postpartum_seated_press_light_v1": [
      "Sit on a chair with back support and a light dumbbell in each hand at shoulder height.",
      "Exhale pressing the dumbbells overhead without arching the lower back.",
      "Lower in 2 seconds back to the shoulders."
    ],
    "postpartum_side_lying_glute_v1": [
      "Lie on one side with knees bent and stacked, head on the bottom arm.",
      "Keeping the feet together, lift the top knee opening the hip without rotating the pelvis.",
      "Lower under control; switch sides after all reps."
    ],
    "postpartum_standing_pelvic_tuck_v1": [
      "Stand with feet hip-width apart and knees soft.",
      "Exhale tucking the pelvis under and gently lifting the pelvic floor.",
      "Inhale releasing back to neutral; repeat slowly."
    ],
    "postpartum_walking_v1": [
      "Begin with 5–10 minutes of slow walking on flat ground, progressing weekly.",
      "Pay attention to pelvic-floor heaviness and stop if symptoms appear.",
      "Build duration gradually before increasing pace or terrain difficulty."
    ],
    "postpartum_wall_pushup_v1": [
      "Stand facing a wall with hands at chest height, slightly wider than shoulders.",
      "Bend the elbows lowering the chest toward the wall, exhaling and gently engaging the core.",
      "Press back without locking the elbows."
    ],
    "postpp_bird_dog_v1": [
      "Start on hands and knees with wrists under shoulders and knees under hips (neutral spine).",
      "Gently engage the core, then simultaneously extend the opposite arm and leg until parallel to the floor.",
      "Hold for 2 seconds, return with control, and alternate sides for the prescribed repetitions."
    ],
    "postpp_clamshell_band_v1": [
      "Lie on your side with hips and knees bent at approximately 45 degrees. Place a resistance band just above the knees.",
      "Keeping the feet together and pelvis stable, rotate the top knee upward as far as comfortable without rolling the hip back.",
      "Lower the knee with control and repeat for the prescribed repetitions. Switch sides."
    ],
    "postpp_glute_bridge_march_v1": [
      "Lie on your back with knees bent and feet flat. Push through both heels to lift the hips into a bridge position.",
      "Keeping hips level and core engaged, slowly lift one foot an inch off the floor (marching motion), then lower it.",
      "Alternate feet for the prescribed repetitions while maintaining a steady bridge height."
    ],
    "postpp_heel_slides_v1": [
      "Lie on your back with knees bent and feet flat. Engage the lower abdominals lightly.",
      "Slowly slide one heel away until the leg straightens partially, then slide it back under control.",
      "Alternate sides for the prescribed repetitions, maintaining core engagement."
    ],
    "postpp_modified_plank_knees_v1": [
      "Start on forearms and knees with a straight line from shoulders to knees.",
      "Gently engage the core and hold the position with normal breathing for the prescribed duration.",
      "Progress by increasing hold time or moving to toes when appropriate and cleared."
    ],
    "postpp_pelvic_tilt_supine_v1": [
      "Lie on your back with knees bent and feet flat on the floor.",
      "Gently tilt the pelvis to flatten the lower back against the floor by engaging the lower abdominals.",
      "Hold the tilted position for the prescribed time, breathing steadily. Repeat for the set."
    ],
    "postpp_standing_pelvic_tilt_v1": [
      "Stand with feet hip-width and a neutral spine. Soften the knees slightly.",
      "Tilt the pelvis under by engaging the lower abdominals, reducing lumbar lordosis slightly.",
      "Hold briefly and return to neutral. Use small, controlled repetitions."
    ],
    "postpp_ta_bracing_supine_v1": [
      "Lie on your back with knees bent and feet on the floor. Palms can rest on the pelvis to feel subtle movement.",
      "Gently draw the lower abdomen towards the spine (short, subtle contraction) without holding the breath.",
      "Hold the gentle brace for the prescribed duration and breathe normally. Repeat for the set."
    ],
    "postpp_wall_sit_isometric_v1": [
      "Stand with your back flat against a wall and feet hip-width, about 60 cm from the wall.",
      "Slide down until thighs are near parallel (or to a comfortable angle), keeping knees above ankles.",
      "Hold the position for the prescribed duration breathing normally, then slide back up."
    ],
    "progressive_muscle_relaxation_v1": [
      "Lie on the back and tense the feet for 5 seconds, then fully release for 10 seconds.",
      "Move up the body tensing and releasing calves, thighs, glutes, abdomen, hands, arms, shoulders and face.",
      "Finish with 1–2 minutes of natural breathing."
    ],
    "prone_yt_raise_v1": [
      "Lie face-down on the floor with arms extended overhead in a Y.",
      "Lift the arms off the floor and hold briefly, then move to a T position and lift again.",
      "Lower under control between positions and repeat the sequence."
    ],
    "pullup_neutral_grip_v1": [
      "Hang from parallel pull-up handles with palms facing each other, arms fully extended.",
      "Pull the chest toward the bar by driving the elbows down and back.",
      "Lower in 2–3 seconds back to a dead hang under control."
    ],
    "push_press_v1": [
      "Stand with the barbell racked at the shoulders, hands just outside shoulder width.",
      "Dip slightly at the knees and explosively drive up pressing the bar overhead.",
      "Lower in 2–3 seconds back to the front rack."
    ],
    "Pushups": [
      "Lie on the floor face down and place your hands about 36 inches apart while holding your torso up at arms length.",
      "Next, lower yourself downward until your chest almost touches the floor as you inhale.",
      "Now breathe out and press your upper body back up to the starting position while squeezing your chest.",
      "After a brief pause at the top contracted position, you can begin to lower yourself downward again for as many repetitions as needed."
    ],
    "quadruped_toe_taps_v1": [
      "Start on hands and knees with a neutral spine.",
      "Lift one knee just off the mat and tap the toe out to the side without rotating the hips.",
      "Return and alternate sides under control."
    ],
    "resistance_band_row_seated_v1": [
      "Sit on the floor or a chair with legs extended, band looped around the feet, ends in each hand.",
      "Row the band toward the lower ribs squeezing the shoulder blades together.",
      "Return in 2 seconds without losing tension."
    ],
    "resistance_band_row_standing_v1": [
      "Hold a resistance band anchored at hip height or grip both ends in your hands.",
      "Stand with knees slightly bent, drive elbows back bringing hands alongside your torso and squeezing shoulder blades together.",
      "Return slowly to the start position under 2 seconds of control."
    ],
    "reverse_lunge_v1": [
      "Stand tall with feet hip-width apart.",
      "Step one foot back into a lunge lowering the back knee toward the floor.",
      "Drive through the front foot to return to standing; alternate sides."
    ],
    "ring_row_v1": [
      "Set the rings at hip height and grab the handles with arms extended, body in a straight line, heels on the floor.",
      "Pull the chest up to the rings by retracting the shoulder blades and bending the elbows.",
      "Lower in 2 seconds back to full extension; raise feet to a box for added difficulty."
    ],
    "sandbag_bear_hug_carry_v1": [
      "Pick up the sandbag and hug it tight against the chest, arms wrapped around it.",
      "Walk forward with controlled steps for the prescribed distance or time.",
      "Set the sandbag down with a hip hinge."
    ],
    "sandbag_clean_v1": [
      "Stand with the sandbag between the feet and grip the handles or the bag itself.",
      "Hinge and explode up driving the hips forward, pulling the sandbag to the chest in a rack position.",
      "Lower the sandbag to the floor under control and repeat."
    ],
    "sandbag_drag_v1": [
      "Loop a strap or grip the sandbag and walk backward dragging it on a smooth surface.",
      "Maintain a slight forward lean and brace the core.",
      "Continue for the prescribed distance or time."
    ],
    "sandbag_get_up_v1": [
      "Lie on the back hugging a sandbag to the chest.",
      "Sit up, post a hand on the floor and stand up under control.",
      "Reverse the sequence back to the floor; alternate sides."
    ],
    "sandbag_rotational_lunge_v1": [
      "Hold a sandbag at chest height and step forward into a lunge.",
      "Rotate the torso toward the front leg without losing balance.",
      "Return to standing and alternate sides."
    ],
    "sandbag_shoulder_to_shoulder_v1": [
      "Rack a sandbag on one shoulder with both hands supporting it.",
      "Explosively press it overhead and lower to the opposite shoulder.",
      "Alternate shoulders for the prescribed reps."
    ],
    "sandbag_squat_v1": [
      "Hold a sandbag racked against the chest with both arms.",
      "Squat down keeping the chest tall and elbows up.",
      "Stand back up driving through the mid-foot."
    ],
    "sandbag_zercher_squat_v1": [
      "Hold a sandbag in the crook of the elbows at chest height.",
      "Squat down keeping the chest up and elbows tucked.",
      "Stand back up driving through the mid-foot."
    ],
    "savasana_v1": [
      "Lie on the back with arms slightly away from the body, palms up, and feet relaxed apart.",
      "Close the eyes and let the body sink into the mat releasing all muscular effort.",
      "Breathe naturally for 5–15 minutes."
    ],
    "seal_row_v1": [
      "Lie chest-down on an elevated bench with a dumbbell in each hand and arms hanging.",
      "Row both dumbbells to the ribs squeezing the shoulder blades.",
      "Lower under control to a full stretch."
    ],
    "seated_box_jump_v1": [
      "Sit on a low box with feet flat and arms by the sides, stationary.",
      "Without rocking, explode straight up jumping onto a target box in front.",
      "Step down and reset between reps."
    ],
    "seated_dumbbell_curl_pregnancy_v1": [
      "Sit on a chair with back support and a light dumbbell in each hand.",
      "Curl the dumbbells to the shoulders without arching the lower back.",
      "Lower in 2 seconds under control."
    ],
    "seated_forward_fold_v1": [
      "Sit with both legs extended forward and feet flexed.",
      "Hinge from the hips reaching toward the feet without rounding the lower back.",
      "Hold breathing steadily; bend the knees slightly if needed."
    ],
    "seated_lateral_raise_light_v1": [
      "Sit on a chair with light dumbbells at the sides, slight elbow bend.",
      "Raise both arms out to shoulder height leading with the elbows.",
      "Lower in 2 seconds without swinging."
    ],
    "seated_marches_v1": [
      "Sit tall on a chair with feet flat and hands on the lower belly.",
      "Lift one knee toward the chest exhaling and engaging the core.",
      "Lower under control and alternate sides."
    ],
    "seated_marching_v1": [
      "Sit tall in a chair with feet flat on the floor and hands resting on thighs or at your sides.",
      "Alternately lift each knee toward your chest to hip height, as if marching while seated.",
      "Keep your torso stable and spine long throughout the movement."
    ],
    "seated_spinal_twist_v1": [
      "Sit on the floor with legs extended. Bend your right knee and place the foot flat on the floor outside your left knee.",
      "Place your left hand on your right knee and rotate your torso to the right, placing your right hand behind you for support.",
      "Hold 30 seconds, rotating a little further with each exhale; return to center and repeat on the other side."
    ],
    "shoulder_cars_v1": [
      "Stand tall with one arm at the side, brace the core.",
      "Trace the largest controlled circle possible with the arm: forward, up, back and down.",
      "Reverse direction; switch arms."
    ],
    "side_lying_clamshell_v1": [
      "Lie on one side with knees bent and stacked, feet aligned with the spine.",
      "Keep the feet together and lift the top knee opening like a clamshell without rotating the pelvis.",
      "Lower under control; switch sides after all reps."
    ],
    "side_lying_leg_raise_v1": [
      "Lie on one side with the bottom leg bent for support and the top leg extended.",
      "Lift the top leg straight up to about 45° without rotating the hip.",
      "Lower under control; switch sides after all reps."
    ],
    "side_plank_dynamic_v1": [
      "Set up in a side plank on the forearm with the hips lifted.",
      "Rotate the top arm under the body to thread the needle, then return to the open side plank.",
      "Complete reps before switching sides."
    ],
    "side_plank_hip_lift_v1": [
      "Set up in a side plank on the forearm with the hips lifted.",
      "Lower the hips toward the floor and drive them back up without rotating the torso.",
      "Complete reps before switching sides."
    ],
    "single_arm_farmer_carry_v1": [
      "Pick up a heavy dumbbell with one hand and stand tall.",
      "Walk for the prescribed distance keeping the shoulders level and the core braced.",
      "Switch sides and repeat."
    ],
    "single_leg_box_jump_v1": [
      "Stand on one leg facing a low box.",
      "Bend the knee and jump explosively up onto the box landing softly on the same leg.",
      "Step down and complete reps before switching sides."
    ],
    "single_leg_hip_thrust_v1": [
      "Sit with the upper back against a bench and one foot flat on the floor.",
      "Drive through the planted heel lifting the hips while keeping the free leg extended.",
      "Lower under control; complete reps before switching sides."
    ],
    "single_leg_rdl_v1": [
      "Stand on one leg holding a dumbbell in the opposite hand.",
      "Hinge at the hip extending the free leg back as the torso lowers parallel to the floor.",
      "Return to standing under control; complete reps before switching sides."
    ],
    "single_leg_squat_v1": [
      "Stand on one leg, the other slightly in front or to the side, arms extended for balance.",
      "Slowly flex the support knee as far as possible without it collapsing inward or the hip dropping.",
      "Return to start by pushing through the heel. Use wall support to progress toward freestanding."
    ],
    "sit_to_stand_v1": [
      "Sit in a chair with feet hip-width apart and flat on the floor.",
      "Lean your torso slightly forward, push through your heels and stand up until fully erect.",
      "Control the descent by sitting back down slowly without dropping onto the chair."
    ],
    "skater_jump_v1": [
      "Stand on one leg with the other crossed slightly behind.",
      "Push off laterally to the opposite side landing softly on the other leg with the trailing leg crossed behind.",
      "Continue alternating side to side."
    ],
    "split_squat_jump_v1": [
      "Step into a split stance with one foot forward and one back.",
      "Lower into a lunge and explode up switching legs in mid-air.",
      "Land softly in the opposite split stance and repeat."
    ],
    "squat_jump_v1": [
      "Stand with feet shoulder-width apart.",
      "Squat to parallel and explode up into a vertical jump swinging the arms.",
      "Land softly bending the knees and immediately repeat."
    ],
    "standing_calf_raise_pregnancy_v1": [
      "Stand with feet hip-width apart, holding a wall or chair for balance.",
      "Rise onto the balls of the feet pushing the heels up.",
      "Lower in 2 seconds under control."
    ],
    "Standing_Calf_Raises": [
      "Adjust the padded lever of the calf raise machine to fit your height.",
      "Place your shoulders under the pads provided and position your toes facing forward (or using any of the two other positions described at the beginning of the chapter). The balls of your feet should be secured on top of the calf block with the heels extending off it. Push the lever up by extending your hips and knees until your torso is standing erect. The knees should be kept with a slight bend; never locked. Toes should be facing forward, outwards or inwards as described at the beginning of the chapter. This will be your starting position.",
      "Raise your heels as you breathe out by extending your ankles as high as possible and flexing your calf. Ensure that the knee is kept stationary at all times. There should be no bending at any time. Hold the contracted position by a second before you start to go back down.",
      "Go back slowly to the starting position as you breathe in by lowering your heels as you bend the ankles until calves are stretched.",
      "Repeat for the recommended amount of repetitions."
    ],
    "step_up_jump_v1": [
      "Place one foot on a low box, drive through it to step up explosively jumping into the air.",
      "Land softly back on the same foot on the box.",
      "Step down and alternate sides."
    ],
    "step_up_v1": [
      "Place one full foot on a step or box about 20–30 cm high.",
      "Drive through the heel of the elevated foot to lift your body, bringing the other foot up to level.",
      "Control the descent over 2 sec; alternate legs or complete all reps on one side before switching."
    ],
    "suitcase_carry_v1": [
      "Pick up a kettlebell with one hand and stand tall, shoulders level.",
      "Walk forward with controlled steps resisting any lean toward the loaded side.",
      "Continue for the prescribed time or distance; switch sides."
    ],
    "sumo_deadlift_v1": [
      "Stand with a wide stance and feet turned out, the barbell over the mid-foot.",
      "Hinge to grip the bar inside the legs.",
      "Drive the floor away pushing the hips forward to lockout."
    ],
    "sun_salutation_a_v1": [
      "From standing inhale arms overhead, exhale fold forward, inhale halfway lift.",
      "Exhale step or jump back to plank, lower to the floor, inhale to upward dog, exhale to downward dog and breathe.",
      "Step or jump to the front of the mat, inhale halfway lift, exhale fold, inhale to stand; complete reps."
    ],
    "sun_salutation_b_v1": [
      "From standing inhale into chair pose, exhale fold forward, inhale halfway lift, exhale step back to plank then chaturanga, inhale upward dog, exhale downward dog.",
      "Inhale step the right foot forward into Warrior I, exhale return to plank/chaturanga and flow through up dog and down dog; repeat with left.",
      "Step or jump to the front, inhale halfway lift, exhale fold, inhale to chair, exhale stand; complete reps."
    ],
    "supine_twist_v1": [
      "Lie on the back, hug one knee to the chest then guide it across the body to the opposite side.",
      "Extend the same-side arm out and turn the gaze toward the extended arm, keeping both shoulders on the floor.",
      "Hold breathing slowly; switch sides."
    ],
    "supported_fish_pose_v1": [
      "Place a foam roller along the spine and lie back so it supports the upper back lengthwise.",
      "Let the arms fall open to the sides and the legs extend or bend at the knees.",
      "Breathe slowly opening the chest for 2–5 minutes."
    ],
    "supported_squat_chair_v1": [
      "Stand in front of a sturdy chair with feet hip-width apart.",
      "Sit back slowly until the glutes lightly touch the chair, keeping the chest up.",
      "Stand back up driving through the mid-foot."
    ],
    "svend_press_v1": [
      "Stand tall pressing two small plates together at chest height with both hands.",
      "Press the plates straight out in front while squeezing them together.",
      "Return to the chest under control."
    ],
    "swiss_ball_hamstring_curl_v1": [
      "Lie on the back with the heels resting on a Swiss ball, arms by the sides.",
      "Lift the hips into a bridge.",
      "Pull the heels toward the glutes by bending the knees, then extend back out under control without dropping the hips."
    ],
    "thoracic_bridge_v1": [
      "Sit with knees bent, feet flat and hands behind you, fingers pointing back.",
      "Lift the hips and rotate to one side reaching the free hand overhead in a thoracic extension.",
      "Return to the start under control; alternate sides."
    ],
    "thread_the_needle_v1": [
      "Start on all fours with hips over knees and shoulders over wrists.",
      "Slide one arm underneath your body, rotating your torso, until the shoulder and side of the head reach the floor.",
      "Hold 2–3 seconds feeling the thoracic stretch, return to start, and repeat on the other side."
    ],
    "tree_pose_v1": [
      "Stand tall and shift weight onto one foot.",
      "Place the other foot on the inner ankle, calf or thigh (avoid the knee) and bring the hands to the chest or overhead.",
      "Hold breathing steadily; switch sides."
    ],
    "triangle_pose_v1": [
      "Step the feet wide, turn the front foot forward and back foot 90°, arms extended sideways.",
      "Hinge from the front hip reaching the front hand toward the ankle and the top hand to the ceiling.",
      "Keep the chest open and gaze up; switch sides."
    ],
    "tricep_dip_chair_v1": [
      "Sit on the edge of a sturdy chair with hands on the front of the seat and feet on the floor.",
      "Slide the hips off the chair and lower by bending the elbows to ~90°.",
      "Press back up to the start."
    ],
    "tuck_jump_v1": [
      "Stand with feet hip-width apart and arms at the sides.",
      "Jump explosively bringing the knees toward the chest at the top.",
      "Land softly bending the knees and immediately repeat."
    ],
    "turkish_get_up_kettlebell_v1": [
      "Lie on the back with one arm pressing a kettlebell straight up toward the ceiling.",
      "Move through the get-up sequence (roll to the elbow, post the hand, bridge the hips, sweep the leg, lunge up to standing) keeping the bell vertical at all times.",
      "Reverse the sequence back to the floor; alternate sides."
    ],
    "tva_activation_supine_v1": [
      "Lie supine with knees bent and feet flat, hands resting on the lower belly.",
      "Exhale slowly drawing the lower belly in toward the spine and lifting the pelvic floor.",
      "Inhale releasing fully; repeat without flattening the lumbar curve."
    ],
    "upward_dog_v1": [
      "Lie face-down with hands under the shoulders and tops of the feet on the mat.",
      "Press into the hands lifting the chest, hips and thighs off the floor with arms straight.",
      "Roll the shoulders back and look slightly up; hold breathing steadily."
    ],
    "waiter_walk_v1": [
      "Press a kettlebell or dumbbell overhead with one arm in a locked-out position.",
      "Walk forward keeping the bell stable directly over the shoulder.",
      "Continue for the prescribed time; switch sides."
    ],
    "walking_lunge_v1": [
      "Stand tall with feet hip-width apart.",
      "Step forward into a lunge lowering the back knee toward the floor.",
      "Drive up and step the back foot through into the next lunge; continue alternating."
    ],
    "wall_press_core_v1": [
      "Stand a foot away from a wall with both palms flat against it at chest height.",
      "Press the wall as if pushing it away while bracing the core and exhaling.",
      "Hold the brace breathing steadily."
    ],
    "wall_push_up_v1": [
      "Stand facing a wall about 60 cm away, hands at shoulder height and slightly wider than shoulder-width.",
      "Bend your elbows until your chest nearly touches the wall, keeping your body straight like a plank.",
      "Push the wall to return to the start position, controlling the movement throughout."
    ],
    "wall_pushup_pregnancy_v1": [
      "Stand facing a wall with hands at chest height, slightly wider than shoulders.",
      "Bend the elbows lowering the chest toward the wall while keeping the body in a straight line.",
      "Press back to the start without locking the elbows."
    ],
    "wall_slide_v1": [
      "Stand with the back, head and arms against a wall, elbows at 90° in a goalpost.",
      "Slide the arms overhead keeping contact with the wall.",
      "Pull back down to the start without losing contact."
    ],
    "warrior_one_v1": [
      "Step one foot forward into a long lunge with the back foot turned out 45°.",
      "Bend the front knee over the ankle and reach both arms overhead, palms facing.",
      "Square the hips forward and hold breathing steadily; switch sides."
    ],
    "warrior_two_v1": [
      "Step the feet wide apart, turn the front foot forward and the back foot 90° to the side.",
      "Bend the front knee over the ankle and extend the arms parallel to the floor.",
      "Gaze over the front hand and hold breathing steadily; switch sides."
    ],
    "weighted_vest_burpee_v1": [
      "Wear a weighted vest and stand with feet shoulder-width apart.",
      "Drop to a push-up position, perform one push-up, jump the feet to the hands and explode up into a small jump.",
      "Land softly and immediately repeat."
    ],
    "weighted_vest_lunge_walk_v1": [
      "Wear a weighted vest and stand tall with feet hip-width apart.",
      "Step forward into a lunge lowering the back knee toward the floor.",
      "Drive up and step the back foot through into the next lunge; alternate sides."
    ],
    "weighted_vest_pullup_v1": [
      "Wear a weighted vest and hang from a pull-up bar with palms facing away.",
      "Pull the chest toward the bar by driving the elbows down.",
      "Lower in 2–3 seconds to a dead hang."
    ],
    "weighted_vest_pushup_v1": [
      "Wear a weighted vest and set up in a high plank with hands shoulder-width apart.",
      "Lower the chest to the floor in 2 seconds keeping the elbows tucked at ~45°.",
      "Press back up to the start without sagging the hips."
    ],
    "weighted_vest_ruck_walk_v1": [
      "Wear a weighted vest and walk briskly on flat ground or a moderate incline.",
      "Maintain an upright posture and a controlled cadence.",
      "Continue for the prescribed time gradually increasing distance over weeks."
    ],
    "weighted_vest_squat_v1": [
      "Wear a weighted vest and stand with feet shoulder-width apart.",
      "Squat down keeping the chest up and knees tracking over the toes.",
      "Stand back up driving through the mid-foot."
    ],
    "weighted_vest_step_up_v1": [
      "Wear a weighted vest and stand in front of a step or low box.",
      "Step up driving through the front foot until standing on top.",
      "Step down under control and alternate sides."
    ],
    "wide_grip_pullup_v1": [
      "Hang from a pull-up bar with palms facing away wider than shoulder-width.",
      "Pull the chest toward the bar by driving the elbows down and out.",
      "Lower in 2–3 seconds to a dead hang."
    ],
    "world_greatest_stretch_v1": [
      "From a push-up position step the right foot outside the right hand into a deep lunge.",
      "Drop the right elbow toward the instep, then rotate the torso opening the right arm up to the ceiling.",
      "Return the hand to the floor and step back; alternate sides."
    ],
    "wrist_warmup_circles_v1": [
      "Extend the arms in front and interlock the fingers.",
      "Circle the wrists slowly clockwise for the prescribed reps.",
      "Reverse direction for the same number of reps."
    ],
    "ytwl_complex_v1": [
      "Lie face-down on an incline bench with a light dumbbell in each hand.",
      "Move the arms through Y, T, W and L positions raising the dumbbells with shoulder blades retracted.",
      "Lower under control between positions and repeat the sequence."
    ]
  }
}
