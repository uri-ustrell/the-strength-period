  {
    "id": "Chin-Up",
    "nameKey": "exercises:Chin-Up",
    "primaryMuscles": [
      "dorsal"
    ],
    "secondaryMuscles": [
      "biceps",
      "avantbras",
      "dorsal"
    ],
    "equipment": [
