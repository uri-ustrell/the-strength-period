  "ingested_presets": {
    "embaras_1r_trimestre_v1": {
      "name": "Pregnancy — 1st trimester (conservative)",
      "description": "Generator-mode conservative block for the first trimester. Prioritizes pelvic stability, hip mobility and gentle core. Always consult a healthcare professional."
    },
    "embaras_2n_trimestre_v1": {
      "name": "Pregnancy — 2nd trimester (moderate strength)",
      "description": "Faithful-mode moderate strength block for the second trimester: glutes, stabilizers and upper body. Conservative progression. Always consult a healthcare professional."
    },
    "embaras_3r_trimestre_v1": {
      "name": "Pregnancy — 3rd trimester (gentle maintenance)",
      "description": "Very gentle generator-mode maintenance block for the third trimester: mobility, hip stabilizers and low-impact core. Consult a midwife or physiotherapist."
    },
    "postpart_corredora_general_v1": {
      "name": "Postpartum — General runner (strength base)",
      "description": "A 6–12 week block for postpartum runners: rebuilds lower-body strength, core stability and running-specific resilience. Medical clearance required."
    },
    "postpart_generator_core_strength_v1": {
      "name": "Postpartum — Generator: core → strength",
      "description": "Generator-mode preset prioritizing pelvic stability, glutes and hip stabilizers; the engine will select suitable exercises from your catalog."
    },
    "postpart_rehab_conservative_v1": {
      "name": "Postpartum — Gentle rehab",
      "description": "A cautious 4–6 week block focused on pelvic stability, core re-education and mobility. Consult a healthcare professional before starting."
    },
    "postpart_retorn_trail_v1": {
      "name": "Postpartum — Return to trail (progressive)",
      "description": "An 8–12 week block bridging postpartum strength to trail-specific demands: eccentric control on descents, reactive stability and hip power. Full medical clearance required."
    },
    "postpart_return_strength_v1": {
      "name": "Postpartum — Return to strength (progressive)",
      "description": "Progressive 6–12 week block to rebuild hip and core strength and stability. Increase load conservatively."
    },
    "postpart_return_to_running_v1": {
      "name": "Postpartum — Return to running (progressive)",
      "description": "An 8–12 week block combining strength, stability and cautious plyometrics to prepare for return to running. Seek medical clearance and progress conservatively."
    },
    "principianta_descoberta_v1": {
      "name": "Beginner — Movement discovery",
      "description": "Generator-mode introductory block for women with no prior training history. Very conservative distribution, mobility and stability emphasis. Ideal as a first 4–6 week program."
    },
    "principianta_forca_base_v1": {
      "name": "Beginner — Foundation strength",
      "description": "Faithful-mode foundational strength block for beginners. 2 sessions/week, basic body-weight or light resistance exercises. Prioritizes technique and movement pattern learning."
    },
    "principianta_forca_progressiva_v1": {
      "name": "Beginner — Progressive strength (stage 2)",
      "description": "Faithful-mode progression block for women who have completed a foundations block. 3 sessions/week with light dumbbells, undulating periodization. Recommended after 6+ weeks of the introductory block."
    },
    "tsp_descent_eccentric_linear_04": {
      "name": "Downhill Control and Knee Health",
      "description": "Block centered on eccentric work to protect the patellar tendon and improve braking capacity."
    },
    "tsp_hybrid_all_terrain_undulating_05": {
      "name": "All-Terrain Performance: Hybrid Athlete",
      "description": "Complete program that combines running-specific leg strength with meaningful upper-body conditioning."
    },
    "tsp_lumbar_resilience_linear_06": {
      "name": "Lumbar Resilience and Pelvic Stability",
      "description": "Preventive and rehab-focused block for runners with low-back history or posterior-chain weakness."
    },
    "tsp_road_foundation_linear_01": {
      "name": "Road Foundation: Base Strength",
      "description": "Introductory block for road runners who want a solid strength base and injury prevention."
    },
    "tsp_trail_stability_undulating_02": {
      "name": "Technical Trail: Hip and Core Stability",
      "description": "Focused on improving motor control and the stability needed for uneven terrain and technical descents."
    },
    "tsp_vertical_power_block_03": {
      "name": "Vertical Power: Uphill Specialist",
      "description": "Designed for runners who want to improve performance on steep climbs (Vertical Kilometer)."
    }
  }
