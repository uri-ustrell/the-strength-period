  "Wide-Grip_Lat_Pulldown": "Wide-Grip Lat Pulldown",
  "world_greatest_stretch_v1": "World's Greatest Stretch",
  "instructions": {
    "band_bicep_curl_v1": [
      "Stand on the center of the band; grip ends with palms up and arms at your sides.",
      "Curl the handles toward your shoulders, keeping elbows fixed at your sides without swinging.",
      "Lower under control over 2 sec."
    ],
    "band_chest_press_standing_v1": [
      "Anchor a resistance band behind you at chest height (door or stable weight).",
      "Grip one end in each hand, one foot slightly forward for stability.",
      "Press handles forward until arms are nearly extended; return slowly over 2 sec."
    ],
    "band_face_pull_v1": [
      "Anchor a band at face height and stand back so it has tension, holding the ends with palms down.",
      "Pull the band toward the face leading with the elbows wide and externally rotating the shoulders.",
      "Return in 2 seconds without losing band tension."
    ],
    "band_lateral_walk_v1": [
      "Place a resistance band around your ankles or just above knees; stand with knees slightly bent.",
      "Take controlled lateral steps, maintaining constant band tension and a stable core.",
      "Do not let feet come together fully to keep the band under tension throughout."
    ],
    "band_overhead_press_v1": [
      "Stand on the center of the band with feet hip-width apart; grip ends at shoulder height.",
      "Press handles overhead until arms are nearly extended, keeping core braced.",
      "Lower slowly back to shoulder height and repeat."
    ],
    "band_squat_v1": [
      "Place a resistance band just above your knees; stand with feet hip-width apart.",
      "Push your knees out against the band resistance throughout the squat.",
      "Lower to parallel or below; drive up through your heels."
    ],
    "band_tricep_pushdown_v1": [
      "Anchor a band overhead and grip the ends with elbows tucked at the sides.",
      "Press the band down by extending the elbows fully without moving the upper arms.",
      "Return in 2 seconds back to the starting position."
    ],
    "Barbell_Deadlift": [
      "Stand in front of a loaded barbell.",
      "While keeping the back as straight as possible, bend your knees, bend forward and grasp the bar using a medium (shoulder width) overhand grip. This will be the starting position of the exercise. Tip: If it is difficult to hold on to the bar with this grip, alternate your grip or use wrist straps.",
      "While holding the bar, start the lift by pushing with your legs while simultaneously getting your torso to the upright position as you breathe out. In the upright position, stick your chest out and contract the back by bringing the shoulder blades back. Think of how the soldiers in the military look when they are in standing in attention.",
      "Go back to the starting position by bending at the knees while simultaneously leaning the torso forward at the waist while keeping the back straight. When the weights on the bar touch the floor you are back at the starting position and ready to perform another repetition.",
      "Perform the amount of repetitions prescribed in the program."
    ],
    "Barbell_Squat": [
      "This exercise is best performed inside a squat rack for safety purposes. To begin, first set the bar on a rack to just below shoulder level. Once the correct height is chosen and the bar is loaded, step under the bar and place the back of your shoulders (slightly below the neck) across it.",
      "Hold on to the bar using both arms at each side and lift it off the rack by first pushing with your legs and at the same time straightening your torso.",
      "Step away from the rack and position your legs using a shoulder width medium stance with the toes slightly pointed out. Keep your head up at all times and also maintain a straight back. This will be your starting position. (Note: For the purposes of this discussion we will use the medium stance described above which targets overall development; however you can choose any of the three stances discussed in the foot stances section).",
      "Begin to slowly lower the bar by bending the knees and hips as you maintain a straight posture with the head up. Continue down until the angle between the upper leg and the calves becomes slightly less than 90-degrees. Inhale as you perform this portion of the movement. Tip: If you performed the exercise correctly, the front of the knees should make an imaginary straight line with the toes that is perpendicular to the front. If your knees are past that imaginary line (if they are past your toes) then you are placing undue stress on the knee and the exercise has been performed incorrectly.",
      "Begin to raise the bar as you exhale by pushing the floor with the heel of your foot as you straighten the legs again and go back to the starting position.",
      "Repeat for the recommended amount of repetitions."
    ],
    "bb_bent_over_row_v1": [
      "Hinge at the hips to about a 45° torso angle, holding the barbell with an overhand grip just outside the knees.",
      "Pull the bar to the lower ribs by leading with the elbows and squeezing the shoulder blades.",
      "Lower in 2 seconds back to the start without rounding the back."
    ],
    "bb_bicep_curl_v1": [
      "Stand with the barbell at arm's length, hands shoulder-width apart, palms facing forward.",
      "Curl the bar up toward the shoulders without swinging the torso.",
      "Lower in 2–3 seconds under control to a full elbow extension."
    ],
    "bb_close_grip_bench_v1": [
      "Lie on a bench with the barbell gripped at shoulder-width, slight elbow tuck.",
      "Lower the bar to the lower chest in 2 seconds keeping the elbows tucked at ~30°.",
      "Press the bar back up to lockout without flaring the elbows."
    ],
    "bb_overhead_press_v1": [
      "Stand with feet hip-width apart and the barbell racked at the shoulders, hands just outside shoulder width.",
      "Press the bar straight up overhead, moving the head slightly forward as the bar passes the face.",
      "Lower in 2–3 seconds back to the front rack with the elbows tucked."
    ],
    "bb_shrug_v1": [
      "Stand with the barbell held at arm's length in front of the thighs, hands shoulder-width apart.",
      "Lift the shoulders straight up toward the ears without rolling them.",
      "Pause briefly at the top and lower the shoulders under control."
    ],
    "db_arnold_press_v1": [
      "Sit on a bench with back support, holding two dumbbells in front of the shoulders, palms facing the body.",
      "Press the dumbbells overhead while rotating the palms outward until the arms are fully extended.",
      "Reverse the motion in 2 seconds back to the starting position."
    ],
    "db_chest_supported_row_v1": [
      "Lie face-down on an incline bench set to ~30°, holding a dumbbell in each hand with arms hanging.",
      "Row both dumbbells toward the rib cage by squeezing the shoulder blades together.",
      "Lower in 2 seconds back to full extension."
    ],
    "db_concentration_curl_v1": [
      "Sit on a bench with legs spread, holding a dumbbell in one hand and bracing that elbow against the inner thigh.",
      "Curl the dumbbell up to the shoulder while keeping the elbow fixed against the thigh.",
      "Lower in 2 seconds and repeat for all reps before switching arms."
    ],
    "db_hammer_curl_v1": [
      "Stand with a dumbbell in each hand by the sides, palms facing the body (neutral grip).",
      "Curl the dumbbells up toward the shoulders without rotating the wrists.",
      "Lower in 2–3 seconds under control."
    ],
    "db_incline_bench_press_v1": [
      "Set an adjustable bench to a 30–45° incline and lie back with a dumbbell in each hand at shoulder height, palms facing forward.",
      "Press both dumbbells up and slightly inward until the arms are extended without locking the elbows.",
      "Lower the dumbbells in 2–3 seconds until the elbows reach roughly chest level, keeping the shoulder blades retracted."
    ],
    "db_lateral_raise_v1": [
      "Stand with a dumbbell in each hand, arms relaxed by the sides, slight bend in the elbows.",
      "Raise both arms out to the sides until they reach shoulder height, leading with the elbows.",
      "Lower in 2–3 seconds back to the starting position without swinging."
    ],
    "db_pullover_v1": [
      "Lie supine on a bench with both hands holding one dumbbell over the chest, elbows slightly bent.",
      "Lower the dumbbell behind the head in an arc until you feel a stretch across the lats and chest, keeping the lower back in contact with the bench.",
      "Pull the dumbbell back over the chest under control."
    ],
    "db_rear_delt_fly_v1": [
      "Hinge forward at the hips with a flat back, holding light dumbbells with arms hanging down, palms facing each other.",
      "Raise both arms out to the sides squeezing the shoulder blades together until the upper arms reach torso level.",
      "Lower in 2 seconds back to the start under control."
    ],
    "db_renegade_row_v1": [
      "Set up in a push-up position with hands on two dumbbells placed shoulder-width apart, feet wider than hips.",
      "Row one dumbbell to the side of the rib cage while keeping the hips square to the floor.",
      "Lower under control and alternate sides for the prescribed reps."
    ],
    "db_single_arm_row_v1": [
      "Place one knee and same-side hand on a bench, the other foot on the floor and a dumbbell in the free hand.",
      "Row the dumbbell to the side of the rib cage, leading with the elbow.",
      "Lower in 2 seconds and complete all reps before switching sides."
    ],
    "db_skullcrusher_v1": [
      "Lie on a bench with two dumbbells extended over the chest, palms facing each other.",
      "Bend the elbows to lower the dumbbells toward the temples, keeping the upper arms vertical.",
      "Extend the elbows to return without flaring them out."
    ],
    "db_zottman_curl_v1": [
      "Stand with a dumbbell in each hand at the sides, palms facing forward.",
      "Curl the dumbbells up to the shoulders, then rotate the wrists so the palms face down at the top.",
      "Lower in 3 seconds with the palms down, rotating back to palms-up at the bottom."
    ],
    "depth_jump_v1": [
      "Stand on a box (20–40 cm), step off and land on both feet simultaneously.",
      "Upon landing, absorb into a squat and immediately jump upward to maximize reactive power.",
      "Minimize ground contact time. Stop the exercise if landing feels stiff or a joint signals pain."
    ],
    "downward_dog_v1": [
      "From a plank position, push your hips up and back to form an inverted V with hands and feet on the ground.",
      "Lengthen your spine, trying to bring your heels to the floor and your head between your arms.",
      "Hold for 20–40 seconds breathing deeply; alternating knee bends can deepen the hamstring stretch."
    ],
    "Dumbbell_Bicep_Curl": [
      "Stand up straight with a dumbbell in each hand at arm's length. Keep your elbows close to your torso and rotate the palms of your hands until they are facing forward. This will be your starting position.",
      "Now, keeping the upper arms stationary, exhale and curl the weights while contracting your biceps. Continue to raise the weights until your biceps are fully contracted and the dumbbells are at shoulder level. Hold the contracted position for a brief pause as you squeeze your biceps.",
      "Then, inhale and slowly begin to lower the dumbbells back to the starting position.",
      "Repeat for the recommended amount of repetitions."
    ],
    "Dumbbell_Lunges": [
      "Stand with your torso upright holding two dumbbells in your hands by your sides. This will be your starting position.",
      "Step forward with your right leg around 2 feet or so from the foot being left stationary behind and lower your upper body down, while keeping the torso upright and maintaining balance. Inhale as you go down. Note: As in the other exercises, do not allow your knee to go forward beyond your toes as you come down, as this will put undue stress on the knee joint. Make sure that you keep your front shin perpendicular to the ground.",
      "Using mainly the heel of your foot, push up and go back to the starting position as you exhale.",
      "Repeat the movement for the recommended amount of repetitions and then perform with the left leg."
    ],
    "Dumbbell_Shoulder_Press": [
      "While holding a dumbbell in each hand, sit on a military press bench or utility bench that has back support. Place the dumbbells upright on top of your thighs.",
      "Now raise the dumbbells to shoulder height one at a time using your thighs to help propel them up into position.",
      "Make sure to rotate your wrists so that the palms of your hands are facing forward. This is your starting position.",
      "Now, exhale and push the dumbbells upward until they touch at the top.",
      "Then, after a brief pause at the top contracted position, slowly lower the weights back down to the starting position while inhaling.",
      "Repeat for the recommended amount of repetitions."
    ],
    "eccentric_calf_raise_v1": [
      "Stand on the edge of a step with the ball of your foot, holding a wall for balance.",
      "Rise on both toes (concentric), then slowly lower on one leg over 4–5 sec, letting the heel drop below the step level.",
      "Return with both legs and repeat. Progress by adding load or increasing reps."
    ],
    "kb_clean_v1": [
      "Start with the kettlebell on the floor between the feet, hinge at the hips and grip with one hand.",
      "Drive the hips forward to pull the kettlebell up, guiding the elbow back as the bell rotates around the wrist.",
      "Catch the kettlebell in the rack position at the shoulder, then reverse to the floor."
    ],
    "kb_farmer_carry_v1": [
      "Hold a heavy kettlebell in each hand by the sides with shoulders packed and ribs down.",
      "Walk forward with controlled steps for the prescribed distance or time.",
      "Set the kettlebells down with a hip hinge, do not drop them."
    ],
    "kb_goblet_squat_v1": [
      "Hold a kettlebell at chest height with both hands cupping the bell.",
      "Squat down keeping the chest up and elbows tracking inside the knees.",
      "Stand back up driving through the mid-foot."
    ],
    "kb_halo_v1": [
      "Hold a light kettlebell upside down by the horns at chest height.",
      "Circle the kettlebell around the head close to the skull while keeping the elbows tucked.",
      "Reverse direction halfway through the set."
    ],
    "kb_press_v1": [
      "Stand with a kettlebell racked at the shoulder, elbow tucked, opposite hand at the side.",
      "Press the kettlebell overhead until the arm is fully extended and the bicep is near the ear.",
      "Lower in 2–3 seconds back to the rack and complete reps before switching sides."
    ],
    "kb_swing_v1": [
      "Stand with feet shoulder-width apart, kettlebell on the floor about a foot in front.",
      "Hinge at the hips, grip the kettlebell with both hands and hike it back between the legs.",
      "Drive the hips forward explosively to swing the kettlebell up to chest height, then let it fall back into the next rep."
    ],
    "kb_turkish_get_up_v1": [
      "Lie on your back with one arm pressing a kettlebell overhead, same-side knee bent and foot flat.",
      "Roll up to the elbow, then to the hand, then sweep the straight leg under to a half-kneeling position, all while keeping the kettlebell stacked over the shoulder.",
      "Stand up under control and reverse every step back to the floor; alternate sides."
    ],
    "kb_windmill_v1": [
      "Stand with feet wider than shoulders and a light kettlebell pressed overhead in one hand.",
      "Rotate the feet 45° toward the empty hand and slide that hand down the inside of the leg while pushing the hips toward the loaded side.",
      "Return to standing under control by squeezing the obliques and glutes; switch sides."
    ],
    "Lat_Pulldown": [
      "Sit down on a pull-down machine with a wide bar attached to the top pulley. Make sure that you adjust the knee pad of the machine to fit your height. These pads will prevent your body from being raised by the resistance attached to the bar.",
      "Grab the bar with the palms facing forward using the prescribed grip. Note on grips: For a wide grip, your hands need to be spaced out at a distance wider than shoulder width. For a medium grip, your hands need to be spaced out at a distance equal to your shoulder width and for a close grip at a distance smaller than your shoulder width.",
      "As you have both arms extended in front of you holding the bar at the chosen grip width, bring your torso back around 30 degrees or so while creating a curvature on your lower back and sticking your chest out. This is your starting position.",
      "As you breathe out, bring the bar down until it touches your upper chest by drawing the shoulders and the upper arms down and back. Tip: Concentrate on squeezing the back muscles once you reach the full contracted position. The upper torso should remain stationary and only the arms should move. The forearms should do no other work except for holding the bar; therefore do not try to pull down the bar using the forearms.",
      "After a second at the contracted position squeezing your shoulder blades together, slowly raise the bar back to the starting position when your arms are fully extended and the lats are fully stretched. Inhale during this portion of the movement.",
      "Repeat this motion for the prescribed amount of repetitions."
    ],
    "lateral_step_down_v1": [
      "Stand on a step or box (10–20 cm) with the control foot near the edge.",
      "Slowly flex the support knee to lower the other foot toward the floor in 3–4 sec, keeping the knee aligned over the second toe.",
      "Touch the floor without transferring weight; push back up. Control the hip not dropping to the side."
    ],
    "Lying_Leg_Curls": [
      "Adjust the machine lever to fit your height and lie face down on the leg curl machine with the pad of the lever on the back of your legs (just a few inches under the calves). Tip: Preferably use a leg curl machine that is angled as opposed to flat since an angled position is more favorable for hamstrings recruitment.",
      "Keeping the torso flat on the bench, ensure your legs are fully stretched and grab the side handles of the machine. Position your toes straight (or you can also use any of the other two stances described on the foot positioning section). This will be your starting position.",
      "As you exhale, curl your legs up as far as possible without lifting the upper legs from the pad. Once you hit the fully contracted position, hold it for a second.",
      "As you inhale, bring the legs back to the initial position. Repeat for the recommended amount of repetitions."
    ],
    "nordic_curl_v1": [
      "Kneel with ankles secured under a bench, bar, or held by a partner.",
      "Keeping your body straight from knees to head, lean forward slowly (3–5 sec) under eccentric hamstring control.",
      "When you can no longer control the fall, use your hands to brake, then push back. Progress from partial to full range of motion."
    ],
    "pigeon_pose_v1": [
      "From all fours, bring your right knee forward and let it fall to the outside of your right hand; extend your left leg back.",
      "Lower your right hip toward the floor as much as comfortable without pain; a block or folded blanket under the hip can help.",
      "Hold 30–60 seconds on each side, breathing slowly; avoid compensating by leaning the torso to one side."
    ],
    "Plank": [
      "Get into a prone position on the floor, supporting your weight on your toes and your forearms. Your arms are bent and directly below the shoulder.",
      "Keep your body straight at all times, and hold this position as long as possible. To increase difficulty, an arm or leg can be raised."
    ],
    "postpp_bird_dog_v1": [
      "Start on hands and knees with wrists under shoulders and knees under hips (neutral spine).",
      "Gently engage the core, then simultaneously extend the opposite arm and leg until parallel to the floor.",
      "Hold for 2 seconds, return with control, and alternate sides for the prescribed repetitions."
    ],
    "postpp_clamshell_band_v1": [
      "Lie on your side with hips and knees bent at approximately 45 degrees. Place a resistance band just above the knees.",
      "Keeping the feet together and pelvis stable, rotate the top knee upward as far as comfortable without rolling the hip back.",
      "Lower the knee with control and repeat for the prescribed repetitions. Switch sides."
    ],
    "postpp_glute_bridge_march_v1": [
      "Lie on your back with knees bent and feet flat. Push through both heels to lift the hips into a bridge position.",
      "Keeping hips level and core engaged, slowly lift one foot an inch off the floor (marching motion), then lower it.",
      "Alternate feet for the prescribed repetitions while maintaining a steady bridge height."
    ],
    "postpp_heel_slides_v1": [
      "Lie on your back with knees bent and feet flat. Engage the lower abdominals lightly.",
      "Slowly slide one heel away until the leg straightens partially, then slide it back under control.",
      "Alternate sides for the prescribed repetitions, maintaining core engagement."
    ],
    "postpp_modified_plank_knees_v1": [
      "Start on forearms and knees with a straight line from shoulders to knees.",
      "Gently engage the core and hold the position with normal breathing for the prescribed duration.",
      "Progress by increasing hold time or moving to toes when appropriate and cleared."
    ],
    "postpp_pelvic_tilt_supine_v1": [
      "Lie on your back with knees bent and feet flat on the floor.",
      "Gently tilt the pelvis to flatten the lower back against the floor by engaging the lower abdominals.",
      "Hold the tilted position for the prescribed time, breathing steadily. Repeat for the set."
    ],
    "postpp_standing_pelvic_tilt_v1": [
      "Stand with feet hip-width and a neutral spine. Soften the knees slightly.",
      "Tilt the pelvis under by engaging the lower abdominals, reducing lumbar lordosis slightly.",
      "Hold briefly and return to neutral. Use small, controlled repetitions."
    ],
    "postpp_ta_bracing_supine_v1": [
      "Lie on your back with knees bent and feet on the floor. Palms can rest on the pelvis to feel subtle movement.",
      "Gently draw the lower abdomen towards the spine (short, subtle contraction) without holding the breath.",
      "Hold the gentle brace for the prescribed duration and breathe normally. Repeat for the set."
    ],
    "postpp_wall_sit_isometric_v1": [
      "Stand with your back flat against a wall and feet hip-width, about 60 cm from the wall.",
      "Slide down until thighs are near parallel (or to a comfortable angle), keeping knees above ankles.",
      "Hold the position for the prescribed duration breathing normally, then slide back up."
    ],
    "pullup_neutral_grip_v1": [
      "Hang from parallel pull-up handles with palms facing each other, arms fully extended.",
      "Pull the chest toward the bar by driving the elbows down and back.",
      "Lower in 2–3 seconds back to a dead hang under control."
    ],
    "Pushups": [
      "Lie on the floor face down and place your hands about 36 inches apart while holding your torso up at arms length.",
      "Next, lower yourself downward until your chest almost touches the floor as you inhale.",
      "Now breathe out and press your upper body back up to the starting position while squeezing your chest.",
      "After a brief pause at the top contracted position, you can begin to lower yourself downward again for as many repetitions as needed."
    ],
    "resistance_band_row_standing_v1": [
      "Hold a resistance band anchored at hip height or grip both ends in your hands.",
      "Stand with knees slightly bent, drive elbows back bringing hands alongside your torso and squeezing shoulder blades together.",
      "Return slowly to the start position under 2 seconds of control."
    ],
    "ring_row_v1": [
      "Set the rings at hip height and grab the handles with arms extended, body in a straight line, heels on the floor.",
      "Pull the chest up to the rings by retracting the shoulder blades and bending the elbows.",
      "Lower in 2 seconds back to full extension; raise feet to a box for added difficulty."
    ],
    "seated_marching_v1": [
      "Sit tall in a chair with feet flat on the floor and hands resting on thighs or at your sides.",
      "Alternately lift each knee toward your chest to hip height, as if marching while seated.",
      "Keep your torso stable and spine long throughout the movement."
    ],
    "seated_spinal_twist_v1": [
      "Sit on the floor with legs extended. Bend your right knee and place the foot flat on the floor outside your left knee.",
      "Place your left hand on your right knee and rotate your torso to the right, placing your right hand behind you for support.",
      "Hold 30 seconds, rotating a little further with each exhale; return to center and repeat on the other side."
    ],
    "single_leg_squat_v1": [
      "Stand on one leg, the other slightly in front or to the side, arms extended for balance.",
      "Slowly flex the support knee as far as possible without it collapsing inward or the hip dropping.",
      "Return to start by pushing through the heel. Use wall support to progress toward freestanding."
    ],
    "sit_to_stand_v1": [
      "Sit in a chair with feet hip-width apart and flat on the floor.",
      "Lean your torso slightly forward, push through your heels and stand up until fully erect.",
      "Control the descent by sitting back down slowly without dropping onto the chair."
    ],
    "Standing_Calf_Raises": [
      "Adjust the padded lever of the calf raise machine to fit your height.",
      "Place your shoulders under the pads provided and position your toes facing forward (or using any of the two other positions described at the beginning of the chapter). The balls of your feet should be secured on top of the calf block with the heels extending off it. Push the lever up by extending your hips and knees until your torso is standing erect. The knees should be kept with a slight bend; never locked. Toes should be facing forward, outwards or inwards as described at the beginning of the chapter. This will be your starting position.",
      "Raise your heels as you breathe out by extending your ankles as high as possible and flexing your calf. Ensure that the knee is kept stationary at all times. There should be no bending at any time. Hold the contracted position by a second before you start to go back down.",
      "Go back slowly to the starting position as you breathe in by lowering your heels as you bend the ankles until calves are stretched.",
      "Repeat for the recommended amount of repetitions."
    ],
    "step_up_v1": [
      "Place one full foot on a step or box about 20–30 cm high.",
      "Drive through the heel of the elevated foot to lift your body, bringing the other foot up to level.",
      "Control the descent over 2 sec; alternate legs or complete all reps on one side before switching."
    ],
    "supine_twist_v1": [
      "Lie on your back; bring both knees to your chest and let them fall gently to one side while extending arms out in a T.",
      "Turn your head to the opposite side from your knees if comfortable, to increase thoracic rotation.",
      "Hold 30–45 seconds on each side; a gradual release of lumbar tension is normal."
    ],
    "thread_the_needle_v1": [
      "Start on all fours with hips over knees and shoulders over wrists.",
      "Slide one arm underneath your body, rotating your torso, until the shoulder and side of the head reach the floor.",
      "Hold 2–3 seconds feeling the thoracic stretch, return to start, and repeat on the other side."
    ],
    "wall_push_up_v1": [
      "Stand facing a wall about 60 cm away, hands at shoulder height and slightly wider than shoulder-width.",
      "Bend your elbows until your chest nearly touches the wall, keeping your body straight like a plank.",
      "Push the wall to return to the start position, controlling the movement throughout."
    ],
    "world_greatest_stretch_v1": [
      "Step your right foot forward into a deep lunge; place your left hand on the floor just inside your right foot.",
      "Rotate your torso to the right, sweeping your right arm up toward the ceiling, opening your chest and tracking your thumb.",
      "Return the hand to the floor, extend the front leg to feel the hamstring stretch, then return to lunge. Do 3–5 reps per side."
    ]
  }
}
