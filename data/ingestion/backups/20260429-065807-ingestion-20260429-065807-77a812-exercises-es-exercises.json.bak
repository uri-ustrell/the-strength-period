  "weighted_vest_step_up_v1": "Step-up con chaleco",
  "Wide-Grip_Lat_Pulldown": "Jalón al pecho con agarre ancho",
  "world_greatest_stretch_v1": "World's Greatest Stretch",
  "wrist_warmup_circles_v1": "Círculos de calentamiento de muñecas",
  "instructions": {
    "alternate_nostril_breathing_v1": [
      "Siéntate cómodo y lleva la mano derecha a la cara con el pulgar sobre la fosa derecha y el anular sobre la izquierda.",
      "Cierra la fosa derecha e inhala por la izquierda, luego cierra la izquierda y exhala por la derecha.",
      "Inhala por la derecha, ciérrala y exhala por la izquierda; continúa alternando."
    ],
    "ankle_rocking_v1": [
      "Arrodíllate sobre una rodilla con el pie delantero plano y manos sobre el muslo.",
      "Empuja la rodilla delantera por encima de los dedos sintiendo estiramiento en el tobillo, con el talón en el suelo.",
      "Vuelve y repite; cambia de lado."
    ],
    "band_bicep_curl_v1": [
      "Pisa la banda en el centro; agarra los extremos con las palmas hacia arriba y brazos al lado del cuerpo.",
      "Flexiona los codos llevando las manos hacia los hombros sin balancear el tronco.",
      "Baja de forma controlada en 2 seg."
    ],
    "band_chest_press_standing_v1": [
      "Ancla la banda detrás de ti a la altura del pecho (puerta o peso estable).",
      "Agarra un extremo con cada mano, un pie ligeramente adelante para estabilidad.",
      "Empuja las manos hacia adelante hasta casi extendidos; vuelve lentamente en 2 seg."
    ],
    "band_face_pull_v1": [
      "Ancla una banda a la altura de la cara y da un paso atrás para tensarla, sosteniendo los extremos con palmas abajo.",
      "Tira de la banda hacia la cara guiando con los codos abiertos y haciendo rotación externa del hombro.",
      "Vuelve en 2 segundos sin perder tensión."
    ],
    "band_lateral_walk_v1": [
      "Coloca una banda elástica sobre los tobillos o rodillas; rodillas ligeramente flexionadas.",
      "Da pasos laterales controlados manteniendo tensión constante en la banda y el core estable.",
      "No dejes que los pies se junten del todo para mantener la tensión durante todo el movimiento."
    ],
    "band_overhead_press_v1": [
      "Pisa la banda en el centro con los pies a la anchura de las caderas; agarra los extremos a la altura de los hombros.",
      "Empuja las manos hacia arriba hasta casi extendidos, manteniendo el core activado.",
      "Baja lentamente hasta la altura de los hombros y repite."
    ],
    "band_squat_v1": [
      "Coloca una banda elástica justo por encima de las rodillas; de pie con los pies a la anchura de las caderas.",
      "Empuja las rodillas hacia afuera para oponer resistencia a la banda mientras haces la sentadilla.",
      "Baja hasta paralelo o más abajo; sube empujando por talones."
    ],
    "band_tricep_pushdown_v1": [
      "Ancla una banda en alto y agarra los extremos con los codos pegados al cuerpo.",
      "Empuja la banda hacia abajo extendiendo completamente los codos sin mover los brazos.",
      "Vuelve en 2 segundos a la posición inicial."
    ],
    "Barbell_Deadlift": [
      "Sitúate frente a la barra con los pies al ancho de las caderas.",
      "Flexiona las caderas y agarra la barra con las manos al ancho de los hombros.",
      "Mantén la espalda neutra, el pecho erguido y los hombros hacia atrás.",
      "Extiende las caderas y las rodillas para levantar la barra hasta estar completamente erguido.",
      "Baja la barra controlando el movimiento hacia el suelo."
    ],
    "Barbell_Squat": [
      "De pie con los pies al ancho de los hombros. Centra la barra sobre los hombros.",
      "Flexiona las rodillas y baja las caderas como si te sentaras en una silla.",
      "Mantén la espalda recta y el pecho erguido durante todo el movimiento.",
      "Baja hasta que las caderas estén por debajo de las rodillas (o hasta donde la movilidad permita).",
      "Empuja con los talones para volver a la posición inicial."
    ],
    "bb_bent_over_row_v1": [
      "Inclínate por las caderas hasta unos 45° de torso, sosteniendo la barra con agarre prono por fuera de las rodillas.",
      "Tira de la barra hacia las costillas inferiores guiando con los codos y juntando las escápulas.",
      "Baja en 2 segundos al inicio sin redondear la espalda."
    ],
    "bb_bicep_curl_v1": [
      "De pie con la barra a longitud de brazo, manos al ancho de hombros, palmas hacia delante.",
      "Flexiona los codos para subir la barra hacia los hombros sin balancear el torso.",
      "Baja en 2–3 segundos hasta la extensión completa del codo."
    ],
    "bb_close_grip_bench_v1": [
      "Túmbate en un banco con la barra agarrada al ancho de los hombros, codos ligeramente pegados.",
      "Baja la barra al pecho bajo en 2 segundos manteniendo los codos pegados a unos 30°.",
      "Empuja la barra hacia arriba hasta la extensión sin abrir los codos."
    ],
    "bb_overhead_press_v1": [
      "De pie con pies al ancho de cadera y la barra en posición rack en los hombros, manos justo por fuera del ancho de hombros.",
      "Empuja la barra recta hacia arriba moviendo la cabeza ligeramente hacia delante cuando pasa por delante de la cara.",
      "Baja en 2–3 segundos al rack frontal con los codos flexionados."
    ],
    "bb_shrug_v1": [
      "De pie con la barra a longitud de brazo frente a los muslos, manos al ancho de hombros.",
      "Eleva los hombros directamente hacia las orejas sin rotarlos.",
      "Pausa breve arriba y baja los hombros de forma controlada."
    ],
    "bird_dog_pregnancy_v1": [
      "A cuatro patas con columna neutra.",
      "Extiende el brazo y la pierna opuestos manteniendo caderas y hombros paralelos al suelo.",
      "Baja controlada y cambia de lado."
    ],
    "body_scan_v1": [
      "Túmbate cómodo de espaldas con brazos a los lados y ojos cerrados.",
      "Lleva la atención lento por cada parte del cuerpo desde los pies hasta la cabeza, observando sin juzgar.",
      "Respira naturalmente 10–20 minutos."
    ],
    "bound_alternating_v1": [
      "Corre unos pasos para coger ritmo.",
      "Empuja de una pierna y salta adelante y ligeramente arriba aterrizando en la pierna opuesta.",
      "Continúa alternando los bounds buscando distancia horizontal."
    ],
    "box_breathing_v1": [
      "Siéntate cómodo con la columna alta y los hombros relajados.",
      "Inhala por la nariz 4 segundos, retén 4 segundos.",
      "Exhala 4 segundos, retén vacío 4 segundos; repite el ciclo."
    ],
    "box_jump_v1": [
      "De pie a un pie de un cajón sólido con pies al ancho de cadera.",
      "Balancea los brazos atrás, haz un breve hinge y salta explosivo aterrizando suave sobre el cajón con rodillas flexionadas.",
      "Baja caminando (no saltes hacia abajo) para la siguiente repetición."
    ],
    "box_squat_jump_v1": [
      "Siéntate en un cajón bajo con pies planos y torso erguido.",
      "Empuja por los pies y salta explosivo del cajón.",
      "Aterriza suave, vuelve a sentarte brevemente y repite."
    ],
    "bridge_kegel_v1": [
      "Túmbate de espaldas con rodillas flexionadas y pies al ancho de cadera.",
      "Exhala elevando las caderas mientras activas suave el suelo pélvico.",
      "Inhala bajando las caderas y relajando el suelo pélvico; repite."
    ],
    "bridge_pose_yoga_v1": [
      "Túmbate de espaldas con rodillas flexionadas y pies al ancho de cadera.",
      "Empuja por los pies y eleva las caderas hacia el techo, opcionalmente entrelazando las manos debajo.",
      "Mantén respirando y baja controlado."
    ],
    "broad_jump_v1": [
      "De pie con pies al ancho de cadera, balancea los brazos atrás y flexiona las rodillas.",
      "Empuja los brazos adelante y salta lo máximo horizontalmente.",
      "Aterriza suave con rodillas flexionadas; resetea."
    ],
    "burpee_jump_v1": [
      "De pie con pies al ancho de hombros.",
      "Baja a plancha, haz una flexión, salta los pies a las manos y explota a un salto vertical.",
      "Aterriza suave y repite."
    ],
    "butterfly_breath_v1": [
      "Siéntate con las plantas de los pies juntas y rodillas relajadas abiertas.",
      "Inhala visualizando la respiración bajando a la pelvis y relajando el suelo.",
      "Exhala elevando suave el suelo pélvico; continúa el tiempo prescrito."
    ],
    "cat_cow_v1": [
      "Empieza a cuatro patas con muñecas bajo hombros y rodillas bajo caderas.",
      "Inhala y arquea la columna bajando el abdomen mientras miras arriba (vaca).",
      "Exhala y redondea la columna escondiendo barbilla y pelvis (gato); alterna lento."
    ],
    "childs_pose_v1": [
      "Arrodíllate en la esterilla con los dedos gordos juntos y las rodillas abiertas.",
      "Sienta las caderas en los talones y camina las manos delante extendiendo los brazos.",
      "Apoya la frente en la esterilla y respira lento hacia la espalda."
    ],
    "clap_pushup_v1": [
      "Plancha alta con manos al ancho de hombros.",
      "Baja el pecho y empuja explosivo dando una palmada arriba.",
      "Aterriza suave con codos flexibles y continúa."
    ],
    "cobra_pose_v1": [
      "Túmbate boca abajo con manos bajo hombros y codos pegados.",
      "Empuja ligeramente elevando el pecho del suelo con los codos aún flexionados.",
      "Mantén respirando; baja controlado."
    ],
    "coherent_breathing_v1": [
      "Siéntate o túmbate cómodo con la columna neutra.",
      "Inhala por la nariz 5 segundos expandiendo abdomen y costillas.",
      "Exhala por la nariz 5 segundos; continúa a este ritmo 5–10 minutos."
    ],
    "couch_stretch_v1": [
      "Arrodíllate de espaldas a la pared o sofá, coloca una tibia contra la pared con el pie hacia arriba y el otro pie plano delante en zancada.",
      "Contrae el glúteo trasero y eleva el pecho alto manteniendo la lumbar neutra.",
      "Mantén 30–60 segundos respirando lento; cambia de lado."
    ],
    "db_arnold_press_v1": [
      "Siéntate en un banco con respaldo con dos mancuernas frente a los hombros y las palmas hacia el cuerpo.",
      "Empuja las mancuernas hacia arriba mientras rotas las palmas hacia fuera hasta extender los brazos.",
      "Invierte el movimiento en 2 segundos hasta la posición inicial."
    ],
    "db_chest_supported_row_v1": [
      "Túmbate boca abajo en un banco inclinado a unos 30° con una mancuerna en cada mano y brazos colgando.",
      "Tira de ambas mancuernas hacia las costillas juntando las escápulas.",
      "Baja en 2 segundos hasta la extensión completa."
    ],
    "db_concentration_curl_v1": [
      "Siéntate en un banco con las piernas abiertas sosteniendo una mancuerna y apoyando ese codo contra la cara interna del muslo.",
      "Flexiona el codo para subir la mancuerna hasta el hombro manteniendo el codo fijo.",
      "Baja en 2 segundos; completa las repeticiones antes de cambiar de brazo."
    ],
    "db_hammer_curl_v1": [
      "De pie con una mancuerna en cada mano a los lados del cuerpo, palmas enfrentadas (agarre neutro).",
      "Flexiona los codos para llevar las mancuernas hacia los hombros sin rotar las muñecas.",
      "Baja en 2–3 segundos de forma controlada."
    ],
    "db_incline_bench_press_v1": [
      "Coloca un banco reclinable a 30–45° y túmbate con una mancuerna en cada mano a la altura del hombro, palmas hacia delante.",
      "Empuja ambas mancuernas hacia arriba y ligeramente hacia dentro hasta extender los brazos sin bloquear los codos.",
      "Baja las mancuernas en 2–3 segundos hasta que los codos lleguen al nivel del pecho, manteniendo las escápulas retraídas."
    ],
    "db_lateral_raise_v1": [
      "De pie con una mancuerna en cada mano, brazos relajados a los lados y ligera flexión de codo.",
      "Eleva ambos brazos a los lados hasta la altura de los hombros, guiando con el codo.",
      "Baja en 2–3 segundos hasta la posición inicial sin balanceo."
    ],
    "db_pullover_v1": [
      "Túmbate sobre un banco sosteniendo una mancuerna con ambas manos sobre el pecho y los codos ligeramente flexionados.",
      "Baja la mancuerna en arco hacia detrás de la cabeza hasta sentir un estiramiento en el dorsal y pecho, manteniendo la zona lumbar en contacto con el banco.",
      "Vuelve a llevar la mancuerna sobre el pecho de forma controlada."
    ],
    "db_rear_delt_fly_v1": [
      "Inclínate por las caderas con la espalda recta, mancuernas ligeras y brazos colgando, palmas enfrentadas.",
      "Eleva los brazos a los lados juntando las escápulas hasta que el brazo alcance el nivel del torso.",
      "Baja en 2 segundos al inicio de forma controlada."
    ],
    "db_renegade_row_v1": [
      "Colócate en posición de flexión con las manos sobre dos mancuernas separadas al ancho de los hombros, pies más abiertos que las caderas.",
      "Tira de una mancuerna hacia el costado del torso manteniendo las caderas paralelas al suelo.",
      "Baja controlado y alterna lados durante las repeticiones."
    ],
    "db_single_arm_row_v1": [
      "Apoya una rodilla y la mano del mismo lado sobre un banco; el otro pie en el suelo y la mancuerna en la mano libre.",
      "Tira de la mancuerna hacia el costado del torso guiando con el codo.",
      "Baja en 2 segundos; completa todas las repeticiones antes de cambiar de lado."
    ],
    "db_skullcrusher_v1": [
      "Túmbate en un banco con dos mancuernas extendidas sobre el pecho, palmas enfrentadas.",
      "Flexiona los codos para bajar las mancuernas hacia las sienes manteniendo los brazos verticales.",
      "Extiende los codos para volver sin abrirlos."
    ],
    "db_snatch_v1": [
      "Empieza con una mancuerna entre los pies y hinge para agarrarla con una mano.",
      "Empuja las caderas explosivo tirando la mancuerna recta arriba en un solo movimiento.",
      "Baja controlado al suelo y haz las reps antes de cambiar."
    ],
    "db_thruster_v1": [
      "De pie con una mancuerna en cada mano racked en hombros.",
      "Sentadilla a paralelo manteniendo el pecho alto.",
      "Empuja arriba explosivo y presiona las mancuernas sobre la cabeza en un solo movimiento."
    ],
    "db_zottman_curl_v1": [
      "De pie con una mancuerna en cada mano a los lados del cuerpo, palmas hacia delante.",
      "Flexiona los codos hasta los hombros, luego rota las muñecas para que las palmas queden abajo arriba.",
      "Baja en 3 segundos con las palmas abajo y rota a palmas arriba al final del recorrido."
    ],
    "dead_bug_neutral_pelvis_v1": [
      "Túmbate de espaldas con brazos al techo y rodillas sobre caderas a 90°.",
      "Exhala activando el core y baja el brazo y la pierna opuestos hacia el suelo sin arquear.",
      "Inhala devolviendo; alterna lados."
    ],
    "deep_squat_release_v1": [
      "De pie con pies algo más abiertos que las caderas, dedos hacia fuera.",
      "Baja a la sentadilla más profunda que toleres, con apoyo si hace falta.",
      "Mantén 30–60 segundos respirando lento hacia el suelo pélvico."
    ],
    "depth_drop_jump_v1": [
      "De pie sobre un cajón de altura moderada (30–60 cm).",
      "Sal del cajón y en cuanto aterrices, rebota inmediatamente en un salto vertical máximo.",
      "Aterriza suave y resetea antes del siguiente."
    ],
    "depth_jump_v1": [
      "De pie sobre una caja (20–40 cm), da un paso al frente y cae al suelo con ambos pies.",
      "Al contactar, amortigua la caída flexionando rodillas y caderas; inmediatamente salta hacia arriba para maximizar la potencia.",
      "Mantén el tiempo de contacto con el suelo al mínimo. Para el ejercicio si el contacto es rígido o una articulación da señales."
    ],
    "diaphragmatic_breathing_v1": [
      "Túmbate de espaldas con rodillas flexionadas y una mano en el pecho, la otra en el abdomen.",
      "Inhala lento por la nariz 4 segundos expandiendo el abdomen mientras el pecho se mantiene casi quieto.",
      "Exhala por los labios fruncidos 6 segundos; repite el tiempo prescrito."
    ],
    "downward_dog_v1": [
      "Desde cuatro patas, flexiona los dedos de los pies y eleva las caderas arriba y atrás formando una V invertida.",
      "Empuja el pecho hacia los muslos y los talones hacia el suelo sin bloquear rodillas.",
      "Mantén respirando con constancia el tiempo prescrito."
    ],
    "Dumbbell_Bicep_Curl": [
      "De pie con una mancuerna en cada mano, brazos extendidos a los lados.",
      "Flexiona los codos para subir las mancuernas hacia los hombros.",
      "Mantén los codos fijos al lado del cuerpo.",
      "Baja las mancuernas de manera controlada.",
      "Evita balancear el cuerpo para generar impulso."
    ],
    "Dumbbell_Lunges": [
      "De pie con una mancuerna en cada mano a los lados del cuerpo.",
      "Da un paso adelante con un pie y baja el cuerpo hasta que ambas rodillas formen 90 grados.",
      "La rodilla trasera casi toca el suelo.",
      "Empuja con el pie delantero para volver a la posición inicial.",
      "Alterna las piernas con cada repetición."
    ],
    "Dumbbell_Shoulder_Press": [
      "Siéntate o ponte de pie con una mancuerna en cada mano a la altura de los hombros.",
      "Empuja las mancuernas hacia arriba hasta extender completamente los brazos.",
      "Mantén el tronco estable y el abdomen activado.",
      "Baja las mancuernas de manera controlada hasta la altura de los hombros.",
      "Repite sin bloquear los codos completamente arriba."
    ],
    "eccentric_calf_raise_v1": [
      "De pie en el borde de un escalón con la mitad del pie, agarrándose a una pared para equilibrarse.",
      "Sube de puntillas con ambas piernas y baja lentamente en 4–5 seg con una sola pierna, dejando que el talón caiga por debajo del nivel del escalón.",
      "Vuelve con ambas piernas y repite. Progresa añadiendo carga o aumentando repeticiones."
    ],
    "fitball_dead_bug_v1": [
      "Túmbate de espaldas sosteniendo una fitball entre manos y rodillas con brazos y piernas a 90°.",
      "Presiona manos y rodillas contra la pelota mientras extiendes el brazo y pierna opuestos sin perder presión.",
      "Vuelve y alterna controlada."
    ],
    "fitball_pelvic_circles_v1": [
      "Siéntate sobre una fitball con los pies planos y la columna alta.",
      "Haz círculos lentos con las caderas en una dirección.",
      "Invierte la dirección las mismas reps; respira natural."
    ],
    "fitball_pelvic_tilt_v1": [
      "Siéntate sobre una fitball con los pies planos y las manos en las caderas.",
      "Bascula la pelvis adelante y atrás lento sin mover el torso.",
      "Repite suave coordinando con la respiración."
    ],
    "fitball_wall_squat_v1": [
      "Coloca una fitball entre la parte baja de la espalda y una pared, pies al ancho del hombro y algo adelante.",
      "Baja rodando la pelota hasta que los muslos queden paralelos al suelo.",
      "Mantén o levántate controlada."
    ],
    "foam_roll_glutes_v1": [
      "Siéntate sobre un foam roller con un tobillo cruzado sobre la rodilla opuesta.",
      "Inclínate hacia el lado de la pierna cruzada y muévete lento sobre el glúteo.",
      "Pausa en puntos tensos y respira; cambia de lado."
    ],
    "foam_roll_quads_v1": [
      "Túmbate boca abajo con el foam roller en la parte frontal de los muslos, apoyado sobre los antebrazos.",
      "Muévete lento desde justo encima de las rodillas hasta los flexores de cadera.",
      "Pausa en puntos tensos y respira; evita rodar sobre la rótula."
    ],
    "foam_roll_thoracic_v1": [
      "Túmbate sobre un foam roller colocado en la parte alta de la espalda, rodillas flexionadas y manos detrás de la cabeza.",
      "Eleva ligeramente las caderas y muévete arriba y abajo entre las escápulas y la zona media.",
      "Pausa en puntos tensos y respira lento; evita la zona lumbar."
    ],
    "four_seven_eight_breathing_v1": [
      "Siéntate cómodo y coloca la punta de la lengua detrás de los dientes superiores.",
      "Inhala en silencio por la nariz 4 segundos, retén la respiración 7 segundos.",
      "Exhala audiblemente por la boca 8 segundos; repite 4 ciclos."
    ],
    "hang_clean_v1": [
      "De pie con la barra a la altura de la cadera, manos al ancho de hombros.",
      "Hinge a medio-muslo, explota empujando las caderas y lleva la barra a rack frontal en hombros, bajando para recibirla.",
      "Levántate del todo y baja la barra al inicio controlado."
    ],
    "happy_baby_pose_v1": [
      "Túmbate de espaldas y lleva las rodillas hacia las axilas.",
      "Agarra el exterior de los pies y tira de ellos suavemente hacia el suelo con las tibias verticales.",
      "Balancéate ligeramente respirando lento."
    ],
    "heel_slide_pelvic_v1": [
      "Túmbate de espaldas con rodillas flexionadas y pies en la esterilla.",
      "Exhala activando suave el suelo pélvico y desliza un talón hacia delante hasta extender la pierna.",
      "Inhala devolviendo el talón; alterna lados."
    ],
    "heel_slide_supine_v1": [
      "Túmbate de espaldas con rodillas flexionadas y pies en la esterilla.",
      "Exhala y desliza un talón hacia delante por el suelo hasta extender la pierna sin arquear.",
      "Inhala devolviendo el talón; alterna lados."
    ],
    "hip_90_90_switch_v1": [
      "Siéntate con una pierna delante con la tibia paralela al cuerpo y la otra al lado, ambas a 90°.",
      "Eleva las rodillas y rota las caderas para cambiar las piernas a la posición opuesta.",
      "Vuelve lento controlado sin ayudarte con las manos."
    ],
    "hip_cars_v1": [
      "De pie sobre una pierna, agárrate a una pared para equilibrio si hace falta.",
      "Eleva la rodilla libre a la altura de la cadera, ábrela al lado y luego llévala atrás y baja.",
      "Invierte el círculo; cambia de lado."
    ],
    "incline_plank_pregnancy_v1": [
      "Coloca las manos en un banco o silla sólida al ancho de hombros.",
      "Retrocede los pies en línea recta de cabeza a pies, exhalando y activando suave el suelo pélvico.",
      "Mantén el tiempo prescrito respirando; no dejes caer la lumbar."
    ],
    "kb_clean_v1": [
      "Empieza con la kettlebell en el suelo entre los pies, flexiona las caderas y agárrala con una mano.",
      "Empuja las caderas hacia delante para subir la kettlebell, guiando el codo hacia atrás mientras la campana rota alrededor de la muñeca.",
      "Recibe la kettlebell en posición rack en el hombro y vuelve al suelo."
    ],
    "kb_double_clean_v1": [
      "De pie con dos kettlebells en el suelo entre los pies.",
      "Hinge, agarra ambas y empuja las caderas para clean ambas a doble rack en hombros.",
      "Baja controlado al suelo y repite."
    ],
    "kb_double_press_v1": [
      "Empieza con dos kettlebells racked en hombros, codos pegados.",
      "Empuja ambas arriba hasta extensión completa.",
      "Baja en 2–3 segundos al rack."
    ],
    "kb_farmer_carry_v1": [
      "Sostén una kettlebell pesada en cada mano a los lados, hombros fijos y costillas hacia abajo.",
      "Camina hacia delante con pasos controlados durante la distancia o tiempo prescritos.",
      "Deja las kettlebells en el suelo con una flexión de caderas, no las dejes caer."
    ],
    "kb_goblet_squat_v1": [
      "Sostén una kettlebell a la altura del pecho con ambas manos sujetando la campana.",
      "Realiza la sentadilla manteniendo el pecho alto y los codos siguiendo por dentro de las rodillas.",
      "Levántate empujando por la planta del pie."
    ],
    "kb_halo_v1": [
      "Sostén una kettlebell ligera invertida por los cuernos a la altura del pecho.",
      "Haz círculos con la kettlebell alrededor de la cabeza pegada al cráneo con los codos flexionados.",
      "Invierte la dirección a mitad de la serie."
    ],
    "kb_press_v1": [
      "De pie con la kettlebell en posición rack en el hombro, codo pegado al cuerpo y la otra mano al costado.",
      "Empuja la kettlebell hacia arriba hasta extender completamente el brazo con el bíceps cerca de la oreja.",
      "Baja en 2–3 segundos al rack y completa las repeticiones antes de cambiar."
    ],
    "kb_snatch_v1": [
      "Empieza con la kettlebell en el suelo entre los pies.",
      "Hinge, empuja explosivo las caderas y tira la kettlebell recta arriba en un solo movimiento atravesando la mano arriba.",
      "Baja controlado al suelo y cambia manos según programación."
    ],
    "kb_swing_v1": [
      "De pie con los pies al ancho de hombros y la kettlebell en el suelo a un pie de distancia delante.",
      "Flexiona las caderas, agarra la kettlebell con ambas manos y pásala entre las piernas.",
      "Empuja las caderas hacia delante explosivamente para columpiar la kettlebell hasta la altura del pecho y deja que vuelva a la siguiente repetición."
    ],
    "kb_turkish_get_up_v1": [
      "Túmbate boca arriba con un brazo sosteniendo una kettlebell sobre la cabeza, misma rodilla flexionada y pie apoyado.",
      "Levántate hasta el codo, luego hasta la mano, y pasa la pierna recta por debajo hasta arrodillarte, manteniendo la kettlebell sobre el hombro.",
      "Ponte de pie controlado y revierte todos los pasos hasta el suelo; alterna lados."
    ],
    "kb_windmill_v1": [
      "De pie con los pies más abiertos que los hombros y una kettlebell ligera presionada sobre la cabeza con una mano.",
      "Rota los pies 45° hacia el lado de la mano libre y desliza esa mano por la cara interna de la pierna mientras empujas la cadera hacia el lado cargado.",
      "Vuelve al inicio contrayendo oblicuos y glúteos; cambia de lado."
    ],
    "kegel_basic_v1": [
      "Siéntate o túmbate cómoda con rodillas flexionadas y postura relajada.",
      "Eleva suave el suelo pélvico como si quisieras detener el pis, mantén 3–5 segundos sin aguantar la respiración.",
      "Suelta del todo 5 segundos antes de la siguiente repetición; la calidad importa más que la cantidad."
    ],
    "kegel_elevator_v1": [
      "Siéntate cómoda y visualiza el suelo pélvico como un ascensor con varios pisos.",
      "Contrae progresivamente en 3 niveles (planta 1, 2, arriba) manteniendo brevemente cada uno.",
      "Suelta en los mismos 3 niveles hasta relajación completa; respira natural."
    ],
    "kegel_quick_pulses_v1": [
      "Siéntate o túmbate cómoda con la columna neutra.",
      "Haz contracciones cortas de 1 segundo del suelo pélvico seguidas de soltar completo de 1 segundo.",
      "Mantén glúteos y aductores relajados; respira normal."
    ],
    "kegel_with_breath_v1": [
      "Túmbate de espaldas con rodillas flexionadas y una mano en el abdomen.",
      "Inhala relajando el suelo pélvico y expandiendo el abdomen.",
      "Exhala elevando suave el suelo pélvico; repite coordinando respiración y contracción."
    ],
    "Lat_Pulldown": [
      "Siéntate en la máquina de polea alta con los muslos fijados bajo las almohadillas.",
      "Agarra la barra con las manos más abiertas que los hombros.",
      "Tira de la barra hacia abajo hasta el pecho, contrayendo la espalda.",
      "Mantén el pecho erguido y los hombros hacia atrás.",
      "Retorna la barra de manera controlada a la posición inicial."
    ],
    "lateral_box_jump_v1": [
      "De pie de lado junto a un cajón bajo.",
      "Flexiona las rodillas y salta lateralmente al cajón aterrizando suave.",
      "Baja al lado opuesto y salta de vuelta; alterna."
    ],
    "lateral_step_down_v1": [
      "De pie sobre un escalón o caja (10–20 cm), con el pie de control al lado del suelo.",
      "Flexiona lentamente la rodilla de apoyo para bajar el otro pie hacia el suelo en 3–4 segundos, manteniendo la rodilla alineada sobre el segundo dedo.",
      "Toca el suelo sin transferir el peso; empuja para volver. Controla que la cadera no caiga al lado."
    ],
    "legs_up_wall_v1": [
      "Siéntate de lado contra una pared y sube las piernas por la pared mientras te tumbas en la esterilla.",
      "Desliza las caderas cerca de la pared y deja los brazos relajados a los lados.",
      "Respira lento 5–15 minutos."
    ],
    "Lying_Leg_Curls": [
      "Sitúate boca abajo en la máquina de piernas con los tobillos bajo las almohadillas.",
      "Agarra las asas laterales para estabilizarte.",
      "Flexiona las rodillas para llevar las almohadillas hacia los glúteos.",
      "Mantén la contracción un momento arriba.",
      "Baja lentamente a la posición inicial."
    ],
    "modified_side_plank_knee_v1": [
      "Túmbate de lado con el antebrazo de abajo en la esterilla y rodillas flexionadas y apiladas.",
      "Eleva las caderas creando una línea recta de rodillas a cabeza.",
      "Mantén respirando; cambia de lado."
    ],
    "mountain_climber_explosive_v1": [
      "Plancha alta con manos bajo hombros.",
      "Lleva una rodilla al pecho y cambia piernas explosivo en el aire.",
      "Continúa a ritmo rápido con caderas bajas."
    ],
    "neck_cars_v1": [
      "Siéntate o quédate de pie con los hombros relajados.",
      "Rota lento la cabeza dibujando un círculo controlado explorando el rango sin dolor.",
      "Invierte la dirección las mismas reps; mantén el movimiento lento."
    ],
    "nordic_curl_v1": [
      "Arrodíllate con los tobillos sujetos bajo un banco, barra o por un compañero.",
      "Manteniendo el cuerpo recto desde las rodillas hasta la cabeza, inclínate hacia adelante lentamente (3–5 seg), cediendo la resistencia de los isquiotibiales.",
      "Cuando no puedas controlar la caída, usa las manos para frenarte y empuja para volver. Progresa desde movimientos parciales a completos."
    ],
    "open_book_stretch_v1": [
      "Túmbate de lado con rodillas apiladas a 90° y brazos extendidos delante, palmas juntas.",
      "Inhala y abre lento el brazo de arriba siguiéndolo con la mirada, manteniendo las rodillas juntas.",
      "Exhala para volver; haz reps y cambia de lado."
    ],
    "pec_release_ball_v1": [
      "Coloca una pelota de masaje entre la parte alta del pecho y una pared, justo bajo la clavícula.",
      "Aplica presión contra la pelota y mueve el brazo para encontrar puntos tensos.",
      "Mantén 20–30 segundos cada punto respirando lento; cambia de lado."
    ],
    "pelvic_clock_v1": [
      "Túmbate de espaldas con rodillas flexionadas y pies en la esterilla.",
      "Imagina un reloj en la pelvis y bascula lento a las posiciones de 12, 3, 6 y 9.",
      "Haz círculos suaves en ambos sentidos; respira natural."
    ],
    "pigeon_pose_v1": [
      "Desde cuatro patas, lleva una tibia adelante cruzando la esterilla con la pierna trasera estirada.",
      "Cuadra las caderas y baja el torso sobre la tibia delantera hasta donde toleres.",
      "Mantén respirando lento; cambia de lado."
    ],
    "Plank": [
      "Sitúate en posición de flexión con los antebrazos en el suelo.",
      "Mantén el cuerpo en línea recta desde la cabeza hasta los talones.",
      "Activa el abdomen y evita que las caderas caigan o se eleven.",
      "Mantén la posición durante el tiempo indicado.",
      "Respira de manera constante durante todo el ejercicio."
    ],
    "plank_jack_v1": [
      "Plancha alta con pies juntos.",
      "Salta los pies abiertos a los lados e inmediatamente juntos.",
      "Continúa a ritmo constante con caderas niveladas."
    ],
    "plyo_pushup_v1": [
      "Plancha alta con manos al ancho de hombros.",
      "Baja el pecho y empuja explosivo para que las manos salgan del suelo.",
      "Aterriza suave con codos flexibles y baja a la siguiente repetición."
    ],
    "postpartum_band_row_v1": [
      "Siéntate alta con la banda alrededor de los pies y un extremo en cada mano.",
      "Tira de la banda hacia las costillas inferiores juntando las escápulas.",
      "Vuelve en 2 segundos sin perder tensión."
    ],
    "postpartum_diaphragmatic_breath_v1": [
      "Túmbate de espaldas o siéntate cómoda con una mano en el pecho y la otra en el abdomen.",
      "Inhala por la nariz expandiendo abdomen y costillas sin subir el pecho.",
      "Exhala lento soltando del todo; repite 5–10 minutos."
    ],
    "postpartum_gentle_squat_v1": [
      "De pie con pies al ancho de cadera, manos en las caderas.",
      "Baja a una profundidad cómoda manteniendo el pecho alto y exhalando al bajar.",
      "Levántate empujando por la planta del pie."
    ],
    "postpartum_glute_bridge_v1": [
      "Túmbate de espaldas con rodillas flexionadas y pies al ancho de cadera.",
      "Exhala elevando las caderas contrayendo los glúteos sin arquear la lumbar.",
      "Baja en 2 segundos controlada."
    ],
    "postpartum_pelvic_tilt_v1": [
      "Túmbate de espaldas con rodillas flexionadas y pies en la esterilla.",
      "Exhala basculando la pelvis para aplanar la lumbar y activar suave el suelo pélvico.",
      "Inhala soltando a neutra."
    ],
    "postpartum_seated_press_light_v1": [
      "Siéntate en una silla con respaldo y una mancuerna ligera en cada mano a la altura del hombro.",
      "Exhala empujando las mancuernas arriba sin arquear la lumbar.",
      "Baja en 2 segundos a los hombros."
    ],
    "postpartum_side_lying_glute_v1": [
      "Túmbate de lado con rodillas flexionadas y apiladas, cabeza sobre el brazo de abajo.",
      "Manteniendo los pies juntos, eleva la rodilla de arriba abriendo la cadera sin rotar la pelvis.",
      "Baja controlada; cambia de lado."
    ],
    "postpartum_standing_pelvic_tuck_v1": [
      "De pie con pies al ancho de cadera y rodillas suaves.",
      "Exhala basculando la pelvis y elevando suave el suelo pélvico.",
      "Inhala soltando a neutra; repite lento."
    ],
    "postpartum_walking_v1": [
      "Empieza con 5–10 minutos de caminar lento en plano, progresando semanalmente.",
      "Atención a sensación de pesadez en el suelo pélvico; para si hay síntomas.",
      "Aumenta la duración gradualmente antes del ritmo o desnivel."
    ],
    "postpartum_wall_pushup_v1": [
      "De pie de cara a una pared con manos a la altura del pecho, algo más abiertas que los hombros.",
      "Flexiona los codos acercando el pecho a la pared, exhalando y activando suave el core.",
      "Empuja sin bloquear los codos."
    ],
    "postpp_bird_dog_v1": [
      "Empieza a cuatro patas con muñecas bajo hombros y rodillas bajo caderas (columna neutra).",
      "Activa suavemente el core y extiende simultáneamente el brazo y la pierna opuestos hasta quedar paralelos al suelo.",
      "Mantén 2 segundos, vuelve con control y alterna lados por las repeticiones indicadas."
    ],
    "postpp_clamshell_band_v1": [
      "Túmbate de lado con caderas y rodillas flexionadas a unos 45 grados. Coloca una banda elástica justo por encima de las rodillas.",
      "Manteniendo los pies juntos y la pelvis estable, rota la rodilla superior hacia arriba sin volcar la cadera.",
      "Baja la rodilla con control y repite. Cambia de lado."
    ],
    "postpp_glute_bridge_march_v1": [
      "Tumbado/a boca arriba con rodillas flexionadas y pies planos. Empuja con los talones para elevar las caderas en posición de puente.",
      "Manteniendo las caderas niveladas y el core activo, levanta lentamente un pie un centímetro del suelo (movimiento de marcha) y bájalo.",
      "Alterna pies por las repeticiones indicadas manteniendo la altura del puente constante."
    ],
    "postpp_heel_slides_v1": [
      "Tumbado/a boca arriba con rodillas flexionadas y pies planos. Activa ligeramente el abdomen inferior.",
      "Desliza lentamente un talón hasta estirar parcialmente la pierna y vuelve a la posición inicial con control.",
      "Alterna lado por el número de repeticiones indicadas, manteniendo la activación del core."
    ],
    "postpp_modified_plank_knees_v1": [
      "Apoyado/a sobre los antebrazos y rodillas formando una línea recta desde los hombros hasta las rodillas.",
      "Activa suavemente el core y mantén la posición respirando normalmente el tiempo indicado.",
      "Progresa aumentando el tiempo de mantenimiento o pasando a la punta de los pies cuando sea adecuado y esté autorizado."
    ],
    "postpp_pelvic_tilt_supine_v1": [
      "Tumbado/a boca arriba con rodillas flexionadas y pies planos en el suelo.",
      "Inclina suavemente la pelvis para aplanar la espalda lumbar contra el suelo activando el abdomen inferior.",
      "Mantén la posición el tiempo indicado respirando regularmente. Repite la serie."
    ],
    "postpp_standing_pelvic_tilt_v1": [
      "De pie con los pies a la anchura de las caderas y columna neutra. Suaviza ligeramente las rodillas.",
      "Inclina la pelvis hacia abajo activando el abdomen inferior, reduciendo ligeramente la lordosis lumbar.",
      "Mantén brevemente y vuelve a neutro. Haz repeticiones pequeñas y controladas."
    ],
    "postpp_ta_bracing_supine_v1": [
      "Tumbado/a boca arriba con rodillas flexionadas. Las manos pueden reposar sobre la pelvis.",
      "Lleva suavemente el abdomen inferior hacia la columna (contracción corta y sutil) sin retener el aliento.",
      "Mantén la contracción ligera el tiempo indicado respirando normalmente. Repite la serie."
    ],
    "postpp_wall_sit_isometric_v1": [
      "De pie con la espalda plana contra la pared y pies a la anchura de las caderas, a unos 60 cm de la pared.",
      "Deslízate hacia abajo hasta que los muslos queden casi paralelos (o a un ángulo cómodo), manteniendo las rodillas sobre los tobillos.",
      "Mantén la posición el tiempo indicado respirando normalmente y vuelve a subir deslizando."
    ],
    "progressive_muscle_relaxation_v1": [
      "Túmbate de espaldas y tensa los pies 5 segundos, luego suelta totalmente 10 segundos.",
      "Sube por el cuerpo tensando y soltando gemelos, muslos, glúteos, abdomen, manos, brazos, hombros y cara.",
      "Termina con 1–2 minutos de respiración natural."
    ],
    "pullup_neutral_grip_v1": [
      "Cuélgate de mangos paralelos de dominadas con palmas enfrentadas, brazos completamente extendidos.",
      "Tira del pecho hacia la barra empujando los codos abajo y atrás.",
      "Baja en 2–3 segundos hasta la suspensión muerta de forma controlada."
    ],
    "push_press_v1": [
      "De pie con la barra racked en hombros, manos justo por fuera del hombro.",
      "Ligero dip de rodillas y empuja explosivo presionando la barra sobre la cabeza.",
      "Baja en 2–3 segundos al rack frontal."
    ],
    "Pushups": [
      "Sitúate en posición de plancha con las manos al ancho de los hombros.",
      "Baja el cuerpo flexionando los codos hasta que el pecho casi toque el suelo.",
      "Mantén el cuerpo en línea recta durante todo el movimiento.",
      "Empuja hacia arriba hasta extender los brazos completamente.",
      "Repite de manera controlada."
    ],
    "quadruped_toe_taps_v1": [
      "A cuatro patas con columna neutra.",
      "Eleva una rodilla de la esterilla y toca la punta del pie al lado sin rotar las caderas.",
      "Vuelve y alterna lados controlada."
    ],
    "resistance_band_row_seated_v1": [
      "Siéntate en el suelo o silla con piernas extendidas, banda alrededor de los pies y extremos en cada mano.",
      "Tira de la banda hacia las costillas inferiores juntando las escápulas.",
      "Vuelve en 2 segundos sin perder tensión."
    ],
    "resistance_band_row_standing_v1": [
      "Sujeta una banda elástica anclada a la altura de la cadera o con ambos extremos en las manos.",
      "De pie con rodillas ligeramente flexionadas, lleva los codos hacia atrás acercando las manos a los costados del tronco y juntando las escápulas.",
      "Regresa lentamente a la posición inicial con 2 segundos de control."
    ],
    "ring_row_v1": [
      "Coloca las anillas a la altura de la cadera y agárralas con brazos extendidos, cuerpo en línea recta y talones en el suelo.",
      "Tira del pecho hacia las anillas retrayendo las escápulas y flexionando los codos.",
      "Baja en 2 segundos a la extensión completa; eleva los pies sobre un cajón para mayor dificultad."
    ],
    "sandbag_bear_hug_carry_v1": [
      "Recoge el sandbag y abrázalo fuerte al pecho, brazos alrededor.",
      "Camina adelante con pasos controlados por la distancia o tiempo prescritos.",
      "Déjalo con una flexión de caderas."
    ],
    "sandbag_clean_v1": [
      "De pie con el sandbag entre los pies y agarra las asas o el saco.",
      "Hinge y explota arriba empujando las caderas, tirando el sandbag al pecho en posición rack.",
      "Baja al suelo controlado y repite."
    ],
    "sandbag_drag_v1": [
      "Ata una correa o agarra el sandbag y camina hacia atrás arrastrándolo por superficie lisa.",
      "Mantén una ligera inclinación adelante y el core activo.",
      "Continúa por la distancia o tiempo prescritos."
    ],
    "sandbag_get_up_v1": [
      "Túmbate de espaldas abrazando el sandbag al pecho.",
      "Siéntate, apoya una mano en el suelo y ponte de pie controlado.",
      "Invierte la secuencia hasta el suelo; alterna lados."
    ],
    "sandbag_rotational_lunge_v1": [
      "Sostén un sandbag a la altura del pecho y avanza a una zancada.",
      "Rota el torso hacia la pierna delantera sin perder el equilibrio.",
      "Vuelve a de pie y alterna lados."
    ],
    "sandbag_shoulder_to_shoulder_v1": [
      "Racked un sandbag en un hombro con ambas manos.",
      "Empuja explosivo arriba y baja al hombro opuesto.",
      "Alterna hombros las reps."
    ],
    "sandbag_squat_v1": [
      "Sostén un sandbag racked en el pecho con ambos brazos.",
      "Haz la sentadilla manteniendo el pecho alto y los codos arriba.",
      "Levántate empujando por la planta del pie."
    ],
    "sandbag_zercher_squat_v1": [
      "Sostén un sandbag en el ángulo de los codos a la altura del pecho.",
      "Haz la sentadilla manteniendo el pecho alto y codos pegados.",
      "Levántate empujando por la planta del pie."
    ],
    "savasana_v1": [
      "Túmbate de espaldas con los brazos ligeramente separados del cuerpo, palmas arriba, y los pies relajados abiertos.",
      "Cierra los ojos y deja que el cuerpo se hunda en la esterilla liberando todo esfuerzo muscular.",
      "Respira naturalmente 5–15 minutos."
    ],
    "seated_box_jump_v1": [
      "Siéntate en un cajón bajo con pies planos y brazos a los lados, sin movimiento previo.",
      "Sin balanceo, explota recto arriba saltando a un cajón objetivo delante.",
      "Baja y resetea entre reps."
    ],
    "seated_dumbbell_curl_pregnancy_v1": [
      "Siéntate en una silla con respaldo y una mancuerna ligera en cada mano.",
      "Flexiona los codos a los hombros sin arquear la lumbar.",
      "Baja en 2 segundos controlada."
    ],
    "seated_forward_fold_v1": [
      "Siéntate con ambas piernas extendidas delante y los pies flexionados.",
      "Inclínate desde las caderas hacia los pies sin redondear la lumbar.",
      "Mantén respirando; flexiona ligeramente las rodillas si hace falta."
    ],
    "seated_lateral_raise_light_v1": [
      "Siéntate en una silla con mancuernas ligeras a los lados, ligera flexión de codo.",
      "Eleva los brazos a los lados a la altura del hombro guiando con el codo.",
      "Baja en 2 segundos sin balanceo."
    ],
    "seated_marches_v1": [
      "Siéntate alta en una silla con pies planos y manos en el abdomen bajo.",
      "Eleva una rodilla hacia el pecho exhalando y activando el core.",
      "Baja controlada y alterna lados."
    ],
    "seated_marching_v1": [
      "Siéntate erguido en una silla con los pies en el suelo y las manos sobre los muslos o a los lados.",
      "Levanta alternadamente cada rodilla hacia el pecho hasta la altura de la cadera, como si marcharas sentado.",
      "Mantén el tronco estable y la columna alargada durante todo el movimiento."
    ],
    "seated_spinal_twist_v1": [
      "Siéntate en el suelo con las piernas extendidas. Flexiona la rodilla derecha y coloca el pie plano en el suelo fuera de la rodilla izquierda.",
      "Pon la mano izquierda en la rodilla derecha y gira el tronco hacia la derecha, colocando la mano derecha detrás de la espalda como apoyo.",
      "Mantén 30 segundos girando un poco más con cada exhalación; vuelve al centro y repite al otro lado."
    ],
    "shoulder_cars_v1": [
      "De pie con un brazo al lado, contrae el core.",
      "Traza el círculo controlado más grande posible con el brazo: adelante, arriba, atrás y abajo.",
      "Invierte la dirección; cambia de brazo."
    ],
    "side_lying_clamshell_v1": [
      "Túmbate de lado con rodillas flexionadas y apiladas, pies alineados con la columna.",
      "Mantén los pies juntos y eleva la rodilla de arriba abriendo como una almeja sin rotar la pelvis.",
      "Baja controlada; cambia de lado."
    ],
    "side_lying_leg_raise_v1": [
      "Túmbate de lado con la pierna de abajo flexionada y la de arriba extendida.",
      "Eleva la pierna de arriba a unos 45° sin rotar la cadera.",
      "Baja controlada; cambia de lado."
    ],
    "single_leg_box_jump_v1": [
      "De pie sobre una pierna de cara a un cajón bajo.",
      "Flexiona la rodilla y salta explosivo al cajón aterrizando suave en la misma pierna.",
      "Baja y haz las reps antes de cambiar."
    ],
    "single_leg_squat_v1": [
      "De pie sobre una pierna, la otra ligeramente al frente o al lado, brazos extendidos para el equilibrio.",
      "Flexiona lentamente la rodilla de apoyo hasta donde sea posible sin que colapse hacia dentro o la cadera caiga.",
      "Vuelve a la posición inicial empujando por el talón. Progresa con la mano en la pared hasta dominar el movimiento libre."
    ],
    "sit_to_stand_v1": [
      "Siéntate en una silla con los pies a la anchura de las caderas y planos en el suelo.",
      "Inclina ligeramente el tronco hacia adelante, empuja los talones contra el suelo y levántate hasta quedar completamente erguido.",
      "Controla el descenso volviendo a sentarte lentamente, sin caer sobre la silla."
    ],
    "skater_jump_v1": [
      "De pie sobre una pierna con la otra cruzada ligeramente atrás.",
      "Empuja lateralmente al lado opuesto aterrizando suave en la otra pierna con la pierna de seguimiento detrás.",
      "Continúa alternando lado a lado."
    ],
    "split_squat_jump_v1": [
      "Posición de split con un pie delante y otro detrás.",
      "Baja a zancada y salta explosivo cambiando piernas en el aire.",
      "Aterriza suave en la posición de split opuesta y repite."
    ],
    "squat_jump_v1": [
      "De pie con pies al ancho de hombros.",
      "Sentadilla a paralelo y explota arriba en salto vertical balanceando los brazos.",
      "Aterriza suave con rodillas flexionadas y repite."
    ],
    "standing_calf_raise_pregnancy_v1": [
      "De pie con pies al ancho de cadera, agarrada a una pared o silla.",
      "Sube sobre las puntas empujando los talones arriba.",
      "Baja en 2 segundos controlada."
    ],
    "Standing_Calf_Raises": [
      "Sitúate de pie con los pies al ancho de los hombros.",
      "Elévate sobre los dedos de los pies, apretando los gemelos arriba.",
      "Mantén la posición un segundo arriba.",
      "Baja lentamente hasta la posición inicial.",
      "Repite de manera controlada."
    ],
    "step_up_jump_v1": [
      "Coloca un pie en un cajón bajo, empuja y salta explosivamente al aire.",
      "Aterriza suave con el mismo pie en el cajón.",
      "Baja y alterna lados."
    ],
    "step_up_v1": [
      "Coloca un pie completo sobre un escalón o caja a unos 20–30 cm de altura.",
      "Empuja el talón del pie en el escalón para levantarte, llevando el otro pie al nivel del escalón.",
      "Baja controlando el descenso en 2 seg; alterna piernas o haz todas las reps de un lado primero."
    ],
    "sun_salutation_a_v1": [
      "Desde de pie, inhala brazos arriba, exhala flexión adelante, inhala medio elevado.",
      "Exhala retrocede a plancha, baja al suelo, inhala perro arriba, exhala perro abajo y respira.",
      "Paso o salto al frente, inhala medio elevado, exhala flexión, inhala a de pie; completa reps."
    ],
    "sun_salutation_b_v1": [
      "Desde de pie, inhala a postura de la silla, exhala flexión, inhala medio elevado, exhala retrocede a plancha-chaturanga, inhala perro arriba, exhala perro abajo.",
      "Inhala lleva el pie derecho a Guerrero I, exhala vuelve a plancha-chaturanga y fluye por perro arriba y abajo; repite con el izquierdo.",
      "Paso o salto al frente, inhala medio elevado, exhala flexión, inhala a silla, exhala a de pie; completa reps."
    ],
    "supine_twist_v1": [
      "Túmbate de espaldas, abraza una rodilla al pecho y guíala a través del cuerpo al lado opuesto.",
      "Extiende el brazo del mismo lado y mira hacia el brazo extendido, manteniendo ambos hombros en el suelo.",
      "Mantén respirando lento; cambia de lado."
    ],
    "supported_fish_pose_v1": [
      "Coloca un foam roller a lo largo de la columna y túmbate de espaldas para que sostenga la parte alta longitudinalmente.",
      "Deja caer los brazos a los lados y las piernas extendidas o flexionadas.",
      "Respira lento abriendo el pecho 2–5 minutos."
    ],
    "supported_squat_chair_v1": [
      "De pie ante una silla sólida con pies al ancho de cadera.",
      "Siéntate lenta hasta que los glúteos toquen la silla manteniendo el pecho alto.",
      "Levántate empujando por la planta del pie."
    ],
    "thoracic_bridge_v1": [
      "Siéntate con rodillas flexionadas, pies en el suelo y manos detrás con dedos hacia atrás.",
      "Eleva las caderas y rota a un lado extendiendo el brazo libre hacia arriba en extensión torácica.",
      "Vuelve a la posición inicial controlado; alterna lados."
    ],
    "thread_the_needle_v1": [
      "Comienza en cuadrupedia con las caderas sobre las rodillas y los hombros sobre las muñecas.",
      "Desliza un brazo por debajo del cuerpo, girando el tronco, hasta que el hombro y el lado de la cabeza lleguen al suelo.",
      "Mantén 2–3 segundos sintiendo el estiramiento torácico, vuelve a la posición inicial y repite al otro lado."
    ],
    "tree_pose_v1": [
      "De pie y transfiere el peso a una pierna.",
      "Coloca el otro pie en el tobillo, gemelo o muslo interno (evita la rodilla) y lleva las manos al pecho o arriba.",
      "Mantén respirando; cambia de lado."
    ],
    "triangle_pose_v1": [
      "Abre los pies, gira el pie delantero adelante y el trasero 90°, brazos extendidos a los lados.",
      "Flexiona por la cadera delantera llevando la mano delantera hacia el tobillo y la mano de arriba al techo.",
      "Mantén el pecho abierto y mira arriba; cambia de lado."
    ],
    "tuck_jump_v1": [
      "De pie con pies al ancho de cadera y brazos a los lados.",
      "Salta explosivo llevando las rodillas al pecho arriba.",
      "Aterriza suave flexionando las rodillas y repite."
    ],
    "tva_activation_supine_v1": [
      "Túmbate de espaldas con rodillas flexionadas y pies planos, manos sobre el abdomen bajo.",
      "Exhala lento llevando el abdomen bajo hacia la columna y elevando el suelo pélvico.",
      "Inhala soltando del todo; repite sin aplanar la curva lumbar."
    ],
