  "ytwl_complex_v1": "Complex YTWL",
  "instructions": {
    "ab_wheel_rollout_v1": [
      "A genolls al terra sostenint una roda abdominal sota les espatlles.",
      "Roda la roda endavant mantenint la columna neutra i les costelles avall.",
      "Torna sense perdre la pressió abdominal."
    ],
    "alternate_nostril_breathing_v1": [
      "Asseu-te còmode i porta la mà dreta a la cara amb el polze sobre la fossa dreta i l'anular sobre l'esquerra.",
      "Tanca la fossa dreta i inspira per l'esquerra, llavors tanca l'esquerra i espira per la dreta.",
      "Inspira per la dreta, tanca-la i espira per l'esquerra; continua alternant."
    ],
    "ankle_rocking_v1": [
      "Agenolla't sobre un genoll amb el peu davant pla i mans sobre la cuixa.",
      "Empeny el genoll davanter cap endavant per damunt dels dits sentint estirament al turmell, amb el taló a terra.",
      "Torna i repeteix; canvia de costat."
    ],
    "band_bicep_curl_v1": [
      "Trepitja la banda al centre; agafa els extrems amb les palmes cap amunt i braços al costat del cos.",
      "Flexiona els colzes portant les mans cap als muscles sense balancejar el tronc.",
      "Baixa de forma controlada en 2 seg."
    ],
    "band_chest_fly_v1": [
      "Ancora dues bandes a l'altura del pit darrere i agafa una nansa a cada mà amb braços oberts.",
      "Porta les mans davant del pit en arc prement el pit.",
      "Torna lent a l'inici."
    ],
    "band_chest_press_standing_v1": [
      "Ancora la banda darrere teu a l'alçada del pit (porta o pes estable).",
      "Agafa un extrem amb cada mà, un peu lleugerament davant per estabilitat.",
      "Empeny les mans cap endavant fins gairebé estesos; torna lentament en 2 seg."
    ],
    "band_concentration_curl_v1": [
      "Asseu-te i posa un peu sobre una banda, agafant l'altre extrem amb la mateixa mà.",
      "Recolza el colze contra la cara interna de la cuixa i cuda la banda amunt.",
      "Baixa lent a l'inici; fes les reps abans de canviar."
    ],
    "band_external_rotation_v1": [
      "Ancora una banda a l'altura del colze i posa't de costat agafant-la amb la mà més llunyana, colze a 90°.",
      "Rota l'avantbraç enfora del cos mantenint el colze al costat.",
      "Torna lent; fes les reps abans de canviar."
    ],
    "band_face_pull_v1": [
      "Ancora una banda a l'altura de la cara i fes un pas enrere per tensar-la, agafant els extrems amb palmells avall.",
      "Tira la banda cap a la cara guiant amb els colzes oberts i fent rotació externa de l'espatlla.",
      "Torna en 2 segons sense perdre tensió."
    ],
    "band_internal_rotation_v1": [
      "Ancora una banda a l'altura del colze i posa't de costat agafant-la amb la mà més propera, colze a 90°.",
      "Rota l'avantbraç cap a dins creuant el cos mantenint el colze fixat.",
      "Torna lent; fes les reps abans de canviar."
    ],
    "band_lateral_walk_v1": [
      "Col·loca una banda elàstica per sobre dels turmells o genolls; genolls lleugerament flexionats.",
      "Fes passos laterals controlats mantenint tensió constant a la banda i el core estable.",
      "No deixis que els peus es juntin del tot per mantenir la tensió durant tot el moviment."
    ],
    "band_monster_walk_v1": [
      "Posa una mini-banda als turmells o per sobre dels genolls i adopta un quart de sentadella.",
      "Camina endavant i enfora alternant cames mantenint tensió a la banda.",
      "Continua per les reps o distància prescrites."
    ],
    "band_overhead_press_v1": [
      "Trepitja la banda al centre amb els peus a l'amplada dels malucs; agafa els extrems a l'alçada de les espatlles.",
      "Empeny les mans cap amunt fins gairebé estesos, mantenint el core activat.",
      "Baixa lentament fins a l'alçada de les espatlles i repeteix."
    ],
    "band_seated_abduction_v1": [
      "Asseu-te en un banc amb una mini-banda al voltant de les cuixes, just per sobre dels genolls.",
      "Empeny els genolls cap enfora contra la banda mantenint els peus plans.",
      "Torna lent a l'inici."
    ],
    "band_squat_v1": [
      "Col·loca una banda elàstica just per sobre dels genolls; dempeus amb els peus a l'amplada dels malucs.",
      "Empeny els genolls cap a fora per oposar resistència a la banda mentre fas la sentadella.",
      "Baixa fins paral·lel o més avall; puja empenyent per talons."
    ],
    "band_tricep_overhead_extension_v1": [
      "Ancora una banda baixa i posa't d'esquena sostenint-la sobre el cap amb les dues mans.",
      "Flexiona els colzes baixant la banda darrere el cap.",
      "Estén els braços a l'inici controlat."
    ],
    "band_tricep_pushdown_v1": [
      "Ancora una banda al sostre i agafa els extrems amb els colzes enganxats al cos.",
      "Empeny la banda cap avall estenent completament els colzes sense moure els braços.",
      "Torna en 2 segons fins a la posició inicial."
    ],
    "Barbell_Deadlift": [
      "Situa't davant la barra amb els peus a l'amplada dels malucs.",
      "Flexiona els malucs i agafa la barra amb les mans a l'amplada de les espatlles.",
      "Mantén l'esquena neutra, el pit enlaire i les espatlles enrere.",
      "Estén els malucs i els genolls per aixecar la barra fins a estar completament dret.",
      "Baixa la barra controlant el moviment cap al terra."
    ],
    "Barbell_Squat": [
      "Dret amb els peus a l'amplada de les espatlles. Centra la barra sobre les espatlles.",
      "Flexiona els genolls i baixa els malucs com si et seguessis en una cadira.",
      "Mantén l'esquena recta i el pit enlaire durant tot el moviment.",
      "Baixa fins que els malucs estiguin per sota dels genolls (o fins on la mobilitat permeti).",
      "Empeny amb els talons per tornar a la posició inicial."
    ],
    "bb_bench_press_v1": [
      "Estira't en banc amb la barra sobre el pit, mans just per fora de l'espatlla.",
      "Baixa la barra al pit en 2–3 segons amb colzes a uns 45°.",
      "Pressiona la barra a lockout."
    ],
    "bb_bent_over_row_v1": [
      "Inclina't pels malucs fins a uns 45° de tronc, sostenint la barra amb presa pronada per fora dels genolls.",
      "Tira la barra cap a les costelles inferiors guiant amb els colzes i juntant les escàpules.",
      "Baixa en 2 segons fins a l'inici sense arrodonir l'esquena."
    ],
    "bb_bicep_curl_v1": [
      "Dret amb la barra a llargada de braç, mans a l'amplada de l'espatlla, palmells endavant.",
      "Flexiona els colzes per pujar la barra cap a les espatlles sense balancejar el tronc.",
      "Baixa en 2–3 segons fins a l'extensió completa del colze."
    ],
    "bb_close_grip_bench_v1": [
      "Estira't en un banc amb la barra agafada a l'amplada de l'espatlla, colzes lleugerament tucats.",
      "Baixa la barra al pit baix en 2 segons mantenint els colzes tucats a uns 30°.",
      "Empeny la barra cap amunt fins a l'extensió sense obrir els colzes."
    ],
    "bb_drag_curl_v1": [
      "Dret amb la barra a l'altura del maluc, mans a l'amplada de l'espatlla supinació.",
      "Cuda la barra arrossegant-la pel cos mantenint els colzes darrere el tronc.",
      "Baixa en 2–3 segons a l'inici."
    ],
    "bb_good_morning_v1": [
      "Dret amb la barra a la part alta de l'esquena, peus a l'amplada del maluc.",
      "Hinge als malucs amb una lleugera flexió de genoll baixant el tronc cap a paral·lel al terra.",
      "Empeny els malucs endavant per tornar a dret."
    ],
    "bb_hip_thrust_v1": [
      "Asseu-te amb l'esquena alta contra un banc i la barra sobre els malucs.",
      "Empeny pels talons aixecant els malucs fins formar línia recta de genolls a espatlles.",
      "Baixa controlat a l'inici."
    ],
    "bb_overhead_press_v1": [
      "Dret amb peus a l'amplada del maluc i la barra racked a les espatlles, mans just per fora de l'amplada de l'espatlla.",
      "Empeny la barra recta cap amunt, movent el cap lleugerament endavant quan passa per davant de la cara.",
      "Baixa en 2–3 segons fins al rack frontal amb els colzes plegats."
    ],
    "bb_pendlay_row_v1": [
      "Dret amb peus a l'amplada del maluc i la barra al terra sobre el mig del peu.",
      "Hinge a esquena plana paral·lela al terra i agafa la barra a l'amplada de l'espatlla.",
      "Rema la barra explosiu a les costelles baixes i torna-la al terra controlat entre reps."
    ],
    "bb_rdl_v1": [
      "Dret amb la barra a l'altura del maluc, mans a l'amplada de l'espatlla.",
      "Hinge als malucs amb una lleugera flexió de genoll, lliscant la barra per les cuixes fins notar estirament dels isquiotibials.",
      "Empeny els malucs endavant per tornar a dret mantenint la barra a prop del cos."
    ],
    "bb_shrug_v1": [
      "Dret amb la barra a llargada de braç davant les cuixes, mans a l'amplada de l'espatlla.",
      "Aixeca les espatlles directament cap a les orelles sense rotar-les.",
      "Pausa breu a dalt i baixa les espatlles de forma controlada."
    ],
    "bear_crawl_v1": [
      "Posició de mans i puntes dels peus amb genolls a un dit del terra.",
      "Avança movent la mà i el peu oposats alhora mantenint els malucs baixos.",
      "Continua per la distància o temps prescrits."
    ],
    "bike_hill_simulation_v1": [
      "Escalfa 5 minuts a ritme suau.",
      "Augmenta resistència per simular pujada forta i pedaleja dur 2–4 minuts.",
      "Recupera a baixa resistència 2 minuts; repeteix les reps prescrites."
    ],
    "bike_sprint_v1": [
      "Escalfa a ritme suau 5 minuts.",
      "Esprinta dur 20–30 segons a màxim esforç.",
      "Recupera a ritme suau 60–90 segons; repeteix les reps prescrites."
    ],
    "bike_tabata_v1": [
      "Escalfa a ritme suau 5 minuts.",
      "Alterna 20 segons d'esforç màxim amb 10 segons de recuperació, 8 rondes.",
      "Refreda a ritme suau 5 minuts."
    ],
    "bike_zone2_v1": [
      "Mantén un ritme constant i conversacional on parlar en frases curtes és possible.",
      "Mantén l'esforç durant la durada prescrita sense pics d'intensitat.",
      "Refreda els últims 5 minuts a ritme més suau."
    ],
    "bird_dog_pregnancy_v1": [
      "A quatre grapes amb columna neutra.",
      "Estén el braç i la cama oposats mantenint malucs i espatlles paral·lels al terra.",
      "Baixa controlat i canvia de costat."
    ],
    "bird_dog_row_v1": [
      "Tres punts: un genoll i la mà oposada en un banc, l'altre braç sostenint una manuella i la cama lliure estesa enrere.",
      "Rema la manuella a les costelles sense rotar els malucs.",
      "Baixa controlat; fes les reps abans de canviar."
    ],
    "body_saw_plank_v1": [
      "Planxa amb avantbraços i sliders o tovallola sota els peus.",
      "Empeny enrere amb els colzes perquè el cos llisqui cap als talons.",
      "Torna endavant a la planxa mantenint el core actiu."
    ],
    "body_scan_v1": [
      "Estira't còmode d'esquena amb braços als costats i ulls tancats.",
      "Porta l'atenció lentament per cada part del cos des dels peus fins al cap, observant sense jutjar.",
      "Respira naturalment 10–20 minuts."
    ],
    "bottoms_up_kb_press_v1": [
      "Sostén una kettlebell a l'espatlla amb la bola amunt i la nansa ben agafada.",
      "Pressiona la kettlebell sobre el cap mantenint la bola equilibrada cap per avall.",
      "Baixa controlat; fes les reps abans de canviar."
    ],
    "bound_alternating_v1": [
      "Corre uns passos per agafar ritme.",
      "Empeny d'una cama i salta endavant i lleugerament amunt aterrant a la cama oposada.",
      "Continua alternant pels bounds prescrits buscant distància horitzontal."
    ],
    "box_breathing_v1": [
      "Asseu-te còmode amb la columna alta i les espatlles relaxades.",
      "Inspira pel nas 4 segons, retén 4 segons.",
      "Espira 4 segons, retén buit 4 segons; repeteix el cicle."
    ],
    "box_jump_v1": [
      "Dret a un peu d'un calaix sòlid amb peus a l'amplada del maluc.",
      "Balanceja els braços enrere, fes un breu hinge i salta explosiu aterrant suau a sobre del calaix amb genolls flexionats.",
      "Baixa caminant (no saltis avall) per la repetició següent."
    ],
    "box_squat_jump_v1": [
      "Asseu-te en un calaix baix amb peus plans i tronc dret.",
      "Empeny pels peus i salta explosiu del calaix.",
      "Aterra suau, torna a seure breument i repeteix."
    ],
    "bridge_kegel_v1": [
      "Estira't d'esquena amb genolls flexionats i peus a l'amplada del maluc.",
      "Espira aixecant els malucs mentre actives suau el sòl pèlvic.",
      "Inspira baixant els malucs i relaxant el sòl pèlvic; repeteix."
    ],
    "bridge_pose_yoga_v1": [
      "Estira't d'esquena amb genolls flexionats i peus a l'amplada del maluc.",
      "Empeny pels peus i aixeca els malucs cap al sostre, opcionalment entrellaçant les mans sota.",
      "Mantingues respirant i baixa controlat."
    ],
    "brisk_walk_v1": [
      "Camina a un ritme on parlar en frases curtes és còmode.",
      "Mantén postura dreta i cadència constant.",
      "Continua el temps prescrit."
    ],
    "broad_jump_v1": [
      "Dret amb peus a l'amplada del maluc, balanceja els braços enrere i flexiona els genolls.",
      "Empeny els braços endavant i salta el màxim horitzontalment possible.",
      "Aterra suau amb genolls flexionats; reseteja."
    ],
    "bulgarian_split_squat_v1": [
      "Dret a una passa d'un banc i recolza la part superior d'un peu al banc darrere.",
      "Baixa a llunja fins que la cuixa davantera quedi paral·lela al terra.",
      "Empeny pel peu davanter per tornar; fes les reps abans de canviar."
    ],
    "burpee_jump_v1": [
      "Dret amb peus a l'amplada de l'espatlla.",
      "Baixa a planxa, fes una flexió, salta els peus a les mans i explota a un salt vertical.",
      "Aterra suau i repeteix."
    ],
    "butt_kicker_v1": [
      "Dret amb peus a l'amplada del maluc.",
      "Corre al lloc apartant els talons fins als glutis a cada pas.",
      "Continua a cadència ràpida el temps prescrit."
    ],
    "butterfly_breath_v1": [
      "Asseu-te amb les soles dels peus juntes i els genolls relaxats oberts.",
      "Inspira visualitzant la respiració baixant a la pelvis i relaxant el sòl.",
      "Espira aixecant suau el sòl pèlvic; continua pel temps prescrit."
    ],
    "cat_cow_v1": [
      "Comença a quatre grapes amb canells sota espatlles i genolls sota malucs.",
      "Inspira i arqueja la columna baixant la panxa mentre mires amunt (vaca).",
      "Espira i arrodoneix la columna amagant la barbeta i la pelvis (gat); alterna lentament."
    ],
    "childs_pose_v1": [
      "Agenolla't al matalàs amb els polzes dels peus tocant-se i els genolls oberts.",
      "Asseu els malucs als talons i camina les mans endavant estenent els braços.",
      "Recolza el front al matalàs i respira lent cap a l'esquena."
    ],
    "chinup_v1": [
      "Penja't d'una barra amb palmells cap al cos a l'amplada de l'espatlla.",
      "Tira el pit cap a la barra empenyent els colzes avall.",
      "Baixa en 2–3 segons a suspensió morta."
    ],
    "circuit_complex_basic_v1": [
      "Fes 10 sentadelles, 10 flexions i 10 abdominals seguides.",
      "Descansa 60 segons.",
      "Completa les rondes prescrites."
    ],
    "clap_pushup_v1": [
      "Planxa alta amb mans a l'amplada de l'espatlla.",
      "Baixa el pit i empeny explosiu picant les mans a dalt.",
      "Aterra suau amb colzes flexibles i continua."
    ],
    "close_grip_pushup_v1": [
      "Planxa alta amb mans sota les espatlles o lleugerament més tancades.",
      "Baixa el pit amb els colzes propers a les costelles.",
      "Empeny per tornar sense obrir els colzes."
    ],
    "cobra_pose_v1": [
      "Estira't boca avall amb les mans sota les espatlles i els colzes plegats.",
      "Empeny lleugerament aixecant el pit del terra amb els colzes encara plegats.",
      "Mantingues respirant; baixa controlat."
    ],
    "coherent_breathing_v1": [
      "Asseu-te o estira't còmode amb la columna neutra.",
      "Inspira pel nas 5 segons expandint la panxa i les costelles.",
      "Espira pel nas 5 segons; continua a aquest ritme 5–10 minuts."
    ],
    "copenhagen_plank_v1": [
      "Estira't de costat amb la cama de dalt recolzada en un banc a l'altura del turmell o genoll.",
      "Aixeca els malucs en planxa lateral pressionant la cama de dalt contra el banc.",
      "Mantén sense deixar caure els malucs el temps prescrit."
    ],
    "cossack_squat_v1": [
      "Dret amb peus més amples que l'espatlla.",
      "Desplaça el pes a un costat flexionant aquell genoll mentre l'altra cama queda recta amb dits amunt.",
      "Empeny per tornar al centre i alterna."
    ],
    "couch_stretch_v1": [
      "Agenolla't d'esquena a la paret o sofà, posa una tíbia contra la paret amb el peu cap amunt i l'altre peu pla davant en llunja.",
      "Contrau el glúti del darrere i puja el pit alt mantenint la lumbar neutra.",
      "Mantingues 30–60 segons respirant lent; canvia de costat."
    ],
    "crab_walk_v1": [
      "Asseu-te al terra amb mans darrere els malucs i peus plans.",
      "Aixeca els malucs en taula invertida i camina endavant o lateralment usant mà i peu oposats.",
      "Continua per la distància o temps prescrits."
    ],
    "cuban_press_db_v1": [
      "Dret amb una manuella lleugera a cada mà i colzes flexionats a 90° a l'altura del pit.",
      "Rota externament les espatlles portant les manuelles a les orelles.",
      "Pressiona sobre el cap, després inverteix per tornar."
    ],
    "curtsy_lunge_v1": [
      "Dret amb peus a l'amplada del maluc.",
      "Fes un pas enrere i creuat baixant a llunja reverència.",
      "Torna a dret i alterna."
    ],
    "db_arnold_press_v1": [
      "Asseu-te en un banc amb respatller, amb dues manuelles davant les espatlles i els palmells cap al cos.",
      "Empeny les manuelles cap amunt mentre rotes els palmells cap enfora fins a estendre els braços.",
      "Inverteix el moviment en 2 segons fins a la posició inicial."
    ],
    "db_bulgarian_split_squat_v1": [
      "Sostén una manuella a cada mà i posa't a una passa d'un banc amb un peu darrere recolzat.",
      "Baixa a llunja fins paral·lel.",
      "Empeny pel peu davanter per tornar a dret."
    ],
    "db_chest_fly_v1": [
      "Estira't en banc amb una manuella a cada mà pressionada sobre el pit, colzes lleugerament flexionats.",
      "Baixa les manuelles als costats en arc fins notar estirament al pit.",
      "Inverteix prement el pit a dalt."
    ],
    "db_chest_supported_row_v1": [
      "Estira't boca avall sobre un banc inclinat a uns 30° amb una manuella a cada mà i braços penjant.",
      "Tira les dues manuelles cap a les costelles juntant les escàpules.",
      "Baixa en 2 segons fins a l'extensió completa."
    ],
    "db_concentration_curl_v1": [
