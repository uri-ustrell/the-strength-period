  "weighted_vest_pushup_v1": "Flexión con chaleco lastrado",
  "weighted_vest_ruck_walk_v1": "Ruck walking con chaleco",
  "weighted_vest_squat_v1": "Sentadilla con chaleco",
  "weighted_vest_step_up_v1": "Step-up con chaleco",
