  "world_greatest_stretch_v1": "El millor estirament del món",
  "instructions": {
    "band_bicep_curl_v1": [
      "Trepitja la banda al centre; agafa els extrems amb les palmes cap amunt i braços al costat del cos.",
      "Flexiona els colzes portant les mans cap als muscles sense balancejar el tronc.",
      "Baixa de forma controlada en 2 seg."
    ],
    "band_chest_press_standing_v1": [
      "Ancora la banda darrere teu a l'alçada del pit (porta o pes estable).",
      "Agafa un extrem amb cada mà, un peu lleugerament davant per estabilitat.",
      "Empeny les mans cap endavant fins gairebé estesos; torna lentament en 2 seg."
    ],
    "band_face_pull_v1": [
      "Ancora una banda a l'altura de la cara i fes un pas enrere per tensar-la, agafant els extrems amb palmells avall.",
      "Tira la banda cap a la cara guiant amb els colzes oberts i fent rotació externa de l'espatlla.",
      "Torna en 2 segons sense perdre tensió."
    ],
    "band_lateral_walk_v1": [
      "Col·loca una banda elàstica per sobre dels turmells o genolls; genolls lleugerament flexionats.",
      "Fes passos laterals controlats mantenint tensió constant a la banda i el core estable.",
      "No deixis que els peus es juntin del tot per mantenir la tensió durant tot el moviment."
    ],
    "band_overhead_press_v1": [
      "Trepitja la banda al centre amb els peus a l'amplada dels malucs; agafa els extrems a l'alçada de les espatlles.",
      "Empeny les mans cap amunt fins gairebé estesos, mantenint el core activat.",
      "Baixa lentament fins a l'alçada de les espatlles i repeteix."
    ],
    "band_squat_v1": [
      "Col·loca una banda elàstica just per sobre dels genolls; dempeus amb els peus a l'amplada dels malucs.",
      "Empeny els genolls cap a fora per oposar resistència a la banda mentre fas la sentadella.",
      "Baixa fins paral·lel o més avall; puja empenyent per talons."
    ],
    "band_tricep_pushdown_v1": [
      "Ancora una banda al sostre i agafa els extrems amb els colzes enganxats al cos.",
      "Empeny la banda cap avall estenent completament els colzes sense moure els braços.",
      "Torna en 2 segons fins a la posició inicial."
    ],
    "Barbell_Deadlift": [
      "Situa't davant la barra amb els peus a l'amplada dels malucs.",
      "Flexiona els malucs i agafa la barra amb les mans a l'amplada de les espatlles.",
      "Mantén l'esquena neutra, el pit enlaire i les espatlles enrere.",
      "Estén els malucs i els genolls per aixecar la barra fins a estar completament dret.",
      "Baixa la barra controlant el moviment cap al terra."
    ],
    "Barbell_Squat": [
      "Dret amb els peus a l'amplada de les espatlles. Centra la barra sobre les espatlles.",
      "Flexiona els genolls i baixa els malucs com si et seguessis en una cadira.",
      "Mantén l'esquena recta i el pit enlaire durant tot el moviment.",
      "Baixa fins que els malucs estiguin per sota dels genolls (o fins on la mobilitat permeti).",
      "Empeny amb els talons per tornar a la posició inicial."
    ],
    "bb_bent_over_row_v1": [
      "Inclina't pels malucs fins a uns 45° de tronc, sostenint la barra amb presa pronada per fora dels genolls.",
      "Tira la barra cap a les costelles inferiors guiant amb els colzes i juntant les escàpules.",
      "Baixa en 2 segons fins a l'inici sense arrodonir l'esquena."
    ],
    "bb_bicep_curl_v1": [
      "Dret amb la barra a llargada de braç, mans a l'amplada de l'espatlla, palmells endavant.",
      "Flexiona els colzes per pujar la barra cap a les espatlles sense balancejar el tronc.",
      "Baixa en 2–3 segons fins a l'extensió completa del colze."
    ],
    "bb_close_grip_bench_v1": [
      "Estira't en un banc amb la barra agafada a l'amplada de l'espatlla, colzes lleugerament tucats.",
      "Baixa la barra al pit baix en 2 segons mantenint els colzes tucats a uns 30°.",
      "Empeny la barra cap amunt fins a l'extensió sense obrir els colzes."
    ],
    "bb_overhead_press_v1": [
      "Dret amb peus a l'amplada del maluc i la barra racked a les espatlles, mans just per fora de l'amplada de l'espatlla.",
      "Empeny la barra recta cap amunt, movent el cap lleugerament endavant quan passa per davant de la cara.",
      "Baixa en 2–3 segons fins al rack frontal amb els colzes plegats."
    ],
    "bb_shrug_v1": [
      "Dret amb la barra a llargada de braç davant les cuixes, mans a l'amplada de l'espatlla.",
      "Aixeca les espatlles directament cap a les orelles sense rotar-les.",
      "Pausa breu a dalt i baixa les espatlles de forma controlada."
    ],
    "db_arnold_press_v1": [
      "Asseu-te en un banc amb respatller, amb dues manuelles davant les espatlles i els palmells cap al cos.",
      "Empeny les manuelles cap amunt mentre rotes els palmells cap enfora fins a estendre els braços.",
      "Inverteix el moviment en 2 segons fins a la posició inicial."
    ],
    "db_chest_supported_row_v1": [
      "Estira't boca avall sobre un banc inclinat a uns 30° amb una manuella a cada mà i braços penjant.",
      "Tira les dues manuelles cap a les costelles juntant les escàpules.",
      "Baixa en 2 segons fins a l'extensió completa."
    ],
    "db_concentration_curl_v1": [
      "Asseu-te en un banc amb les cames obertes, sostenint una manuella amb una mà i recolzant aquell colze contra la cara interna de la cuixa.",
      "Flexiona el colze per pujar la manuella fins a l'espatlla mantenint el colze fix.",
      "Baixa en 2 segons; completa les reps abans de canviar de braç."
    ],
    "db_hammer_curl_v1": [
      "Dret amb una manuella a cada mà al costat del cos, palmells encarats (presa neutra).",
      "Flexiona els colzes per portar les manuelles cap a les espatlles sense rotar els canells.",
      "Baixa en 2–3 segons de forma controlada."
    ],
    "db_incline_bench_press_v1": [
      "Posa un banc reclinable a 30–45° i estira-t'hi amb una manuella a cada mà a l'alçada de l'espatlla, palmells endavant.",
      "Empeny les dues manuelles cap amunt i lleugerament cap a dins fins a estendre els braços sense bloquejar el colze.",
      "Baixa les manuelles en 2–3 segons fins que els colzes arribin més o menys al nivell del pit, mantenint les escàpules retretes."
    ],
    "db_lateral_raise_v1": [
      "Dret amb una manuella a cada mà, braços relaxats al costat del cos i lleugera flexió de colze.",
      "Eleva els braços als costats fins a l'alçada de les espatlles, guiant amb el colze.",
      "Baixa en 2–3 segons fins a la posició inicial sense balanceig."
    ],
    "db_pullover_v1": [
      "Estira't sobre un banc, sostenint una manuella amb les dues mans sobre el pit i els colzes lleugerament flexionats.",
      "Baixa la manuella en arc cap a darrere del cap fins notar un estirament al dorsal i al pit, amb la zona lumbar en contacte amb el banc.",
      "Torna la manuella sobre el pit de forma controlada."
    ],
    "db_rear_delt_fly_v1": [
      "Inclina't pels malucs amb l'esquena recta, amb manuelles lleugeres i braços penjant, palmells encarats.",
      "Eleva els braços als costats juntant les escàpules fins que el braç arribi al nivell del tronc.",
      "Baixa en 2 segons fins a l'inici de forma controlada."
    ],
    "db_renegade_row_v1": [
      "Posa't en posició de flexió amb les mans damunt dues manuelles separades a l'amplada de l'espatlla, peus més oberts que els malucs.",
      "Tira d'una manuella cap al costat del tòrax mantenint els malucs paral·lels al terra.",
      "Baixa controlat i alterna costats per fer les repeticions."
    ],
    "db_single_arm_row_v1": [
      "Recolza un genoll i la mà del mateix costat sobre un banc; l'altre peu a terra i la manuella a la mà lliure.",
      "Tira la manuella cap al costat del tòrax guiant amb el colze.",
      "Baixa en 2 segons; fes totes les reps abans de canviar de costat."
    ],
    "db_skullcrusher_v1": [
      "Estira't en un banc amb dues manuelles esteses sobre el pit, palmells encarats.",
      "Flexiona els colzes per baixar les manuelles cap a les temples mantenint els braços verticals.",
      "Estén els colzes per tornar sense obrir els colzes."
    ],
    "db_zottman_curl_v1": [
      "Dret amb una manuella a cada mà al costat del cos, palmells endavant.",
      "Flexiona els colzes fins a les espatlles, després rota els canells perquè els palmells quedin avall a dalt.",
      "Baixa en 3 segons amb els palmells avall i rota a palmells amunt al final del recorregut."
    ],
    "depth_jump_v1": [
      "Dret sobre una caixa (20–40 cm), passos cap endavant i cau al terra amb tots dos peus.",
      "En contactar, amorteix la caiguda flexionant genolls i malucs; immediatament salta cap amunt per maximitzar la potència.",
      "Mantén el temps de contacte amb el terra el mínim possible. Atura si el contacte és rígid o l'articulació dóna senyals."
    ],
    "downward_dog_v1": [
      "Des de la posició de planxa, empeny els malucs amunt i enrere formant una V invertida, amb les mans i peus a terra.",
      "Allarga la columna tractant de portar els talons al terra i el cap entre els braços mirant els peus.",
      "Manté de 20 a 40 segons respirant profundament; pots alternar flexions de genolls per aprofundir l'estirament dels isquiotibials."
    ],
    "Dumbbell_Bicep_Curl": [
      "Dret amb una manuella a cada mà, braços estesos als costats.",
      "Flexiona els colzes per pujar les manuelles cap a les espatlles.",
      "Mantén els colzes fixes al costat del cos.",
      "Baixa les manuelles de manera controlada.",
      "Evita balancejar el cos per generar impuls."
    ],
    "Dumbbell_Lunges": [
      "Dret amb una manuella a cada mà als costats del cos.",
      "Fes un pas endavant amb un peu i baixa el cos fins que ambdós genolls formin 90 graus.",
      "El genoll posterior gairebé toca el terra.",
      "Empeny amb el peu davanter per tornar a la posició inicial.",
      "Alterna les cames amb cada repetició."
    ],
    "Dumbbell_Shoulder_Press": [
      "Seu o situa't dret amb una manuella a cada mà a l'alçada de les espatlles.",
      "Empeny les manuelles cap amunt fins a estendre completament els braços.",
      "Mantén el tronc estable i l'abdomen activat.",
      "Baixa les manuelles de manera controlada fins a l'alçada de les espatlles.",
      "Repeteix sense bloquejar els colzes completament a dalt."
    ],
    "eccentric_calf_raise_v1": [
      "Dret al canell d'un escaló a la meitat de peu, agafant-se a una paret per equilibrar.",
      "Puja als punts de peus amb totes dues cames (concèntric) i baixa lentament en 4–5 seg amb una sola cama, deixant que el taló caigui per sota del nivell.",
      "Retorna amb les dues cames i repeteix. Progressa la càrrega afegint pes o augmentant reps."
    ],
    "kb_clean_v1": [
      "Comença amb la kettlebell al terra entre els peus, flexiona els malucs i agafa-la amb una mà.",
      "Empeny els malucs cap endavant per pujar la kettlebell, guiant el colze enrere mentre la campana rota al voltant del canell.",
      "Recull la kettlebell a la posició rack a l'espatlla i torna al terra."
    ],
    "kb_farmer_carry_v1": [
      "Subjecta una kettlebell pesada a cada mà al costat del cos, espatlles fixes i costelles cap avall.",
      "Camina endavant amb passos controlats durant la distància o temps prescrits.",
      "Deixa les kettlebells al terra amb una flexió de malucs, no les deixis caure."
    ],
    "kb_goblet_squat_v1": [
      "Subjecta una kettlebell a l'altura del pit amb les dues mans agafant la campana.",
      "Fes la sentadella mantenint el pit alt i els colzes seguint per dins dels genolls.",
      "Aixeca't empenyent pel mig del peu."
    ],
    "kb_halo_v1": [
      "Subjecta una kettlebell lleugera invertida pels banyots a l'altura del pit.",
      "Fes cercles amb la kettlebell al voltant del cap arran del crani amb els colzes plegats.",
      "Inverteix la direcció a meitat de la sèrie."
    ],
    "kb_press_v1": [
      "Dret amb la kettlebell racked a l'espatlla, colze enganxat al cos i l'altra mà al costat.",
      "Empeny la kettlebell cap amunt fins a estendre completament el braç amb el bíceps a prop de l'orella.",
      "Baixa en 2–3 segons fins al rack i fes totes les reps abans de canviar."
    ],
    "kb_swing_v1": [
      "Dret amb els peus a l'amplada de les espatlles i la kettlebell al terra a un peu de distància davant.",
      "Flexiona els malucs, agafa la kettlebell amb les dues mans i passa-la entre les cames.",
      "Empeny els malucs explosivament per balancejar la kettlebell fins a l'altura del pit i deixa-la caure cap a la repetició següent."
    ],
    "kb_turkish_get_up_v1": [
      "Estira't d'esquena amb un braç sostenint una kettlebell sobre el cap, mateix genoll flexionat amb el peu a terra.",
      "Aixeca't fins al colze, després fins a la mà, i passa la cama recta sota fins a quedar agenollat, mantenint sempre la kettlebell sobre l'espatlla.",
      "Posa't dret de forma controlada i reverteix tots els passos fins al terra; alterna costats."
    ],
    "kb_windmill_v1": [
      "Dret amb els peus més oberts que les espatlles i una kettlebell lleugera pressionada sobre el cap amb una mà.",
      "Rota els peus 45° cap al costat de la mà lliure i llisca aquella mà per la cara interna de la cama mentre empenys el maluc cap al costat carregat.",
      "Torna a l'inici contraient oblics i glutis; canvia de costat."
    ],
    "Lat_Pulldown": [
      "Seu a la màquina de politja alta amb les cuixes fixades sota els coixinets.",
      "Agafa la barra amb les mans més obertes que les espatlles.",
      "Tira la barra cap avall fins al pit, contraient l'esquena.",
      "Mantén el pit enlaire i les espatlles enrere.",
      "Retorna la barra de manera controlada a la posició inicial."
    ],
    "lateral_step_down_v1": [
      "Dret sobre un escaló o caixa (10–20 cm), amb el peu controlador al costat del pis.",
      "Flexiona lentament el genoll de recolzament per baixar l'altre peu cap al terra en 3–4 segons, mantenint el genoll alineat sobre el segon dit del peu.",
      "Toca el terra però sense transferir el pes; empeny per tornar a la posició inicial. Controla que el maluc no caigui cap al costat."
    ],
    "Lying_Leg_Curls": [
      "Situa't bocaterrosa a la màquina de cames amb els turmells sota els coixinets.",
      "Agafa les nanses laterals per estabilitzar-te.",
      "Flexiona els genolls per portar els coixinets cap als glutis.",
      "Mantén la contracció un moment a dalt.",
      "Baixa lentament a la posició inicial."
    ],
    "nordic_curl_v1": [
      "Agenolla't amb els turmells subjectats sota un banc, barra o per un company.",
      "Mantenint el cos recte des dels genolls fins al cap, inclina't cap endavant de forma lenta i controlada (3–5 seg), cedint la resistència dels isquiotibials.",
      "Quan ja no puguis controlar la caiguda, usa les mans per aturar-te i empenys per tornar. Progressa des de moviments parcials fins a complets."
    ],
    "pigeon_pose_v1": [
      "Des de quadrupèdia, porta el genoll dret cap endavant i deixa-lo caure cap a l'exterior de la mà dreta; estén la cama esquerra cap enrere.",
      "Baixa el maluc dret cap al terra o aproxima't tant com puguis sense dolor; pot ajudar un bloc o una manta doblada sota el maluc.",
      "Mantén de 30 a 60 segons de cada costat, respirant lentament; evita compensar inclinant el tronc cap a un costat."
    ],
    "Plank": [
      "Situa't en posició de flexió amb els avantbraços al terra.",
      "Mantén el cos en línia recta des del cap fins als talons.",
      "Activa l'abdomen i evita que els malucs caiguin o s'elevin.",
      "Mantén la posició durant el temps indicat.",
      "Respira de manera constant durant tot l'exercici."
    ],
    "postpp_bird_dog_v1": [
      "Comença a quatre grapes amb els canells sota les espatlles i els genolls sota els malucs (columna neutra).",
      "Activa suaument el core i estén simultàniament el braç i la cama oposats fins que siguin paral·lels al terra.",
      "Mantén 2 segons, torna amb control i alterna costats pel nombre de repeticions indicades."
    ],
    "postpp_clamshell_band_v1": [
      "Estirat/ada de costat amb els malucs i els genolls flexionats a uns 45 graus. Col·loca una banda elàstica just per sobre dels genolls.",
      "Mantenint els peus junts i la pelvis estable, gira el genoll superior cap amunt fins on sigui còmode sense bolcar el maluc.",
      "Baixa el genoll amb control i repeteix. Canvia de costat."
    ],
    "postpp_glute_bridge_march_v1": [
      "Estirat/ada de esquena amb els genolls flexionats i els peus plans. Empeny amb els talons per elevar els malucs en posició de pont.",
      "Mantenint els malucs anivellats i el core activat, aixeca lentament un peu un centímetre del terra (moviment de marxa) i torna a baixar-lo.",
      "Alterna peus pel nombre de repeticions indicades mantenint l'altura del pont constant."
    ],
    "postpp_heel_slides_v1": [
      "Estirat/ada de esquena amb els genolls flexionats i els peus plans. Activa lleugerament l'abdomen inferior.",
      "Llisca lentament un taló fins estirar parcialment la cama i torna a la posició inicial sota control.",
      "Alterna costat pel nombre de repeticions indicades, mantenint l'activació del core."
    ],
    "postpp_modified_plank_knees_v1": [
      "Recolzat/ada sobre els avantbraços i els genolls formant una línia recta des de les espatlles fins als genolls.",
      "Activa suaument el core i mantén la posició respirant normalment el temps indicat.",
      "Progressa augmentant el temps de manteniment o passant a la punta dels peus quan sigui adequat i s'hagi autoritzat."
    ],
    "postpp_pelvic_tilt_supine_v1": [
      "Estirat/ada de esquena amb els genolls flexionats i els peus plans a terra.",
      "Inclina suaument la pelvis per aplanar l'esquena lumbar contra el terra activant l'abdomen inferior.",
      "Mantén la posició el temps indicat respirant regularment. Repeteix la sèrie."
    ],
    "postpp_standing_pelvic_tilt_v1": [
      "De peu amb els peus a l'amplada dels malucs i columna neutra. Suavitza lleugerament els genolls.",
      "Inclina la pelvis sota activant l'abdomen inferior, reduint lleugerament la lordosi lumbar.",
      "Mantén breument i retorna a neutre. Fes repeticions petites i controlades."
    ],
    "postpp_ta_bracing_supine_v1": [
      "Estirat/ada de esquena amb els genolls flexionats. Les mans poden reposar sobre la pelvis per sentir el moviment subtil.",
      "Duu suaument l'abdomen inferior cap a la columna (contracció curta i subtil) sense retenir l'alè.",
      "Mantén la contracció lleugera el temps indicat respirant normalment. Repeteix la sèrie."
    ],
    "postpp_wall_sit_isometric_v1": [
      "Dret/a amb l'esquena plana contra la paret i els peus a l'amplada dels malucs, a uns 60 cm de la paret.",
      "Llisca cap avall fins que els cuixes quedin quasi paral·lels (o fins a un angle còmode), mantenint els genolls sobre els turmells.",
      "Mantén la posició el temps indicat respirant normalment i torna a pujar lliscant."
    ],
    "pullup_neutral_grip_v1": [
      "Penja't de mànecs paral·lels de dominades amb palmells encarats, braços ben estesos.",
      "Tira el pit cap a la barra empenyent els colzes avall i enrere.",
      "Baixa en 2–3 segons fins a la suspensió morta de forma controlada."
    ],
    "Pushups": [
      "Situa't en posició de planxa amb les mans a l'amplada de les espatlles.",
      "Baixa el cos flexionant els colzes fins que el pit gairebé toqui el terra.",
      "Mantén el cos en línia recta durant tot el moviment.",
      "Empeny cap amunt fins a estendre els braços completament.",
      "Repeteix de manera controlada."
    ],
    "resistance_band_row_standing_v1": [
      "Subjecta una banda elàstica ancorada a l'altura del maluc o amb els dos extrems a les mans.",
      "Dempeus amb genolls lleugerament flexionats, treu els colzes cap enrere portant las mans als costats del tronc i ajuntant les escàpules.",
      "Retorna lentament a la posició inicial amb 2 segons de control."
    ],
    "ring_row_v1": [
      "Posa les anelles a l'altura del maluc i agafa-les amb braços estesos, cos en línia recta i talons al terra.",
      "Tira el pit cap a les anelles retraient les escàpules i flexionant els colzes.",
      "Baixa en 2 segons fins a l'extensió completa; eleva els peus sobre una caixa per més dificultat."
    ],
    "seated_marching_v1": [
      "Seu ben dret en una cadira amb els peus a terra i les mans sobre les cuixes o als costats.",
      "Aixeca alternativament cada genoll cap al pit fins a l'altura del maluc, com si marxessis assegut.",
      "Mantén el tronc estable i la columna allargada durant tot el moviment."
    ],
    "seated_spinal_twist_v1": [
      "Seu al terra amb les cames esteses. Flexiona el genoll dret i col·loca el peu pla al terra a fora del genoll esquerre.",
      "Posa la mà esquerra al genoll dret i gira el tronc cap a la dreta, col·locant la mà dreta darrere l'esquena com a suport.",
      "Mantén 30 segons girant una mica més amb cada exhalació; torna al centre i repeteix a l'altre costat."
    ],
    "single_leg_squat_v1": [
      "Dret sobre una cama, l'altra lleugera davant o al costat, braços estesos per a l'equilibri.",
      "Flexiona lentament el genoll de recolzament fins on sigui possible sense que col·lapsi cap a dins o el maluc caigui.",
      "Retorna a la posició inicial empenyent pel taló. Progressa amb la mà a la paret fins dominar el moviment lliure."
    ],
    "sit_to_stand_v1": [
      "Seu en una cadira amb els peus a l'amplada dels malucs i plans a terra.",
      "Inclina lleugerament el tronc cap endavant, empeny els talons contra el terra i aixeca't fins a quedar totalment dret.",
      "Controla el descens tornant a seure lentament, sense caure sobre la cadira."
    ],
    "Standing_Calf_Raises": [
      "Situa't dret amb els peus a l'amplada de les espatlles.",
      "Eleva't sobre els dits dels peus, apretant els bessons a dalt.",
      "Mantén la posició un segon a dalt.",
      "Baixa lentament fins a la posició inicial.",
      "Repeteix de manera controlada."
    ],
    "step_up_v1": [
      "Col·loca un peu complet sobre un escaló o caixa a uns 20–30 cm d'altura.",
      "Empeny el taló del peu de l'escaló per aixecar el cos, portant l'altre peu al nivell de l'escaló.",
      "Baixa controlant el descens en 2 seg; alterna les cames o fes totes les reps d'un costat primer."
    ],
    "supine_twist_v1": [
      "Estira't d'esquena; porta els dos genolls al pit i deixa'ls caure suaument cap a un costat mentre estens els braços en creu.",
      "Gira el cap cap al costat contrari als genolls si és còmode, per augmentar la rotació toràcica.",
      "Mantén 30–45 segons de cada costat; és normal sentir un alleugeriment de tensió lumbar progressiu."
    ],
    "thread_the_needle_v1": [
      "Comença en quadrupèdia amb els malucs sobre els genolls i les espatlles sobre els canells.",
      "Llisca un braç per sota del cos, girant el tronc, fins que l'espatlla i el costat del cap arribin al terra.",
      "Mantén la posició 2–3 segons sentint l'estirament toràcic, torna a la posició inicial i repeteix a l'altre costat."
    ],
    "wall_push_up_v1": [
      "Posa't de peu davant d'una paret a uns 60 cm, amb les mans a l'alçada dels muscles i lleugerament separades.",
      "Flexiona els colzes fins que el pit s'acosti a la paret mantenint el cos recte com una planxa.",
      "Empeny la paret per tornar a la posició inicial controlant el moviment en tot moment."
    ],
    "world_greatest_stretch_v1": [
      "Fes un pas llarg cap endavant amb el peu dret fins a una postura de llunada baixa; col·loca la mà esquerra a terra just al costat del peu dret.",
      "Gira el tronc cap a la dreta portant el braç dret cap amunt fins al cel, obrint el pit i mirant el dit polze.",
      "Torna la mà al terra, estén la cama davantera per sentir l'estirament dels isquiotibials, i torna a la posició de llunada. Fes 3–5 reps per costat."
    ]
  }
}
