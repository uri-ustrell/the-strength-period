      "Mantén la posició 2–3 segons sentint l'estirament toràcic, torna a la posició inicial i repeteix a l'altre costat."
    ],
    "tree_pose_v1": [
      "Dret i transfereix el pes a una cama.",
      "Posa l'altre peu al turmell, bessó o cuixa interna (evita el genoll) i porta les mans al pit o amunt.",
      "Mantingues respirant; canvia de costat."
    ],
    "triangle_pose_v1": [
      "Obre els peus, gira el peu davanter endavant i el del darrere 90°, braços estesos als costats.",
      "Flexiona pel maluc davanter portant la mà davantera cap al turmell i la mà de dalt cap al sostre.",
      "Mantingues el pit obert i mira amunt; canvia de costat."
    ],
    "tuck_jump_v1": [
      "Dret amb peus a l'amplada del maluc i braços als costats.",
      "Salta explosiu portant els genolls al pit a dalt.",
      "Aterra suau flexionant els genolls i repeteix."
    ],
    "tva_activation_supine_v1": [
      "Estira't d'esquena amb genolls flexionats i peus plans, mans sobre la panxa baixa.",
      "Espira lent portant la panxa baixa cap a la columna i aixecant el sòl pèlvic.",
      "Inspira alliberant del tot; repeteix sense aplanar la corba lumbar."
    ],
    "upward_dog_v1": [
      "Estira't boca avall amb mans sota espatlles i empenyes dels peus al matalàs.",
      "Empeny les mans aixecant el pit, malucs i cuixes del terra amb braços estesos.",
      "Roda les espatlles enrere i mira lleugerament amunt; mantingues respirant."
    ],
    "wall_press_core_v1": [
      "Dret a un peu de la paret amb les dues palmes contra ella a l'altura del pit.",
      "Empeny la paret com si la volguessis allunyar mentre actives el core i espires.",
      "Mantingues l'activació respirant constant."
    ],
    "wall_push_up_v1": [
      "Posa't de peu davant d'una paret a uns 60 cm, amb les mans a l'alçada dels muscles i lleugerament separades.",
      "Flexiona els colzes fins que el pit s'acosti a la paret mantenint el cos recte com una planxa.",
      "Empeny la paret per tornar a la posició inicial controlant el moviment en tot moment."
    ],
    "wall_pushup_pregnancy_v1": [
      "Dret de cara a una paret amb mans a l'altura del pit, una mica més obertes que les espatlles.",
      "Flexiona els colzes acostant el pit a la paret mantenint el cos recte.",
      "Empeny per tornar sense bloquejar els colzes."
    ],
    "warrior_one_v1": [
      "Avança un peu en una llunja llarga amb el peu del darrere girat 45°.",
      "Flexiona el genoll davanter sobre el turmell i estén els dos braços amunt, palmells encarats.",
      "Quadra els malucs endavant i mantingues respirant; canvia de costat."
    ],
    "warrior_two_v1": [
      "Obre els peus, gira el peu davanter endavant i el del darrere 90° al costat.",
      "Flexiona el genoll davanter sobre el turmell i estén els braços paral·lels al terra.",
      "Mira sobre la mà davantera i mantingues respirant; canvia de costat."
    ],
    "weighted_vest_burpee_v1": [
      "Posa't l'armilla i dret amb peus a l'amplada de l'espatlla.",
      "Baixa a planxa, fes una flexió, salta els peus a les mans i explota a un petit salt.",
      "Aterra suau i repeteix."
    ],
    "weighted_vest_lunge_walk_v1": [
      "Posa't l'armilla i dret amb peus a l'amplada del maluc.",
      "Avança a una llunja baixant el genoll del darrere cap al terra.",
      "Empeny i passa el peu del darrere a la llunja següent; alterna."
    ],
    "weighted_vest_pullup_v1": [
      "Posa't l'armilla i penja't d'una barra de dominades amb palmells endavant.",
