    ],
    "butterfly_breath_v1": [
      "Asseu-te amb les soles dels peus juntes i els genolls relaxats oberts.",
      "Inspira visualitzant la respiració baixant a la pelvis i relaxant el sòl.",
      "Espira aixecant suau el sòl pèlvic; continua pel temps prescrit."
    ],
    "cat_cow_v1": [
      "Comença a quatre grapes amb canells sota espatlles i genolls sota malucs.",
      "Inspira i arqueja la columna baixant la panxa mentre mires amunt (vaca).",
      "Espira i arrodoneix la columna amagant la barbeta i la pelvis (gat); alterna lentament."
