  "ingested_presets": {
    "embaras_1r_trimestre_v1": {
      "name": "Embarazo — 1er trimestre (conservador)",
      "description": "Bloque conservador en modo generador para el primer trimestre. Prioriza estabilidad pélvica, movilidad de cadera y core suave. Consulte con un profesional sanitario."
    },
    "embaras_2n_trimestre_v1": {
      "name": "Embarazo — 2º trimestre (fuerza moderada)",
      "description": "Bloque fiel de fuerza moderada para el segundo trimestre: glúteos, estabilizadores y tren superior. Progresión conservadora. Consulte con un profesional sanitario."
    },
    "embaras_3r_trimestre_v1": {
      "name": "Embarazo — 3er trimestre (mantenimiento suave)",
      "description": "Bloque de mantenimiento muy suave para el tercer trimestre: movilidad, estabilizadores y core de bajo impacto. Consulte con una matrona o fisioterapeuta."
    },
    "mobilitat_toracica_espatlles_v1": {
      "name": "Movilidad torácica y hombros",
      "description": "Rutina fiel de movilidad torácica y de hombros inspirada en yoga/pilates. 2 sesiones/semana de 15–20 minutos. Aborda la rigidez de la cadena anterior habitual en poblaciones sedentarias."
    },
    "mobilitat_tren_inferior_v1": {
      "name": "Movilidad de cadera y tren inferior",
      "description": "Rutina de movilidad en modo generador para el tren inferior: flexores de cadera, rotadores externos, isquiotibiales y tobillo. Adecuada post-carrera o como sesión independiente de 20 minutos."
    },
    "postpart_corredora_general_v1": {
      "name": "Postparto — Corredora general (fuerza base)",
      "description": "Bloque de 6–12 semanas para corredoras posparto: reconstruye fuerza de tren inferior, estabilidad del core y resistencia específica para correr. Se requiere alta médica."
    },
    "postpart_generator_core_strength_v1": {
      "name": "Postparto — Generador: core → fuerza",
      "description": "Preset en modo generador que prioriza estabilidad pélvica, glúteos y estabilizadores de cadera; el algoritmo seleccionará ejercicios adecuados."
    },
    "postpart_rehab_conservative_v1": {
      "name": "Postparto — Rehabilitación suave",
      "description": "Bloque conservador de 4–6 semanas centrado en estabilidad pélvica, reeducación del core y movilidad. Consulte con un profesional de la salud."
    },
    "postpart_retorn_trail_v1": {
      "name": "Postparto — Retorno al trail (progresivo)",
      "description": "Bloque de 8–12 semanas que conecta la fuerza posparto con las demandas del trail: control excéntrico en bajadas, estabilidad reactiva y potencia de cadera. Se requiere alta médica."
    },
    "postpart_return_strength_v1": {
      "name": "Postparto — Retorno de fuerza (progresivo)",
      "description": "Bloque progresivo de 6–12 semanas para reconstruir fuerza y estabilidad de cadera y core. Aumente la carga de forma conservadora."
    },
    "postpart_return_to_running_v1": {
      "name": "Postparto — Retorno a la carrera (progresivo)",
      "description": "Bloque de 8–12 semanas que integra fuerza, estabilidad y pliometría controlada para preparar el retorno a la carrera. Precaución y aprobación médica recomendadas."
    },
    "principianta_descoberta_v1": {
      "name": "Principiante — Descubrimiento del movimiento",
      "description": "Bloque introductorio en modo generador para mujeres sin historial deportivo previo. Distribución muy conservadora, énfasis en movilidad y estabilidad. Ideal como primer programa de 4–6 semanas."
    },
    "principianta_forca_base_v1": {
      "name": "Principiante — Fuerza base (iniciación)",
      "description": "Bloque fiel de fuerza fundamental para principiantes. 2 sesiones/semana, ejercicios básicos con peso corporal o resistencia mínima. Prioriza técnica y aprendizaje del patrón de movimiento."
    },
    "principianta_forca_progressiva_v1": {
      "name": "Principiante — Fuerza progresiva (2a etapa)",
      "description": "Bloque fiel de progresión para mujeres que han completado el bloque de bases. 3 sesiones/semana con mancuernas ligeras, periodización ondulante. Recomendado a partir de las 6+ semanas del bloque introductorio."
    },
    "rutina_mobilitat_global_v1": {
      "name": "Rutina de movilidad global",
      "description": "Rutina fiel de movilidad de cuerpo completo para cualquier nivel. 3 sesiones/semana de 20 minutos alternando movilidad de tren inferior, tren superior e integrada."
    },
    "tsp_descent_eccentric_linear_04": {
      "name": "Control de Bajada y Salud de Rodilla",
      "description": "Bloque centrado en trabajo excéntrico para proteger el tendón rotuliano y aumentar la capacidad de frenado."
    },
    "tsp_hybrid_all_terrain_undulating_05": {
      "name": "Rendimiento Global: Atleta Híbrido",
      "description": "Programa completo que combina la fuerza específica para correr con el acondicionamiento general del tren superior."
    },
    "tsp_lumbar_resilience_linear_06": {
      "name": "Resiliencia Lumbar y Cintura Pélvica",
      "description": "Bloque preventivo y de rehabilitación para corredores con historial de lumbalgia o debilidad en la cadena posterior."
    },
    "tsp_road_foundation_linear_01": {
      "name": "Base en Asfalto: Fuerza Inicial",
      "description": "Bloque de introducción para corredores de asfalto que buscan una base sólida de fuerza y prevención de lesiones."
    },
    "tsp_trail_stability_undulating_02": {
      "name": "Trail Técnico: Estabilidad de Cadera y Core",
      "description": "Enfocado en mejorar el control motor y la estabilidad necesaria para terrenos irregulares y descensos técnicos."
    },
    "tsp_vertical_power_block_03": {
      "name": "Potencia Vertical: Especialista en Subida",
      "description": "Diseñado para corredores que quieren mejorar su rendimiento en fuertes desniveles positivos (Vertical Kilometer)."
    },
    "zero_descoberta_v1": {
      "name": "Cero — Descubrimiento del movimiento",
      "description": "Preset en modo generador para personas que nunca han hecho ejercicio. Muy conservador, centrado en aprender a moverse correctamente. Recomendado para las primeras 4 semanas."
    },
    "zero_fonaments_setmana01_04_v1": {
      "name": "Cero → Fundamentos (Semanas 1–4)",
      "description": "Bloque fiel para principiantes absolutos. 2 sesiones/semana de 15–20 minutos con ejercicios básicos de peso corporal. Prioriza aprender patrones de movimiento sobre la intensidad."
    },
    "zero_progressio_setmana05_10_v1": {
      "name": "Cero → Progresión (Semanas 5–10)",
      "description": "Segundo bloque para personas que han completado las 4 semanas iniciales. 2–3 sesiones/semana de 20–25 minutos. Introduce ejercicios compuestos básicos con carga muy ligera."
    }
  }
}
