  "world_greatest_stretch_v1": "El mejor estiramiento del mundo",
  "instructions": {
    "band_bicep_curl_v1": [
      "Pisa la banda en el centro; agarra los extremos con las palmas hacia arriba y brazos al lado del cuerpo.",
      "Flexiona los codos llevando las manos hacia los hombros sin balancear el tronco.",
      "Baja de forma controlada en 2 seg."
    ],
    "band_chest_press_standing_v1": [
      "Ancla la banda detrás de ti a la altura del pecho (puerta o peso estable).",
      "Agarra un extremo con cada mano, un pie ligeramente adelante para estabilidad.",
      "Empuja las manos hacia adelante hasta casi extendidos; vuelve lentamente en 2 seg."
    ],
    "band_face_pull_v1": [
      "Ancla una banda a la altura de la cara y da un paso atrás para tensarla, sosteniendo los extremos con palmas abajo.",
      "Tira de la banda hacia la cara guiando con los codos abiertos y haciendo rotación externa del hombro.",
      "Vuelve en 2 segundos sin perder tensión."
    ],
    "band_lateral_walk_v1": [
      "Coloca una banda elástica sobre los tobillos o rodillas; rodillas ligeramente flexionadas.",
      "Da pasos laterales controlados manteniendo tensión constante en la banda y el core estable.",
      "No dejes que los pies se junten del todo para mantener la tensión durante todo el movimiento."
    ],
    "band_overhead_press_v1": [
      "Pisa la banda en el centro con los pies a la anchura de las caderas; agarra los extremos a la altura de los hombros.",
      "Empuja las manos hacia arriba hasta casi extendidos, manteniendo el core activado.",
      "Baja lentamente hasta la altura de los hombros y repite."
    ],
    "band_squat_v1": [
      "Coloca una banda elástica justo por encima de las rodillas; de pie con los pies a la anchura de las caderas.",
      "Empuja las rodillas hacia afuera para oponer resistencia a la banda mientras haces la sentadilla.",
      "Baja hasta paralelo o más abajo; sube empujando por talones."
    ],
    "band_tricep_pushdown_v1": [
      "Ancla una banda en alto y agarra los extremos con los codos pegados al cuerpo.",
      "Empuja la banda hacia abajo extendiendo completamente los codos sin mover los brazos.",
      "Vuelve en 2 segundos a la posición inicial."
    ],
    "Barbell_Deadlift": [
      "Sitúate frente a la barra con los pies al ancho de las caderas.",
      "Flexiona las caderas y agarra la barra con las manos al ancho de los hombros.",
      "Mantén la espalda neutra, el pecho erguido y los hombros hacia atrás.",
      "Extiende las caderas y las rodillas para levantar la barra hasta estar completamente erguido.",
      "Baja la barra controlando el movimiento hacia el suelo."
    ],
    "Barbell_Squat": [
      "De pie con los pies al ancho de los hombros. Centra la barra sobre los hombros.",
      "Flexiona las rodillas y baja las caderas como si te sentaras en una silla.",
      "Mantén la espalda recta y el pecho erguido durante todo el movimiento.",
      "Baja hasta que las caderas estén por debajo de las rodillas (o hasta donde la movilidad permita).",
      "Empuja con los talones para volver a la posición inicial."
    ],
    "bb_bent_over_row_v1": [
      "Inclínate por las caderas hasta unos 45° de torso, sosteniendo la barra con agarre prono por fuera de las rodillas.",
      "Tira de la barra hacia las costillas inferiores guiando con los codos y juntando las escápulas.",
      "Baja en 2 segundos al inicio sin redondear la espalda."
    ],
    "bb_bicep_curl_v1": [
      "De pie con la barra a longitud de brazo, manos al ancho de hombros, palmas hacia delante.",
      "Flexiona los codos para subir la barra hacia los hombros sin balancear el torso.",
      "Baja en 2–3 segundos hasta la extensión completa del codo."
    ],
    "bb_close_grip_bench_v1": [
      "Túmbate en un banco con la barra agarrada al ancho de los hombros, codos ligeramente pegados.",
      "Baja la barra al pecho bajo en 2 segundos manteniendo los codos pegados a unos 30°.",
      "Empuja la barra hacia arriba hasta la extensión sin abrir los codos."
    ],
    "bb_overhead_press_v1": [
      "De pie con pies al ancho de cadera y la barra en posición rack en los hombros, manos justo por fuera del ancho de hombros.",
      "Empuja la barra recta hacia arriba moviendo la cabeza ligeramente hacia delante cuando pasa por delante de la cara.",
      "Baja en 2–3 segundos al rack frontal con los codos flexionados."
    ],
    "bb_shrug_v1": [
      "De pie con la barra a longitud de brazo frente a los muslos, manos al ancho de hombros.",
      "Eleva los hombros directamente hacia las orejas sin rotarlos.",
      "Pausa breve arriba y baja los hombros de forma controlada."
    ],
    "db_arnold_press_v1": [
      "Siéntate en un banco con respaldo con dos mancuernas frente a los hombros y las palmas hacia el cuerpo.",
      "Empuja las mancuernas hacia arriba mientras rotas las palmas hacia fuera hasta extender los brazos.",
      "Invierte el movimiento en 2 segundos hasta la posición inicial."
    ],
    "db_chest_supported_row_v1": [
      "Túmbate boca abajo en un banco inclinado a unos 30° con una mancuerna en cada mano y brazos colgando.",
      "Tira de ambas mancuernas hacia las costillas juntando las escápulas.",
      "Baja en 2 segundos hasta la extensión completa."
    ],
    "db_concentration_curl_v1": [
      "Siéntate en un banco con las piernas abiertas sosteniendo una mancuerna y apoyando ese codo contra la cara interna del muslo.",
      "Flexiona el codo para subir la mancuerna hasta el hombro manteniendo el codo fijo.",
      "Baja en 2 segundos; completa las repeticiones antes de cambiar de brazo."
    ],
    "db_hammer_curl_v1": [
      "De pie con una mancuerna en cada mano a los lados del cuerpo, palmas enfrentadas (agarre neutro).",
      "Flexiona los codos para llevar las mancuernas hacia los hombros sin rotar las muñecas.",
      "Baja en 2–3 segundos de forma controlada."
    ],
    "db_incline_bench_press_v1": [
      "Coloca un banco reclinable a 30–45° y túmbate con una mancuerna en cada mano a la altura del hombro, palmas hacia delante.",
      "Empuja ambas mancuernas hacia arriba y ligeramente hacia dentro hasta extender los brazos sin bloquear los codos.",
      "Baja las mancuernas en 2–3 segundos hasta que los codos lleguen al nivel del pecho, manteniendo las escápulas retraídas."
    ],
    "db_lateral_raise_v1": [
      "De pie con una mancuerna en cada mano, brazos relajados a los lados y ligera flexión de codo.",
      "Eleva ambos brazos a los lados hasta la altura de los hombros, guiando con el codo.",
      "Baja en 2–3 segundos hasta la posición inicial sin balanceo."
    ],
    "db_pullover_v1": [
      "Túmbate sobre un banco sosteniendo una mancuerna con ambas manos sobre el pecho y los codos ligeramente flexionados.",
      "Baja la mancuerna en arco hacia detrás de la cabeza hasta sentir un estiramiento en el dorsal y pecho, manteniendo la zona lumbar en contacto con el banco.",
      "Vuelve a llevar la mancuerna sobre el pecho de forma controlada."
    ],
    "db_rear_delt_fly_v1": [
      "Inclínate por las caderas con la espalda recta, mancuernas ligeras y brazos colgando, palmas enfrentadas.",
      "Eleva los brazos a los lados juntando las escápulas hasta que el brazo alcance el nivel del torso.",
      "Baja en 2 segundos al inicio de forma controlada."
    ],
    "db_renegade_row_v1": [
      "Colócate en posición de flexión con las manos sobre dos mancuernas separadas al ancho de los hombros, pies más abiertos que las caderas.",
      "Tira de una mancuerna hacia el costado del torso manteniendo las caderas paralelas al suelo.",
      "Baja controlado y alterna lados durante las repeticiones."
    ],
    "db_single_arm_row_v1": [
      "Apoya una rodilla y la mano del mismo lado sobre un banco; el otro pie en el suelo y la mancuerna en la mano libre.",
      "Tira de la mancuerna hacia el costado del torso guiando con el codo.",
      "Baja en 2 segundos; completa todas las repeticiones antes de cambiar de lado."
    ],
    "db_skullcrusher_v1": [
      "Túmbate en un banco con dos mancuernas extendidas sobre el pecho, palmas enfrentadas.",
      "Flexiona los codos para bajar las mancuernas hacia las sienes manteniendo los brazos verticales.",
      "Extiende los codos para volver sin abrirlos."
    ],
    "db_zottman_curl_v1": [
      "De pie con una mancuerna en cada mano a los lados del cuerpo, palmas hacia delante.",
      "Flexiona los codos hasta los hombros, luego rota las muñecas para que las palmas queden abajo arriba.",
      "Baja en 3 segundos con las palmas abajo y rota a palmas arriba al final del recorrido."
    ],
    "depth_jump_v1": [
      "De pie sobre una caja (20–40 cm), da un paso al frente y cae al suelo con ambos pies.",
      "Al contactar, amortigua la caída flexionando rodillas y caderas; inmediatamente salta hacia arriba para maximizar la potencia.",
      "Mantén el tiempo de contacto con el suelo al mínimo. Para el ejercicio si el contacto es rígido o una articulación da señales."
    ],
    "downward_dog_v1": [
      "Desde la posición de plancha, empuja las caderas hacia arriba y atrás formando una V invertida, con manos y pies en el suelo.",
      "Alarga la columna intentando llevar los talones al suelo y la cabeza entre los brazos mirando los pies.",
      "Mantén de 20 a 40 segundos respirando profundamente; puedes alternar flexiones de rodillas para profundizar el estiramiento de isquiotibiales."
    ],
    "Dumbbell_Bicep_Curl": [
      "De pie con una mancuerna en cada mano, brazos extendidos a los lados.",
      "Flexiona los codos para subir las mancuernas hacia los hombros.",
      "Mantén los codos fijos al lado del cuerpo.",
      "Baja las mancuernas de manera controlada.",
      "Evita balancear el cuerpo para generar impulso."
    ],
    "Dumbbell_Lunges": [
      "De pie con una mancuerna en cada mano a los lados del cuerpo.",
      "Da un paso adelante con un pie y baja el cuerpo hasta que ambas rodillas formen 90 grados.",
      "La rodilla trasera casi toca el suelo.",
      "Empuja con el pie delantero para volver a la posición inicial.",
      "Alterna las piernas con cada repetición."
    ],
    "Dumbbell_Shoulder_Press": [
      "Siéntate o ponte de pie con una mancuerna en cada mano a la altura de los hombros.",
      "Empuja las mancuernas hacia arriba hasta extender completamente los brazos.",
      "Mantén el tronco estable y el abdomen activado.",
      "Baja las mancuernas de manera controlada hasta la altura de los hombros.",
      "Repite sin bloquear los codos completamente arriba."
    ],
    "eccentric_calf_raise_v1": [
      "De pie en el borde de un escalón con la mitad del pie, agarrándose a una pared para equilibrarse.",
      "Sube de puntillas con ambas piernas y baja lentamente en 4–5 seg con una sola pierna, dejando que el talón caiga por debajo del nivel del escalón.",
      "Vuelve con ambas piernas y repite. Progresa añadiendo carga o aumentando repeticiones."
    ],
    "kb_clean_v1": [
      "Empieza con la kettlebell en el suelo entre los pies, flexiona las caderas y agárrala con una mano.",
      "Empuja las caderas hacia delante para subir la kettlebell, guiando el codo hacia atrás mientras la campana rota alrededor de la muñeca.",
      "Recibe la kettlebell en posición rack en el hombro y vuelve al suelo."
    ],
    "kb_farmer_carry_v1": [
      "Sostén una kettlebell pesada en cada mano a los lados, hombros fijos y costillas hacia abajo.",
      "Camina hacia delante con pasos controlados durante la distancia o tiempo prescritos.",
      "Deja las kettlebells en el suelo con una flexión de caderas, no las dejes caer."
    ],
    "kb_goblet_squat_v1": [
      "Sostén una kettlebell a la altura del pecho con ambas manos sujetando la campana.",
      "Realiza la sentadilla manteniendo el pecho alto y los codos siguiendo por dentro de las rodillas.",
      "Levántate empujando por la planta del pie."
    ],
    "kb_halo_v1": [
      "Sostén una kettlebell ligera invertida por los cuernos a la altura del pecho.",
      "Haz círculos con la kettlebell alrededor de la cabeza pegada al cráneo con los codos flexionados.",
      "Invierte la dirección a mitad de la serie."
    ],
    "kb_press_v1": [
      "De pie con la kettlebell en posición rack en el hombro, codo pegado al cuerpo y la otra mano al costado.",
      "Empuja la kettlebell hacia arriba hasta extender completamente el brazo con el bíceps cerca de la oreja.",
      "Baja en 2–3 segundos al rack y completa las repeticiones antes de cambiar."
    ],
    "kb_swing_v1": [
      "De pie con los pies al ancho de hombros y la kettlebell en el suelo a un pie de distancia delante.",
      "Flexiona las caderas, agarra la kettlebell con ambas manos y pásala entre las piernas.",
      "Empuja las caderas hacia delante explosivamente para columpiar la kettlebell hasta la altura del pecho y deja que vuelva a la siguiente repetición."
    ],
    "kb_turkish_get_up_v1": [
      "Túmbate boca arriba con un brazo sosteniendo una kettlebell sobre la cabeza, misma rodilla flexionada y pie apoyado.",
      "Levántate hasta el codo, luego hasta la mano, y pasa la pierna recta por debajo hasta arrodillarte, manteniendo la kettlebell sobre el hombro.",
      "Ponte de pie controlado y revierte todos los pasos hasta el suelo; alterna lados."
    ],
    "kb_windmill_v1": [
      "De pie con los pies más abiertos que los hombros y una kettlebell ligera presionada sobre la cabeza con una mano.",
      "Rota los pies 45° hacia el lado de la mano libre y desliza esa mano por la cara interna de la pierna mientras empujas la cadera hacia el lado cargado.",
      "Vuelve al inicio contrayendo oblicuos y glúteos; cambia de lado."
    ],
    "Lat_Pulldown": [
      "Siéntate en la máquina de polea alta con los muslos fijados bajo las almohadillas.",
      "Agarra la barra con las manos más abiertas que los hombros.",
      "Tira de la barra hacia abajo hasta el pecho, contrayendo la espalda.",
      "Mantén el pecho erguido y los hombros hacia atrás.",
      "Retorna la barra de manera controlada a la posición inicial."
    ],
    "lateral_step_down_v1": [
      "De pie sobre un escalón o caja (10–20 cm), con el pie de control al lado del suelo.",
      "Flexiona lentamente la rodilla de apoyo para bajar el otro pie hacia el suelo en 3–4 segundos, manteniendo la rodilla alineada sobre el segundo dedo.",
      "Toca el suelo sin transferir el peso; empuja para volver. Controla que la cadera no caiga al lado."
    ],
    "Lying_Leg_Curls": [
      "Sitúate boca abajo en la máquina de piernas con los tobillos bajo las almohadillas.",
      "Agarra las asas laterales para estabilizarte.",
      "Flexiona las rodillas para llevar las almohadillas hacia los glúteos.",
      "Mantén la contracción un momento arriba.",
      "Baja lentamente a la posición inicial."
    ],
    "nordic_curl_v1": [
      "Arrodíllate con los tobillos sujetos bajo un banco, barra o por un compañero.",
      "Manteniendo el cuerpo recto desde las rodillas hasta la cabeza, inclínate hacia adelante lentamente (3–5 seg), cediendo la resistencia de los isquiotibiales.",
      "Cuando no puedas controlar la caída, usa las manos para frenarte y empuja para volver. Progresa desde movimientos parciales a completos."
    ],
    "pigeon_pose_v1": [
      "Desde cuadrupedia, lleva la rodilla derecha hacia adelante y déjala caer hacia el exterior de la mano derecha; extiende la pierna izquierda hacia atrás.",
      "Baja la cadera derecha hacia el suelo o aproximate tanto como puedas sin dolor; puede ayudar un bloque o una manta doblada bajo la cadera.",
      "Mantén de 30 a 60 segundos de cada lado, respirando lentamente; evita compensar inclinando el tronco hacia un lado."
    ],
    "Plank": [
      "Sitúate en posición de flexión con los antebrazos en el suelo.",
      "Mantén el cuerpo en línea recta desde la cabeza hasta los talones.",
      "Activa el abdomen y evita que las caderas caigan o se eleven.",
      "Mantén la posición durante el tiempo indicado.",
      "Respira de manera constante durante todo el ejercicio."
    ],
    "postpp_bird_dog_v1": [
      "Empieza a cuatro patas con muñecas bajo hombros y rodillas bajo caderas (columna neutra).",
      "Activa suavemente el core y extiende simultáneamente el brazo y la pierna opuestos hasta quedar paralelos al suelo.",
      "Mantén 2 segundos, vuelve con control y alterna lados por las repeticiones indicadas."
    ],
    "postpp_clamshell_band_v1": [
      "Túmbate de lado con caderas y rodillas flexionadas a unos 45 grados. Coloca una banda elástica justo por encima de las rodillas.",
      "Manteniendo los pies juntos y la pelvis estable, rota la rodilla superior hacia arriba sin volcar la cadera.",
      "Baja la rodilla con control y repite. Cambia de lado."
    ],
    "postpp_glute_bridge_march_v1": [
      "Tumbado/a boca arriba con rodillas flexionadas y pies planos. Empuja con los talones para elevar las caderas en posición de puente.",
      "Manteniendo las caderas niveladas y el core activo, levanta lentamente un pie un centímetro del suelo (movimiento de marcha) y bájalo.",
      "Alterna pies por las repeticiones indicadas manteniendo la altura del puente constante."
    ],
    "postpp_heel_slides_v1": [
      "Tumbado/a boca arriba con rodillas flexionadas y pies planos. Activa ligeramente el abdomen inferior.",
      "Desliza lentamente un talón hasta estirar parcialmente la pierna y vuelve a la posición inicial con control.",
      "Alterna lado por el número de repeticiones indicadas, manteniendo la activación del core."
    ],
    "postpp_modified_plank_knees_v1": [
      "Apoyado/a sobre los antebrazos y rodillas formando una línea recta desde los hombros hasta las rodillas.",
      "Activa suavemente el core y mantén la posición respirando normalmente el tiempo indicado.",
      "Progresa aumentando el tiempo de mantenimiento o pasando a la punta de los pies cuando sea adecuado y esté autorizado."
    ],
    "postpp_pelvic_tilt_supine_v1": [
      "Tumbado/a boca arriba con rodillas flexionadas y pies planos en el suelo.",
      "Inclina suavemente la pelvis para aplanar la espalda lumbar contra el suelo activando el abdomen inferior.",
      "Mantén la posición el tiempo indicado respirando regularmente. Repite la serie."
    ],
    "postpp_standing_pelvic_tilt_v1": [
      "De pie con los pies a la anchura de las caderas y columna neutra. Suaviza ligeramente las rodillas.",
      "Inclina la pelvis hacia abajo activando el abdomen inferior, reduciendo ligeramente la lordosis lumbar.",
      "Mantén brevemente y vuelve a neutro. Haz repeticiones pequeñas y controladas."
    ],
    "postpp_ta_bracing_supine_v1": [
      "Tumbado/a boca arriba con rodillas flexionadas. Las manos pueden reposar sobre la pelvis.",
      "Lleva suavemente el abdomen inferior hacia la columna (contracción corta y sutil) sin retener el aliento.",
      "Mantén la contracción ligera el tiempo indicado respirando normalmente. Repite la serie."
    ],
    "postpp_wall_sit_isometric_v1": [
      "De pie con la espalda plana contra la pared y pies a la anchura de las caderas, a unos 60 cm de la pared.",
      "Deslízate hacia abajo hasta que los muslos queden casi paralelos (o a un ángulo cómodo), manteniendo las rodillas sobre los tobillos.",
      "Mantén la posición el tiempo indicado respirando normalmente y vuelve a subir deslizando."
    ],
    "pullup_neutral_grip_v1": [
      "Cuélgate de mangos paralelos de dominadas con palmas enfrentadas, brazos completamente extendidos.",
      "Tira del pecho hacia la barra empujando los codos abajo y atrás.",
      "Baja en 2–3 segundos hasta la suspensión muerta de forma controlada."
    ],
    "Pushups": [
      "Sitúate en posición de plancha con las manos al ancho de los hombros.",
      "Baja el cuerpo flexionando los codos hasta que el pecho casi toque el suelo.",
      "Mantén el cuerpo en línea recta durante todo el movimiento.",
      "Empuja hacia arriba hasta extender los brazos completamente.",
      "Repite de manera controlada."
    ],
    "resistance_band_row_standing_v1": [
      "Sujeta una banda elástica anclada a la altura de la cadera o con ambos extremos en las manos.",
      "De pie con rodillas ligeramente flexionadas, lleva los codos hacia atrás acercando las manos a los costados del tronco y juntando las escápulas.",
      "Regresa lentamente a la posición inicial con 2 segundos de control."
    ],
    "ring_row_v1": [
      "Coloca las anillas a la altura de la cadera y agárralas con brazos extendidos, cuerpo en línea recta y talones en el suelo.",
      "Tira del pecho hacia las anillas retrayendo las escápulas y flexionando los codos.",
      "Baja en 2 segundos a la extensión completa; eleva los pies sobre un cajón para mayor dificultad."
    ],
    "seated_marching_v1": [
      "Siéntate erguido en una silla con los pies en el suelo y las manos sobre los muslos o a los lados.",
      "Levanta alternadamente cada rodilla hacia el pecho hasta la altura de la cadera, como si marcharas sentado.",
      "Mantén el tronco estable y la columna alargada durante todo el movimiento."
    ],
    "seated_spinal_twist_v1": [
      "Siéntate en el suelo con las piernas extendidas. Flexiona la rodilla derecha y coloca el pie plano en el suelo fuera de la rodilla izquierda.",
      "Pon la mano izquierda en la rodilla derecha y gira el tronco hacia la derecha, colocando la mano derecha detrás de la espalda como apoyo.",
      "Mantén 30 segundos girando un poco más con cada exhalación; vuelve al centro y repite al otro lado."
    ],
    "single_leg_squat_v1": [
      "De pie sobre una pierna, la otra ligeramente al frente o al lado, brazos extendidos para el equilibrio.",
      "Flexiona lentamente la rodilla de apoyo hasta donde sea posible sin que colapse hacia dentro o la cadera caiga.",
      "Vuelve a la posición inicial empujando por el talón. Progresa con la mano en la pared hasta dominar el movimiento libre."
    ],
    "sit_to_stand_v1": [
      "Siéntate en una silla con los pies a la anchura de las caderas y planos en el suelo.",
      "Inclina ligeramente el tronco hacia adelante, empuja los talones contra el suelo y levántate hasta quedar completamente erguido.",
      "Controla el descenso volviendo a sentarte lentamente, sin caer sobre la silla."
    ],
    "Standing_Calf_Raises": [
      "Sitúate de pie con los pies al ancho de los hombros.",
      "Elévate sobre los dedos de los pies, apretando los gemelos arriba.",
      "Mantén la posición un segundo arriba.",
      "Baja lentamente hasta la posición inicial.",
      "Repite de manera controlada."
    ],
    "step_up_v1": [
      "Coloca un pie completo sobre un escalón o caja a unos 20–30 cm de altura.",
      "Empuja el talón del pie en el escalón para levantarte, llevando el otro pie al nivel del escalón.",
      "Baja controlando el descenso en 2 seg; alterna piernas o haz todas las reps de un lado primero."
    ],
    "supine_twist_v1": [
      "Estírate boca arriba; lleva ambas rodillas al pecho y déjalas caer suavemente hacia un lado mientras extiendes los brazos en cruz.",
      "Gira la cabeza hacia el lado contrario a las rodillas si es cómodo, para aumentar la rotación torácica.",
      "Mantén 30–45 segundos de cada lado; es normal sentir un progresivo alivio de la tensión lumbar."
    ],
    "thread_the_needle_v1": [
      "Comienza en cuadrupedia con las caderas sobre las rodillas y los hombros sobre las muñecas.",
      "Desliza un brazo por debajo del cuerpo, girando el tronco, hasta que el hombro y el lado de la cabeza lleguen al suelo.",
      "Mantén 2–3 segundos sintiendo el estiramiento torácico, vuelve a la posición inicial y repite al otro lado."
    ],
    "wall_push_up_v1": [
      "Colócate de pie frente a una pared a unos 60 cm, con las manos a la altura de los hombros y ligeramente separadas.",
      "Flexiona los codos hasta que el pecho se acerque a la pared manteniendo el cuerpo recto como una tabla.",
      "Empuja la pared para volver a la posición inicial controlando el movimiento en todo momento."
    ],
    "world_greatest_stretch_v1": [
      "Da un paso largo hacia adelante con el pie derecho hasta una postura de zancada baja; coloca la mano izquierda en el suelo justo al lado del pie derecho.",
      "Gira el tronco hacia la derecha llevando el brazo derecho hacia arriba al cielo, abriendo el pecho y mirando el pulgar.",
      "Vuelve la mano al suelo, extiende la pierna delantera para sentir el estiramiento de isquiotibiales, y vuelve a la postura de zancada. Haz 3–5 reps por lado."
    ]
  }
}
